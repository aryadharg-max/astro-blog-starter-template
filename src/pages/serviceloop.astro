---
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ServiceLoop | Employee Feedback & Incentive System</title>
    <meta
      name="description"
      content="A live proof of concept for transaction-linked employee reviews, customer feedback capture, and incentive-ready service scoring."
    />

    <style>
      :root {
        --bg: #f3efe7;
        --bg2: #e7dccd;
        --ink: #11110f;
        --muted: #70685d;
        --line: rgba(17, 17, 15, 0.12);
        --line2: rgba(17, 17, 15, 0.2);
        --panel: rgba(255, 255, 255, 0.68);
        --panel2: rgba(255, 255, 255, 0.86);
        --dark: #10100e;
        --navy: #0b243f;
        --blue: #143d68;
        --green: #167a55;
        --red: #d63d31;
        --gold: #ad7e2b;
        --yellow: #d49b1f;
        --shadow: 0 34px 90px rgba(17, 17, 15, 0.12);
        --soft: 0 16px 42px rgba(17, 17, 15, 0.08);
        --radius-xl: 34px;
        --radius-lg: 26px;
        --radius-md: 18px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        color: var(--ink);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at 15% 0%, rgba(11, 36, 63, 0.12), transparent 34rem),
          radial-gradient(circle at 90% 12%, rgba(214, 61, 49, 0.08), transparent 28rem),
          linear-gradient(180deg, var(--bg), var(--bg2));
      }

      body.locked {
        overflow: hidden;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button,
      input,
      select,
      textarea {
        font: inherit;
      }

      button {
        cursor: pointer;
      }

      .noise {
        position: fixed;
        inset: 0;
        z-index: -1;
        opacity: 0.21;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(17, 17, 15, 0.035) 1px, transparent 1px),
          linear-gradient(90deg, rgba(17, 17, 15, 0.035) 1px, transparent 1px);
        background-size: 42px 42px;
        mask-image: linear-gradient(to bottom, black, transparent 95%);
      }

      .shell {
        width: min(1440px, calc(100% - 32px));
        margin: 0 auto;
      }

      .topbar {
        position: sticky;
        top: 12px;
        z-index: 50;
        margin-top: 12px;
        border: 1px solid var(--line);
        border-radius: 22px;
        background: rgba(243, 239, 231, 0.82);
        backdrop-filter: blur(24px);
        min-height: 66px;
        padding: 10px 12px;
        box-shadow: 0 16px 38px rgba(17, 17, 15, 0.08);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .brand-mark {
        width: 44px;
        height: 44px;
        border-radius: 15px;
        background:
          radial-gradient(circle at 28% 18%, rgba(255, 255, 255, 0.46), transparent 22px),
          linear-gradient(135deg, var(--navy), #061421);
        color: white;
        display: grid;
        place-items: center;
        font-weight: 950;
        letter-spacing: -0.08em;
      }

      .brand strong {
        display: block;
        letter-spacing: -0.04em;
      }

      .brand span {
        display: block;
        margin-top: 3px;
        color: var(--muted);
        font-size: 12px;
      }

      .nav-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .nav-actions a,
      .nav-actions button {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.62);
        color: var(--muted);
        border-radius: 999px;
        padding: 10px 12px;
        font-weight: 850;
        font-size: 13px;
        transition: 0.18s ease;
      }

      .nav-actions a:hover,
      .nav-actions button:hover {
        color: var(--ink);
        border-color: var(--line2);
        background: rgba(255, 255, 255, 0.86);
      }

      .hero {
        padding: clamp(38px, 6vw, 94px) 0 46px;
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(360px, 0.9fr);
        gap: 16px;
        min-height: calc(100vh - 95px);
      }

      .glass {
        border: 1px solid var(--line);
        background: var(--panel);
        backdrop-filter: blur(24px);
        box-shadow: var(--shadow);
      }

      .hero-main {
        border-radius: var(--radius-xl);
        padding: clamp(24px, 5vw, 58px);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
        min-height: 690px;
      }

      .hero-main::before {
        content: "";
        position: absolute;
        inset: 20px;
        border: 1px solid rgba(17, 17, 15, 0.08);
        border-radius: 26px;
        pointer-events: none;
      }

      .sweep {
        position: absolute;
        left: -18%;
        bottom: 18%;
        width: 140%;
        height: 100px;
        background:
          linear-gradient(104deg, transparent 0 22%, rgba(214, 61, 49, 0.42) 22.3% 23%, transparent 23.3% 100%),
          linear-gradient(104deg, transparent 0 50%, rgba(11, 36, 63, 0.16) 50.3% 51%, transparent 51.3% 100%);
        transform: rotate(-7deg);
        pointer-events: none;
        opacity: 0.72;
      }

      .hero-content,
      .proof-row {
        position: relative;
        z-index: 1;
      }

      .pill-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 30px;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.6);
        color: var(--muted);
        border-radius: 999px;
        padding: 9px 12px;
        font-weight: 850;
        font-size: 13px;
      }

      .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--green);
        box-shadow: 0 0 0 7px rgba(22, 122, 85, 0.13);
      }

      .kicker {
        margin: 0 0 14px;
        color: var(--red);
        font-family:
          "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco,
          Consolas, monospace;
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.16em;
      }

      h1 {
        margin: 0;
        max-width: 980px;
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(54px, 8vw, 126px);
        font-weight: 500;
        line-height: 0.86;
        letter-spacing: -0.075em;
      }

      h1 em {
        color: var(--red);
        font-style: italic;
      }

      .hero-copy {
        margin: 30px 0 0;
        color: var(--muted);
        font-size: clamp(17px, 2vw, 22px);
        line-height: 1.55;
        max-width: 850px;
      }

      .hero-copy strong {
        color: var(--ink);
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 34px;
      }

      .btn {
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 13px 16px;
        background: rgba(255, 255, 255, 0.68);
        color: var(--ink);
        font-weight: 900;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition:
          transform 0.16s ease,
          border-color 0.16s ease,
          box-shadow 0.16s ease,
          background 0.16s ease;
      }

      .btn:hover {
        transform: translateY(-2px);
        border-color: var(--line2);
        box-shadow: 0 16px 36px rgba(17, 17, 15, 0.1);
      }

      .btn.primary {
        background: linear-gradient(135deg, var(--navy), #061421);
        color: white;
        border-color: rgba(11, 36, 63, 0.7);
      }

      .btn.red {
        background: linear-gradient(135deg, var(--red), #8f1e19);
        border-color: rgba(214, 61, 49, 0.52);
        color: white;
      }

      .btn.small {
        padding: 10px 12px;
        border-radius: 14px;
        font-size: 13px;
      }

      .proof-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
        margin-top: 48px;
      }

      .proof {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.58);
        border-radius: 20px;
        padding: 16px;
        min-height: 136px;
        display: grid;
        align-content: space-between;
      }

      .proof span {
        color: var(--muted);
        font-size: 11px;
        font-weight: 850;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .proof strong {
        display: block;
        margin-top: 18px;
        font-size: 17px;
        letter-spacing: -0.04em;
        line-height: 1.15;
      }

      .side-panel {
        border-radius: var(--radius-xl);
        padding: 18px;
        display: grid;
        gap: 14px;
        min-height: 690px;
      }

      .black-card {
        border-radius: 28px;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.06), transparent),
          var(--dark);
        color: white;
        padding: 20px;
        min-height: 440px;
        position: relative;
        overflow: hidden;
        display: grid;
        align-content: space-between;
      }

      .black-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.048) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.048) 1px, transparent 1px);
        background-size: 31px 31px;
        opacity: 0.5;
      }

      .black-card > * {
        position: relative;
        z-index: 1;
      }

      .mini-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        color: rgba(255, 255, 255, 0.58);
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.13em;
      }

      .black-card h2 {
        margin: 24px 0 0;
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(40px, 5vw, 70px);
        font-weight: 500;
        line-height: 0.9;
        letter-spacing: -0.07em;
      }

      .black-card p {
        color: rgba(255, 255, 255, 0.64);
        line-height: 1.5;
      }

      .flow {
        display: grid;
        gap: 10px;
        margin-top: 26px;
      }

      .flow-item {
        border: 1px solid rgba(255, 255, 255, 0.13);
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.06);
        padding: 14px;
        display: grid;
        grid-template-columns: 92px 1fr;
        gap: 12px;
        align-items: center;
      }

      .flow-item span {
        color: rgba(255, 255, 255, 0.55);
        font-size: 11px;
        font-weight: 850;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .flow-item strong {
        line-height: 1.25;
      }

      .mini-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
      }

      .mini-card {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.58);
        border-radius: 24px;
        padding: 18px;
        min-height: 190px;
      }

      .mini-card span {
        color: var(--muted);
        font-size: 11px;
        font-weight: 850;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .mini-card strong {
        display: block;
        margin-top: 22px;
        font-family: Georgia, "Times New Roman", serif;
        font-size: 32px;
        font-weight: 500;
        letter-spacing: -0.06em;
        line-height: 0.95;
      }

      .mini-card p {
        margin: 10px 0 0;
        color: var(--muted);
        line-height: 1.43;
        font-size: 14px;
      }

      section {
        padding: 56px 0;
      }

      .section-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: 22px;
      }

      .section-head h2 {
        margin: 0;
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(42px, 6vw, 90px);
        font-weight: 500;
        line-height: 0.86;
        letter-spacing: -0.075em;
      }

      .section-head p {
        margin: 0;
        max-width: 620px;
        color: var(--muted);
        font-size: 16px;
        line-height: 1.55;
      }

      .workspace {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: 14px;
      }

      .card {
        border: 1px solid var(--line);
        background: var(--panel);
        backdrop-filter: blur(24px);
        border-radius: var(--radius-xl);
        box-shadow: var(--soft);
        padding: 20px;
      }

      .card h3 {
        margin: 0;
        font-size: 22px;
        letter-spacing: -0.055em;
      }

      .card p {
        color: var(--muted);
        line-height: 1.48;
      }

      .field-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
      }

      label {
        display: block;
        margin: 0 0 6px;
        color: var(--muted);
        font-size: 11px;
        font-weight: 850;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      input,
      select,
      textarea {
        width: 100%;
        border: 1px solid var(--line);
        border-radius: 15px;
        background: rgba(255, 255, 255, 0.84);
        color: var(--ink);
        outline: none;
        padding: 12px;
      }

      textarea {
        min-height: 106px;
        resize: vertical;
      }

      input:focus,
      select:focus,
      textarea:focus {
        border-color: rgba(20, 61, 104, 0.36);
        box-shadow: 0 0 0 4px rgba(20, 61, 104, 0.08);
      }

      .qr-box {
        margin-top: 14px;
        border: 1px solid var(--line);
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.62);
        padding: 16px;
        display: grid;
        grid-template-columns: 160px 1fr;
        gap: 16px;
        align-items: center;
      }

      .qr-box img {
        width: 160px;
        height: 160px;
        border-radius: 18px;
        background: white;
        padding: 10px;
        border: 1px solid var(--line);
      }

      .link-box {
        word-break: break-all;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.45;
      }

      .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
        margin-bottom: 12px;
      }

      .metric {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.62);
        border-radius: 20px;
        padding: 15px;
      }

      .metric span {
        color: var(--muted);
        font-size: 11px;
        font-weight: 850;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .metric strong {
        display: block;
        margin-top: 10px;
        font-size: 28px;
        letter-spacing: -0.06em;
      }

      .employee-list,
      .review-list {
        display: grid;
        gap: 10px;
      }

      .employee-card,
      .review-card {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.58);
        border-radius: 20px;
        padding: 14px;
      }

      .employee-card {
        display: grid;
        grid-template-columns: 46px 1fr auto;
        gap: 12px;
        align-items: center;
      }

      .avatar {
        width: 46px;
        height: 46px;
        border-radius: 16px;
        background: var(--navy);
        color: white;
        display: grid;
        place-items: center;
        font-weight: 950;
        letter-spacing: -0.06em;
      }

      .employee-card strong,
      .review-card strong {
        display: block;
        letter-spacing: -0.035em;
      }

      .employee-card small,
      .review-card small {
        color: var(--muted);
        line-height: 1.45;
      }

      .score {
        text-align: right;
      }

      .score strong {
        font-size: 26px;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.68);
        color: var(--muted);
        padding: 7px 9px;
        font-size: 12px;
        font-weight: 850;
        white-space: nowrap;
      }

      .badge.green {
        color: var(--green);
        border-color: rgba(22, 122, 85, 0.22);
      }

      .badge.red {
        color: var(--red);
        border-color: rgba(214, 61, 49, 0.22);
      }

      .divider {
        height: 1px;
        background: var(--line);
        margin: 16px 0;
      }

      .review-view {
        display: none;
        min-height: 100vh;
        place-items: center;
        padding: 40px 0;
      }

      body.review-mode .review-view {
        display: grid;
      }

      body.review-mode .platform-view {
        display: none;
      }

      .review-shell {
        width: min(760px, calc(100% - 28px));
      }

      .review-card-main {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.78);
        backdrop-filter: blur(24px);
        border-radius: 36px;
        box-shadow: var(--shadow);
        padding: clamp(22px, 5vw, 44px);
      }

      .review-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 28px;
      }

      .employee-strip {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.58);
        border-radius: 22px;
        padding: 14px;
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 18px;
      }

      .review-card-main h1 {
        font-size: clamp(44px, 8vw, 82px);
      }

      .stars {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 8px;
        margin: 18px 0;
      }

      .star {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.72);
        border-radius: 18px;
        min-height: 64px;
        font-size: 32px;
        color: rgba(17, 17, 15, 0.25);
        transition: 0.16s ease;
      }

      .star.active {
        color: var(--gold);
        background: rgba(255, 255, 255, 0.94);
        border-color: rgba(173, 126, 43, 0.28);
        transform: translateY(-2px);
      }

      .trait-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 12px 0 18px;
      }

      .trait {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.62);
        border-radius: 999px;
        padding: 10px 12px;
        color: var(--muted);
        font-weight: 850;
      }

      .trait.active {
        color: white;
        background: var(--navy);
        border-color: var(--navy);
      }

      .success-panel,
      .already-panel {
        display: none;
        border: 1px solid rgba(22, 122, 85, 0.22);
        background: rgba(22, 122, 85, 0.08);
        border-radius: 22px;
        padding: 18px;
        margin-top: 16px;
      }

      .already-panel {
        border-color: rgba(214, 61, 49, 0.22);
        background: rgba(214, 61, 49, 0.07);
      }

      .success-panel.show,
      .already-panel.show {
        display: block;
      }

      .requirements {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
      }

      .requirement {
        border: 1px solid var(--line);
        background: var(--panel);
        border-radius: 24px;
        padding: 18px;
      }

      .requirement span {
        color: var(--red);
        font-size: 11px;
        font-weight: 900;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .requirement h3 {
        margin: 22px 0 0;
        font-size: 22px;
        letter-spacing: -0.05em;
      }

      .requirement p {
        color: var(--muted);
        line-height: 1.48;
      }

      .toast {
        position: fixed;
        right: 18px;
        bottom: 18px;
        background: var(--dark);
        color: white;
        padding: 14px 16px;
        border-radius: 18px;
        box-shadow: var(--shadow);
        opacity: 0;
        transform: translateY(14px);
        pointer-events: none;
        transition: 0.18s ease;
        z-index: 100;
        max-width: 360px;
      }

      .toast.show {
        opacity: 1;
        transform: translateY(0);
      }

      @media (max-width: 1120px) {
        .hero,
        .workspace {
          grid-template-columns: 1fr;
        }

        .hero-main,
        .side-panel {
          min-height: auto;
        }

        .requirements {
          grid-template-columns: 1fr 1fr;
        }
      }

      @media (max-width: 760px) {
        .topbar,
        .review-top,
        .section-head {
          align-items: flex-start;
          flex-direction: column;
        }

        .nav-actions {
          justify-content: flex-start;
        }

        .proof-row,
        .mini-grid,
        .dashboard-grid,
        .field-grid,
        .requirements {
          grid-template-columns: 1fr;
        }

        .qr-box {
          grid-template-columns: 1fr;
        }

        .employee-card {
          grid-template-columns: 46px 1fr;
        }

        .score {
          grid-column: 2;
          text-align: left;
        }

        .stars {
          gap: 6px;
        }

        .star {
          min-height: 54px;
          font-size: 26px;
        }
      }
    </style>
  </head>

  <body>
    <div class="noise"></div>

    <div class="review-view" id="reviewView">
      <div class="review-shell">
        <div class="review-card-main">
          <div class="review-top">
            <a class="brand" href="/serviceloop/">
              <div class="brand-mark">SL</div>
              <div>
                <strong>ServiceLoop</strong>
                <span>Employee Feedback</span>
