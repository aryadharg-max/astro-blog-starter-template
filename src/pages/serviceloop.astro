    <script is:inline>
      const employees = [
        {
          id: "EMP-014",
          name: "Aarav Malhotra",
          role: "Sales Associate",
          zone: "Electronics",
          initials: "AM",
        },
        {
          id: "EMP-021",
          name: "Meera Kapoor",
          role: "Senior Associate",
          zone: "Fashion",
          initials: "MK",
        },
        {
          id: "EMP-033",
          name: "Rohan Sen",
          role: "Floor Executive",
          zone: "Food Court",
          initials: "RS",
        },
        {
          id: "EMP-047",
          name: "Kabir Anand",
          role: "Client Advisor",
          zone: "Luxury Arcade",
          initials: "KA",
        },
      ];

      const STORAGE_KEY = "serviceloop_reviews_v1";

      const $ = (id) => document.getElementById(id);
      const $$ = (selector, root = document) => Array.from(root.querySelectorAll(selector));

      const el = {
        employeeSelect: $("employeeSelect"),
        storeSelect: $("storeSelect"),
        amountInput: $("amountInput"),
        channelSelect: $("channelSelect"),
        generateButton: $("generateButton"),
        qrBox: $("qrBox"),
        qrImage: $("qrImage"),
        generatedLink: $("generatedLink"),
        generatedChannel: $("generatedChannel"),
        copyButton: $("copyButton"),
        openReviewLink: $("openReviewLink"),
        openSampleReview: $("openSampleReview"),

        totalReviews: $("totalReviews"),
        averageRating: $("averageRating"),
        positiveReviews: $("positiveReviews"),
        flaggedReviews: $("flaggedReviews"),
        employeeList: $("employeeList"),
        reviewList: $("reviewList"),
        seedButton: $("seedButton"),
        resetButton: $("resetButton"),

        reviewStore: $("reviewStore"),
        reviewAvatar: $("reviewAvatar"),
        reviewEmployee: $("reviewEmployee"),
        reviewMeta: $("reviewMeta"),
        reviewForm: $("reviewForm"),
        comment: $("comment"),
        successPanel: $("successPanel"),
        alreadyPanel: $("alreadyPanel"),

        toast: $("toast"),
      };

      let currentRating = 0;
      let generatedUrl = "";
      let currentReviewContext = null;

      function toast(message) {
        el.toast.textContent = message;
        el.toast.classList.add("show");

        clearTimeout(el.toast._timer);
        el.toast._timer = setTimeout(() => {
          el.toast.classList.remove("show");
        }, 2200);
      }

      function money(value) {
        return new Intl.NumberFormat("en-IN", {
          style: "currency",
          currency: "INR",
          maximumFractionDigits: 0,
        }).format(value);
      }

      function nowIso() {
        return new Date().toISOString();
      }

      function timeLabel(iso) {
        const date = new Date(iso);
        return date.toLocaleString("en-IN", {
          day: "2-digit",
          month: "short",
          hour: "2-digit",
          minute: "2-digit",
        });
      }

      function generateTransactionId() {
        const date = new Date();
        const day = String(date.getDate()).padStart(2, "0");
        const month = String(date.getMonth() + 1).padStart(2, "0");
        const random = Math.random().toString(36).slice(2, 8).toUpperCase();

        return `SL-${day}${month}-${random}`;
      }

      function getEmployee(id) {
        return employees.find((employee) => employee.id === id) || employees[0];
      }

      function getReviews() {
        try {
          return JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]");
        } catch {
          return [];
        }
      }

      function saveReviews(reviews) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(reviews));
      }

      function seedReviews() {
        const sample = [
          {
            id: crypto.randomUUID(),
            employeeId: "EMP-014",
            employeeName: "Aarav Malhotra",
            transactionId: "SL-0107-A82KLF",
            store: "North Wing - Electronics",
            amount: 5490,
            channel: "Receipt QR",
            rating: 5,
            traits: ["Helpful", "Product knowledge", "Clear communication"],
            comment: "Explained the options clearly and helped compare two products.",
            createdAt: new Date(Date.now() - 1000 * 60 * 14).toISOString(),
          },
          {
            id: crypto.randomUUID(),
            employeeId: "EMP-021",
            employeeName: "Meera Kapoor",
            transactionId: "SL-0107-F92LQP",
            store: "Central Atrium - Fashion",
            amount: 3200,
            channel: "WhatsApp Link",
            rating: 5,
            traits: ["Fast service", "Helpful"],
            comment: "Very quick billing and polite service.",
            createdAt: new Date(Date.now() - 1000 * 60 * 38).toISOString(),
          },
          {
            id: crypto.randomUUID(),
            employeeId: "EMP-047",
            employeeName: "Kabir Anand",
            transactionId: "SL-0107-P81XDM",
            store: "Luxury Arcade - Watches",
            amount: 18400,
            channel: "Receipt QR",
            rating: 4,
            traits: ["Product knowledge"],
            comment: "Good experience overall.",
            createdAt: new Date(Date.now() - 1000 * 60 * 74).toISOString(),
          },
          {
            id: crypto.randomUUID(),
            employeeId: "EMP-033",
            employeeName: "Rohan Sen",
            transactionId: "SL-0107-Z18RMQ",
            store: "Food Court - Counter 4",
            amount: 780,
            channel: "SMS Link",
            rating: 2,
            traits: ["Needs improvement"],
            comment: "Order took longer than expected.",
            createdAt: new Date(Date.now() - 1000 * 60 * 110).toISOString(),
          },
          {
            id: crypto.randomUUID(),
            employeeId: "EMP-014",
            employeeName: "Aarav Malhotra",
            transactionId: "SL-0107-Q74MNA",
            store: "North Wing - Electronics",
            amount: 2450,
            channel: "Receipt QR",
            rating: 4,
            traits: ["Billing support", "Helpful"],
            comment: "",
            createdAt: new Date(Date.now() - 1000 * 60 * 180).toISOString(),
          },
        ];

        saveReviews(sample);
        renderDashboard();
        toast("Sample data loaded");
      }

      function calculateEmployeeStats(employee, reviews) {
        const own = reviews.filter((review) => review.employeeId === employee.id);
        const count = own.length;
        const average = count
          ? own.reduce((sum, review) => sum + review.rating, 0) / count
          : 0;

        const positive = own.filter((review) => review.rating >= 4).length;
        const low = own.filter((review) => review.rating <= 2).length;

        const score = Math.max(0, Math.round(average * 18 + positive * 7 - low * 10));
        const incentive = score * 25;

        return {
          count,
          average,
          positive,
          low,
          score,
          incentive,
        };
      }

      function renderDashboard() {
        const reviews = getReviews();
        const total = reviews.length;
        const average = total
          ? reviews.reduce((sum, review) => sum + review.rating, 0) / total
          : 0;

        const positive = reviews.filter((review) => review.rating >= 4).length;
        const flagged = reviews.filter((review) => review.rating <= 2).length;

        el.totalReviews.textContent = total;
        el.averageRating.textContent = average.toFixed(1);
        el.positiveReviews.textContent = positive;
        el.flaggedReviews.textContent = flagged;

        const employeesWithStats = employees
          .map((employee) => ({
            ...employee,
            stats: calculateEmployeeStats(employee, reviews),
          }))
          .sort((a, b) => b.stats.score - a.stats.score);

        el.employeeList.innerHTML = employeesWithStats
          .map((employee) => {
            const avg = employee.stats.count ? employee.stats.average.toFixed(1) : "—";

            return `
              <div class="employee-card">
                <div class="avatar">${employee.initials}</div>
                <div>
                  <strong>${employee.name}</strong>
                  <small>${employee.role} · ${employee.zone}<br />${employee.stats.count} reviews · ${avg} average · ${money(employee.stats.incentive)} demo incentive</small>
                </div>
                <div class="score">
                  <span class="badge ${employee.stats.low ? "red" : "green"}">${employee.stats.low ? `${employee.stats.low} flag` : "clean"}</span>
                  <strong>${employee.stats.score}</strong>
                  <small>score</small>
                </div>
              </div>
            `;
          })
          .join("");

        const sorted = [...reviews].sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));

        el.reviewList.innerHTML =
          sorted.slice(0, 8).map((review) => {
            const badgeClass = review.rating <= 2 ? "red" : "green";
            const traits = review.traits?.length ? review.traits.join(", ") : "No tags";
            const comment = review.comment ? `“${review.comment}”` : "No written comment.";

            return `
              <div class="review-card">
                <div style="display: flex; justify-content: space-between; gap: 12px; align-items: center;">
                  <strong>${review.employeeName}</strong>
                  <span class="badge ${badgeClass}">${review.rating}/5</span>
                </div>
                <small>
                  ${review.store} · ${review.transactionId} · ${timeLabel(review.createdAt)}<br />
                  ${traits}<br />
                  ${comment}
                </small>
              </div>
            `;
          }).join("") || `
            <div class="review-card">
              <strong>No reviews yet</strong>
              <small>Generate a review link and submit the customer form to populate the dashboard.</small>
            </div>
          `;
      }

      function populateEmployees() {
        el.employeeSelect.innerHTML = employees
          .map((employee) => {
            return `<option value="${employee.id}">${employee.name} — ${employee.zone}</option>`;
          })
          .join("");
      }

      function buildReviewUrl({ employeeId, transactionId, store, amount, channel }) {
        const url = new URL(window.location.origin + "/serviceloop/");
        url.searchParams.set("review", "1");
        url.searchParams.set("employee", employeeId);
        url.searchParams.set("tx", transactionId);
        url.searchParams.set("store", store);
        url.searchParams.set("amount", amount);
        url.searchParams.set("channel", channel);

        return url.toString();
      }

      function generateReviewLink() {
        const employeeId = el.employeeSelect.value;
        const transactionId = generateTransactionId();
        const store = el.storeSelect.value;
        const amount = Number(el.amountInput.value || 0);
        const channel = el.channelSelect.value;

        generatedUrl = buildReviewUrl({
          employeeId,
          transactionId,
          store,
          amount,
          channel,
        });

        el.generatedLink.textContent = generatedUrl;
        el.generatedChannel.textContent = channel;
        el.openReviewLink.href = generatedUrl;
        el.qrImage.src = `https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=${encodeURIComponent(generatedUrl)}`;
        el.qrBox.style.display = "grid";

        toast("Transaction review link generated");
      }

      async function copyGeneratedLink() {
        if (!generatedUrl) return;

        try {
          await navigator.clipboard.writeText(generatedUrl);
          toast("Review link copied");
        } catch {
          toast("Copy failed. Select the link manually.");
        }
      }

      function setupReviewMode() {
        const params = new URLSearchParams(window.location.search);

        if (params.get("review") !== "1") return;

        document.body.classList.add("review-mode");

        const employeeId = params.get("employee") || employees[0].id;
        const employee = getEmployee(employeeId);
        const transactionId = params.get("tx") || generateTransactionId();
        const store = params.get("store") || "Demo Store";
        const amount = Number(params.get("amount") || 0);
        const channel = params.get("channel") || "Review Link";

        currentReviewContext = {
          employee,
          transactionId,
          store,
          amount,
          channel,
        };

        el.reviewStore.textContent = store;
        el.reviewAvatar.textContent = employee.initials;
        el.reviewEmployee.textContent = employee.name;
        el.reviewMeta.textContent = `${employee.role} · ${transactionId}`;

        const duplicate = getReviews().some((review) => review.transactionId === transactionId);

        if (duplicate) {
          el.reviewForm.querySelectorAll("button, textarea").forEach((item) => {
            item.disabled = true;
          });
          el.alreadyPanel.classList.add("show");
        }
      }

      function setRating(rating) {
        currentRating = rating;

        $$(".star").forEach((button) => {
          const value = Number(button.dataset.rating);
          button.classList.toggle("active", value <= rating);
        });
      }

      function submitReview(event) {
        event.preventDefault();

        if (!currentReviewContext) return;

        if (!currentRating) {
          toast("Select a rating first");
          return;
        }

        const existing = getReviews();
        const duplicate = existing.some(
          (review) => review.transactionId === currentReviewContext.transactionId
        );

        if (duplicate) {
          el.alreadyPanel.classList.add("show");
          return;
        }

        const traits = $$(".trait.active").map((item) => item.dataset.trait);

        const review = {
          id: crypto.randomUUID(),
          employeeId: currentReviewContext.employee.id,
          employeeName: currentReviewContext.employee.name,
          transactionId: currentReviewContext.transactionId,
          store: currentReviewContext.store,
          amount: currentReviewContext.amount,
          channel: currentReviewContext.channel,
          rating: currentRating,
          traits,
          comment: el.comment.value.trim(),
          createdAt: nowIso(),
        };

        saveReviews([review, ...existing]);

        el.reviewForm.querySelectorAll("button, textarea").forEach((item) => {
          item.disabled = true;
        });

        el.successPanel.classList.add("show");
        toast("Feedback submitted");
      }

      function bind() {
        el.generateButton.addEventListener("click", generateReviewLink);
        el.copyButton.addEventListener("click", copyGeneratedLink);

        el.openSampleReview.addEventListener("click", () => {
          const url = buildReviewUrl({
            employeeId: "EMP-014",
            transactionId: generateTransactionId(),
            store: "North Wing - Electronics",
            amount: 2450,
            channel: "Demo Link",
          });

          window.open(url, "_blank");
        });

        el.seedButton.addEventListener("click", seedReviews);

        el.resetButton.addEventListener("click", () => {
          localStorage.removeItem(STORAGE_KEY);
          renderDashboard();
          toast("Demo data reset");
        });

        $$(".star").forEach((button) => {
          button.addEventListener("click", () => {
            setRating(Number(button.dataset.rating));
          });
        });

        $$(".trait").forEach((button) => {
          button.addEventListener("click", () => {
            button.classList.toggle("active");
          });
        });

        el.reviewForm.addEventListener("submit", submitReview);
      }

      function init() {
        populateEmployees();
        setupReviewMode();
        bind();

        if (!document.body.classList.contains("review-mode")) {
          renderDashboard();

          if (!getReviews().length) {
            seedReviews();
          }
        }
      }

      init();
    </script>
  </body>
</html>
