---
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ServiceLoop | Employee Feedback & Incentive System</title>
    <meta
      name="description"
      content="ServiceLoop is a transaction-linked employee review and incentive system for malls, retailers, restaurants, and service-led businesses."
    />

    <style>
      :root {
        --bg: #0b0d10;
        --panel: #11151b;
        --panel-2: #171d25;
        --panel-3: #202733;
        --text: #f5f2ea;
        --soft: #cfd6df;
        --muted: #8792a2;
        --line: rgba(255, 255, 255, 0.1);
        --line-strong: rgba(255, 255, 255, 0.18);
        --gold: #d6b46a;
        --gold-2: #f2d990;
        --green: #70d6b7;
        --red: #ff7b7b;
        --blue: #8ab4ff;
        --shadow: 0 28px 90px rgba(0, 0, 0, 0.38);
        --radius-xl: 30px;
        --radius-lg: 22px;
        --radius-md: 16px;
        --max: 1240px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        color: var(--text);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at 16% 0%, rgba(214, 180, 106, 0.16), transparent 34rem),
          radial-gradient(circle at 90% 4%, rgba(112, 214, 183, 0.12), transparent 30rem),
          linear-gradient(180deg, #0b0d10, #08090b);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button,
      input,
      select,
      textarea {
        font: inherit;
      }

      button {
        cursor: pointer;
      }

      .customer-view {
        display: none;
      }

      body.customer-mode .platform-view {
        display: none;
      }

      body.customer-mode .customer-view {
        display: block;
      }

      .shell {
        width: min(var(--max), calc(100% - 36px));
        margin: 0 auto;
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: 20;
        background: rgba(11, 13, 16, 0.78);
        backdrop-filter: blur(18px);
        border-bottom: 1px solid var(--line);
      }

      .nav-inner {
        width: min(var(--max), calc(100% - 36px));
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        padding: 14px 0;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: fit-content;
      }

      .brand-mark {
        width: 40px;
        height: 40px;
        border-radius: 14px;
        background: linear-gradient(135deg, var(--gold-2), #8a6b2e);
        color: #12100a;
        display: grid;
        place-items: center;
        font-weight: 950;
        letter-spacing: -0.08em;
        box-shadow: 0 14px 38px rgba(214, 180, 106, 0.22);
      }

      .brand strong {
        display: block;
        letter-spacing: -0.04em;
      }

      .brand span {
        display: block;
        margin-top: 3px;
        color: var(--muted);
        font-size: 12px;
      }

      .nav-links {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 8px;
        flex-wrap: wrap;
      }

      .nav-links a {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.035);
        color: var(--soft);
        border-radius: 999px;
        padding: 10px 13px;
        font-size: 14px;
        font-weight: 750;
        transition: 160ms ease;
      }

      .nav-links a:hover {
        color: var(--text);
        border-color: rgba(214, 180, 106, 0.45);
        background: rgba(214, 180, 106, 0.09);
      }

      .hero {
        padding: 72px 0 36px;
        display: grid;
        grid-template-columns: 1.08fr 0.92fr;
        gap: 28px;
        align-items: center;
      }

      .eyebrow {
        color: var(--gold);
        text-transform: uppercase;
        font-weight: 850;
        letter-spacing: 0.16em;
        font-size: 12px;
      }

      h1,
      h2,
      h3,
      p {
        margin-top: 0;
      }

      h1 {
        font-size: clamp(48px, 7vw, 86px);
        line-height: 0.9;
        letter-spacing: -0.07em;
        margin-bottom: 18px;
      }

      h2 {
        font-size: clamp(34px, 4vw, 54px);
        line-height: 0.94;
        letter-spacing: -0.055em;
        margin-bottom: 12px;
      }

      h3 {
        font-size: 22px;
        letter-spacing: -0.04em;
        margin-bottom: 10px;
      }

      p {
        color: var(--soft);
        line-height: 1.58;
      }

      .lead {
        font-size: 18px;
        max-width: 780px;
      }

      .actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 24px;
      }

      .btn {
        border: 1px solid transparent;
        border-radius: 15px;
        background: var(--gold);
        color: #14110a;
        padding: 13px 16px;
        font-weight: 850;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: 160ms ease;
      }

      .btn:hover {
        transform: translateY(-1px);
        filter: brightness(1.04);
      }

      .btn.secondary {
        background: rgba(255, 255, 255, 0.06);
        color: var(--text);
        border-color: var(--line);
      }

      .btn.ghost {
        background: transparent;
        color: var(--soft);
        border-color: var(--line);
      }

      .panel {
        border: 1px solid var(--line);
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.025));
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow);
        overflow: hidden;
      }

      .panel-pad {
        padding: 24px;
      }

      .phone {
        width: min(100%, 360px);
        margin: 0 auto;
        border-radius: 34px;
        padding: 14px;
        background: #07080a;
        border: 1px solid rgba(255, 255, 255, 0.13);
        box-shadow: 0 30px 90px rgba(0, 0, 0, 0.58);
      }

      .phone-screen {
        min-height: 440px;
        border-radius: 25px;
        background: linear-gradient(180deg, #f9faf7, #e9edf2);
        color: #141922;
        padding: 18px;
      }

      .phone-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: #6b7280;
        font-size: 12px;
        margin-bottom: 22px;
      }

      .mini-logo {
        width: 46px;
        height: 46px;
        border-radius: 16px;
        background: #141922;
        color: #f2d990;
        display: grid;
        place-items: center;
        font-weight: 950;
        letter-spacing: -0.08em;
        margin-bottom: 22px;
      }

      .phone-screen h3 {
        color: #111827;
        font-size: 26px;
        line-height: 1.02;
      }

      .phone-screen p {
        color: #5b6472;
        font-size: 14px;
      }

      .phone-stars {
        display: flex;
        gap: 5px;
        color: #c39223;
        font-size: 34px;
        margin: 18px 0;
      }

      .phone-chip-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 20px;
      }

      .phone-chip {
        background: #fff;
        border: 1px solid #d9dee6;
        color: #1f2937;
        border-radius: 999px;
        padding: 8px 10px;
        font-size: 12px;
        font-weight: 750;
      }

      .section {
        padding: 56px 0;
      }

      .section-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 22px;
        margin-bottom: 18px;
      }

      .section-head p {
        max-width: 620px;
        margin-bottom: 0;
      }

      .grid-2 {
        display: grid;
        grid-template-columns: 0.95fr 1.05fr;
        gap: 18px;
      }

      .grid-3 {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
      }

      .mini-card,
      .employee-card,
      .review-card,
      .metric {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.045);
        border-radius: var(--radius-lg);
      }

      .mini-card {
        padding: 20px;
      }

      .mini-card span {
        color: var(--gold);
        font-size: 11px;
        font-weight: 850;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .mini-card p {
        margin-bottom: 0;
      }

      label {
        display: block;
        margin-bottom: 7px;
        color: var(--muted);
        font-size: 11px;
        font-weight: 850;
        text-transform: uppercase;
        letter-spacing: 0.11em;
      }

      input,
      select,
      textarea {
        width: 100%;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.055);
        color: var(--text);
        border-radius: 15px;
        padding: 12px;
        outline: none;
      }

      select option {
        background: #11151b;
      }

      textarea {
        min-height: 96px;
        resize: vertical;
      }

      input:focus,
      select:focus,
      textarea:focus {
        border-color: rgba(214, 180, 106, 0.48);
        box-shadow: 0 0 0 4px rgba(214, 180, 106, 0.08);
      }

      .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
      }

      .qr-box {
        display: none;
        grid-template-columns: 150px 1fr;
        gap: 16px;
        align-items: center;
        margin-top: 16px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.04);
        border-radius: var(--radius-lg);
        padding: 16px;
      }

      .qr-box img {
        width: 150px;
        height: 150px;
        border-radius: 18px;
        background: white;
        padding: 10px;
      }

      .link-output {
        word-break: break-all;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.45;
      }

      .metrics {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
        margin-bottom: 14px;
      }

      .metric {
        padding: 15px;
      }

      .metric span {
        display: block;
        color: var(--muted);
        font-size: 11px;
        font-weight: 850;
        text-transform: uppercase;
        letter-spacing: 0.11em;
      }

      .metric strong {
        display: block;
        margin-top: 10px;
        font-size: 30px;
        letter-spacing: -0.06em;
      }

      .dashboard-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
      }

      .employee-list,
      .review-list {
        display: grid;
        gap: 10px;
      }

      .employee-card {
        padding: 14px;
        display: grid;
        grid-template-columns: 46px 1fr auto;
        gap: 12px;
        align-items: center;
      }

      .review-card {
        padding: 14px;
      }

      .avatar {
        width: 46px;
        height: 46px;
        border-radius: 16px;
        background: linear-gradient(135deg, var(--gold), #7f642c);
        color: #14110a;
        display: grid;
        place-items: center;
        font-weight: 950;
        letter-spacing: -0.08em;
      }

      .employee-card strong,
      .review-card strong {
        display: block;
        letter-spacing: -0.035em;
      }

      .employee-card small,
      .review-card small {
        color: var(--muted);
        line-height: 1.45;
      }

      .score {
        text-align: right;
      }

      .score strong {
        font-size: 26px;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.055);
        color: var(--muted);
        padding: 7px 9px;
        font-size: 12px;
        font-weight: 800;
        white-space: nowrap;
      }

      .badge.green {
        color: var(--green);
        border-color: rgba(112, 214, 183, 0.28);
      }

      .badge.red {
        color: var(--red);
        border-color: rgba(255, 123, 123, 0.28);
      }

      .badge.gold {
        color: var(--gold);
        border-color: rgba(214, 180, 106, 0.32);
      }

      .divider {
        height: 1px;
        background: var(--line);
        margin: 18px 0;
      }

      .customer-shell {
        width: min(980px, calc(100% - 28px));
        margin: 0 auto;
        min-height: 100vh;
        display: grid;
        align-items: center;
        padding: 34px 0;
      }

      .customer-card {
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 34px;
        background:
          radial-gradient(circle at 16% 0%, rgba(214, 180, 106, 0.13), transparent 24rem),
          linear-gradient(180deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.025));
        box-shadow: var(--shadow);
      }

      .customer-top {
        padding: 18px;
        border-bottom: 1px solid var(--line);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
      }

      .verified-line {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--green);
        font-size: 13px;
        font-weight: 800;
      }

      .verified-dot {
        width: 8px;
        height: 8px;
        background: var(--green);
        border-radius: 50%;
        box-shadow: 0 0 0 7px rgba(112, 214, 183, 0.12);
      }

      .customer-main {
        display: grid;
        grid-template-columns: 0.8fr 1.2fr;
        gap: 0;
      }

      .receipt-panel {
        padding: 26px;
        border-right: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.035);
      }

      .receipt-box {
        border: 1px solid var(--line);
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.05);
        padding: 18px;
      }

      .receipt-row {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        border-bottom: 1px solid var(--line);
        padding: 12px 0;
        color: var(--soft);
      }

      .receipt-row:first-child {
        padding-top: 0;
      }

      .receipt-row:last-child {
        border-bottom: 0;
        padding-bottom: 0;
      }

      .receipt-row span {
        color: var(--muted);
      }

      .employee-block {
        margin-top: 18px;
        border: 1px solid var(--line);
        border-radius: 24px;
        padding: 18px;
        background: rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .review-panel {
        padding: clamp(24px, 5vw, 42px);
      }

      .step-line {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 22px;
      }

      .step-dot {
        width: 32px;
        height: 5px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.14);
      }

      .step-dot.active {
        background: var(--gold);
      }

      .customer-title {
        font-size: clamp(38px, 6vw, 66px);
        line-height: 0.92;
        letter-spacing: -0.07em;
        margin-bottom: 14px;
      }

      .stars {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 8px;
        margin: 20px 0;
      }

      .star {
        min-height: 62px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.055);
        color: rgba(255, 255, 255, 0.24);
        border-radius: 18px;
        font-size: 32px;
        transition: 140ms ease;
      }

      .star.active {
        background: rgba(214, 180, 106, 0.12);
        border-color: rgba(214, 180, 106, 0.44);
        color: var(--gold);
        transform: translateY(-2px);
      }

      .trait-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 12px 0 18px;
      }

      .trait {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.055);
        color: var(--soft);
        border-radius: 999px;
        padding: 10px 12px;
        font-weight: 800;
      }

      .trait.active {
        background: var(--gold);
        border-color: var(--gold);
        color: #14110a;
      }

      .support-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin: 16px 0;
      }

      .thanks {
        display: none;
        padding: 28px;
        border: 1px solid rgba(112, 214, 183, 0.24);
        background: rgba(112, 214, 183, 0.08);
        border-radius: 24px;
      }

      .thanks.show {
        display: block;
      }

      .review-form.hidden {
        display: none;
      }

      .toast {
        position: fixed;
        right: 18px;
        bottom: 18px;
        z-index: 60;
        max-width: 360px;
        background: #f5f2ea;
        color: #11151b;
        border-radius: 18px;
        padding: 14px 16px;
        box-shadow: var(--shadow);
        opacity: 0;
        transform: translateY(12px);
        pointer-events: none;
        transition: 160ms ease;
      }

      .toast.show {
        opacity: 1;
        transform: translateY(0);
      }

      @media (max-width: 980px) {
        .hero,
        .grid-2,
        .dashboard-grid,
        .customer-main {
          grid-template-columns: 1fr;
        }

        .receipt-panel {
          border-right: 0;
          border-bottom: 1px solid var(--line);
        }

        .grid-3,
        .metrics {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (max-width: 650px) {
        .nav-inner,
        .section-head,
        .customer-top {
          align-items: flex-start;
          flex-direction: column;
        }

        .nav-links {
          justify-content: flex-start;
        }

        .form-grid,
        .qr-box,
        .grid-3,
        .metrics {
          grid-template-columns: 1fr;
        }

        .employee-card {
          grid-template-columns: 46px 1fr;
        }

        .score {
          grid-column: 2;
          text-align: left;
        }

        .stars {
          gap: 6px;
        }

        .star {
          min-height: 54px;
          font-size: 26px;
        }
      }
    </style>
  </head>

  <body>
    <div class="platform-view">
      <nav class="nav">
        <div class="nav-inner">
          <a class="brand" href="/">
            <div class="brand-mark">SL</div>
            <div>
              <strong>ServiceLoop</strong>
              <span>Employee Feedback & Incentive System</span>
            </div>
          </a>

          <div class="nav-links">
            <a href="/">Portfolio</a>
            <a href="#demo">Generate Link</a>
            <a href="#dashboard">Dashboard</a>
            <a href="#deployment">Deployment</a>
          </div>
        </div>
      </nav>

      <main class="shell">
        <section class="hero">
          <div>
            <p class="eyebrow">Transaction-linked employee reviews</p>
            <h1>Turn customer service into incentive-ready performance data.</h1>
            <p class="lead">
              ServiceLoop links every review to a verified transaction, the employee who handled it,
              and the store where it happened. Customers get a simple review experience. Managers get
              clear service records, incentive scores, and low-rating visibility.
            </p>

            <div class="actions">
              <a class="btn" href="#demo">Generate Review Link →</a>
              <button class="btn secondary" id="openSampleCustomer" type="button">Open Customer Experience</button>
              <a class="btn ghost" href="#dashboard">View Dashboard</a>
            </div>
          </div>

          <div class="panel panel-pad">
            <div class="phone">
              <div class="phone-screen">
                <div class="phone-top">
                  <span>ServiceLoop</span>
                  <span>Verified purchase</span>
                </div>
                <div class="mini-logo">SL</div>
                <h3>How was your experience with Aarav?</h3>
                <p>
                  Your feedback is linked to the team member who assisted you and helps the store reward strong service.
                </p>
                <div class="phone-stars">★ ★ ★ ★ ★</div>
                <div class="phone-chip-row">
                  <span class="phone-chip">Helpful</span>
                  <span class="phone-chip">Fast service</span>
                  <span class="phone-chip">Product knowledge</span>
                  <span class="phone-chip">Clear communication</span>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="section">
          <div class="grid-3">
            <div class="mini-card">
              <span>01 / Link</span>
              <h3>Generated after purchase</h3>
              <p>The POS, receipt, WhatsApp message, SMS, or kiosk creates a unique review link for the transaction.</p>
            </div>
            <div class="mini-card">
              <span>02 / Review</span>
              <h3>Customer-facing experience</h3>
              <p>The customer sees the employee, transaction context, rating controls, quick tags, and optional comment box.</p>
            </div>
            <div class="mini-card">
              <span>03 / Incentive</span>
              <h3>Manager-ready score</h3>
              <p>Reviews update employee records with rating quality, volume, low-score flags, and incentive points.</p>
            </div>
          </div>
        </section>

        <section class="section" id="demo">
          <div class="section-head">
            <div>
              <p class="eyebrow">Live proof of concept</p>
              <h2>POS Review Link Generator</h2>
            </div>
            <p>
              Simulate a checkout. Select the employee, store, transaction amount, and delivery channel.
              The system generates the customer-facing review page.
            </p>
          </div>

          <div class="grid-2">
            <div class="panel panel-pad">
              <div class="form-grid">
                <div>
                  <label for="employeeSelect">Employee</label>
                  <select id="employeeSelect"></select>
                </div>

                <div>
                  <label for="storeSelect">Store / Zone</label>
                  <select id="storeSelect">
                    <option value="North Wing - Electronics">North Wing - Electronics</option>
                    <option value="Central Atrium - Fashion">Central Atrium - Fashion</option>
                    <option value="Food Court - Counter 4">Food Court - Counter 4</option>
                    <option value="Luxury Arcade - Watches">Luxury Arcade - Watches</option>
                  </select>
                </div>

                <div>
                  <label for="amountInput">Transaction amount</label>
                  <input id="amountInput" type="number" min="1" value="2450" />
                </div>

                <div>
                  <label for="channelSelect">Delivery channel</label>
                  <select id="channelSelect">
                    <option value="Receipt QR">Receipt QR</option>
                    <option value="WhatsApp Link">WhatsApp Link</option>
                    <option value="SMS Link">SMS Link</option>
                    <option value="Email Receipt">Email Receipt</option>
                    <option value="Exit Kiosk">Exit Kiosk</option>
                  </select>
                </div>
              </div>

              <div class="actions">
                <button class="btn" id="generateButton" type="button">Generate customer review link</button>
                <button class="btn secondary" id="seedButton" type="button">Load sample data</button>
                <button class="btn ghost" id="resetButton" type="button">Reset demo data</button>
              </div>

              <div class="qr-box" id="qrBox">
                <img id="qrImage" alt="Generated review QR code" />
                <div>
                  <span class="badge gold" id="generatedChannel">Receipt QR</span>
                  <h3 style="margin-top: 12px;">Customer page ready</h3>
                  <div class="link-output" id="generatedLink"></div>
                  <div class="actions">
                    <button class="btn secondary" id="copyButton" type="button">Copy link</button>
                    <a class="btn" id="openReviewLink" href="#" target="_blank" rel="noreferrer">Open customer page</a>
                  </div>
                </div>
              </div>
            </div>

            <div class="panel panel-pad">
              <h3>How this reaches the customer</h3>
              <p>
                The safest first deployment is a receipt QR code with a WhatsApp/SMS fallback when the customer number is available.
                The QR should never be generic. It should carry a one-time transaction token.
              </p>

              <div class="divider"></div>

              <div class="review-list">
                <div class="review-card">
                  <strong>Receipt QR</strong>
                  <small>Printed directly on the bill. The customer scans before leaving the store or mall.</small>
                </div>
                <div class="review-card">
                  <strong>WhatsApp / SMS link</strong>
                  <small>Sent automatically after checkout when contact details are available.</small>
                </div>
                <div class="review-card">
                  <strong>Exit kiosk</strong>
                  <small>Useful near mall exits or service desks for customers who miss the receipt QR.</small>
                </div>
                <div class="review-card">
                  <strong>Duplicate protection</strong>
                  <small>Each transaction token can submit one review. Repeated attempts are blocked or flagged.</small>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="section" id="dashboard">
          <div class="section-head">
            <div>
              <p class="eyebrow">Management view</p>
              <h2>Employee Incentive Dashboard</h2>
            </div>
            <p>
              The dashboard converts customer feedback into service visibility: review count,
              average rating, positive reviews, low-rating flags, and incentive-ready scoring.
            </p>
          </div>

          <div class="panel panel-pad">
            <div class="metrics">
              <div class="metric">
                <span>Total reviews</span>
                <strong id="totalReviews">0</strong>
              </div>
              <div class="metric">
                <span>Average rating</span>
                <strong id="averageRating">0.0</strong>
              </div>
              <div class="metric">
                <span>Positive reviews</span>
                <strong id="positiveReviews">0</strong>
              </div>
              <div class="metric">
                <span>Flags</span>
                <strong id="flaggedReviews">0</strong>
              </div>
            </div>

            <div class="dashboard-grid">
              <div>
                <h3>Employee records</h3>
                <p>Demo formula: rating quality + review volume - low-score penalty.</p>
                <div class="employee-list" id="employeeList"></div>
              </div>

              <div>
                <h3>Recent feedback</h3>
                <p>Each review is tied to transaction, store, employee, rating, and timestamp.</p>
                <div class="review-list" id="reviewList"></div>
              </div>
            </div>
          </div>
        </section>

        <section class="section" id="deployment">
          <div class="section-head">
            <div>
              <p class="eyebrow">Production requirements</p>
              <h2>What companies will need</h2>
            </div>
            <p>
              This page is a proof of concept. For production, the system needs secure transaction tokens,
              database storage, admin login, POS integration, and exportable reports.
            </p>
          </div>

          <div class="grid-3">
            <div class="mini-card">
              <span>POS</span>
              <h3>Transaction source</h3>
              <p>Transaction ID, employee ID, store ID, time, amount, and optional customer contact.</p>
            </div>
            <div class="mini-card">
              <span>Review</span>
              <h3>One-time token</h3>
              <p>A secure review link with expiry, duplicate protection, and employee mapping.</p>
            </div>
            <div class="mini-card">
              <span>Admin</span>
              <h3>Incentive logic</h3>
              <p>Transparent scoring rules for review quality, volume, complaint flags, and manager approval.</p>
            </div>
          </div>
        </section>
      </main>
    </div>

    <div class="customer-view">
      <main class="customer-shell">
        <section class="customer-card">
          <div class="customer-top">
            <a class="brand" href="/serviceloop/">
              <div class="brand-mark">SL</div>
              <div>
                <strong>ServiceLoop</strong>
                <span>Customer feedback</span>
              </div>
            </a>

            <div class="verified-line">
              <span class="verified-dot"></span>
              <span>Verified transaction</span>
            </div>
          </div>

          <div class="customer-main">
            <aside class="receipt-panel">
              <p class="eyebrow">Purchase review</p>
              <h2 style="margin-bottom: 18px;">Your feedback goes to the right person.</h2>
              <p>
                This review is linked to your transaction and the team member who assisted you.
                It helps the store improve service and reward strong performance.
              </p>

              <div class="receipt-box">
                <div class="receipt-row">
                  <span>Transaction</span>
                  <strong id="cTx">—</strong>
                </div>
                <div class="receipt-row">
                  <span>Store</span>
                  <strong id="cStore">—</strong>
                </div>
                <div class="receipt-row">
                  <span>Amount</span>
                  <strong id="cAmount">—</strong>
                </div>
                <div class="receipt-row">
                  <span>Channel</span>
                  <strong id="cChannel">—</strong>
                </div>
              </div>

              <div class="employee-block">
                <div class="avatar" id="cAvatar">—</div>
                <div>
                  <strong id="cEmployee">Employee</strong>
                  <small id="cRole">Transaction-linked review</small>
                </div>
              </div>
            </aside>

            <section class="review-panel">
              <div class="step-line">
                <span class="step-dot active"></span>
                <span class="step-dot active"></span>
                <span class="step-dot"></span>
              </div>

              <form class="review-form" id="customerReviewForm">
                <h1 class="customer-title" id="customerTitle">How was your experience?</h1>
                <p>
                  Rate the service you received. Your written comment is optional,
                  but it helps the store understand what went well or what needs attention.
                </p>

                <label>Rating</label>
                <div class="stars" id="stars">
                  <button class="star" type="button" data-rating="1">★</button>
                  <button class="star" type="button" data-rating="2">★</button>
                  <button class="star" type="button" data-rating="3">★</button>
                  <button class="star" type="button" data-rating="4">★</button>
                  <button class="star" type="button" data-rating="5">★</button>
                </div>

                <label>What stood out?</label>
                <div class="trait-grid" id="traits">
                  <button class="trait" type="button" data-trait="Helpful">Helpful</button>
                  <button class="trait" type="button" data-trait="Fast service">Fast service</button>
                  <button class="trait" type="button" data-trait="Product knowledge">Product knowledge</button>
                  <button class="trait" type="button" data-trait="Clear communication">Clear communication</button>
                  <button class="trait" type="button" data-trait="Billing support">Billing support</button>
                  <button class="trait" type="button" data-trait="Needs improvement">Needs improvement</button>
                </div>

                <label for="comment">Comment optional</label>
                <textarea id="comment" placeholder="Add a short note for the store team."></textarea>

                <div class="support-row">
                  <button class="btn" type="submit">Submit feedback</button>
                  <button class="btn secondary" id="needHelpButton" type="button">I need help</button>
                </div>

                <p style="font-size: 13px; color: var(--muted); margin-bottom: 0;">
                  Demo note: this proof of concept stores reviews in this browser only.
                  A production version would use secure server storage and admin access.
                </p>
              </form>

              <div class="thanks" id="thanksPanel">
                <p class="eyebrow">Feedback submitted</p>
                <h2>Thank you. Your review has been recorded.</h2>
                <p>
                  This feedback has been added to the employee performance record for this transaction.
                  In a real deployment, management would see it in the incentive dashboard.
                </p>

                <div class="receipt-box">
                  <div class="receipt-row">
                    <span>Reference</span>
                    <strong id="thanksRef">—</strong>
                  </div>
                  <div class="receipt-row">
                    <span>Status</span>
                    <strong>Submitted</strong>
                  </div>
                </div>

                <div class="actions">
                  <a class="btn" href="/serviceloop/">Back to ServiceLoop</a>
                </div>
              </div>
            </section>
          </div>
        </section>
      </main>
    </div>

    <div class="toast" id="toast"></div>

    <script is:inline>
      const employees = [
        { id: "EMP-014", name: "Aarav Malhotra", role: "Sales Associate", zone: "Electronics", initials: "AM" },
        { id: "EMP-021", name: "Meera Kapoor", role: "Senior Associate", zone: "Fashion", initials: "MK" },
        { id: "EMP-033", name: "Rohan Sen", role: "Floor Executive", zone: "Food Court", initials: "RS" },
        { id: "EMP-047", name: "Kabir Anand", role: "Client Advisor", zone: "Luxury Arcade", initials: "KA" },
      ];

      const STORAGE_KEY = "serviceloop_reviews_v2";

      const $ = (id) => document.getElementById(id);
      const $$ = (selector, root = document) => Array.from(root.querySelectorAll(selector));

      const el = {
        employeeSelect: $("employeeSelect"),
        storeSelect: $("storeSelect"),
        amountInput: $("amountInput"),
        channelSelect: $("channelSelect"),
        generateButton: $("generateButton"),
        qrBox: $("qrBox"),
        qrImage: $("qrImage"),
        generatedLink: $("generatedLink"),
        generatedChannel: $("generatedChannel"),
        openReviewLink: $("openReviewLink"),
        copyButton: $("copyButton"),
        openSampleCustomer: $("openSampleCustomer"),

        totalReviews: $("totalReviews"),
        averageRating: $("averageRating"),
        positiveReviews: $("positiveReviews"),
        flaggedReviews: $("flaggedReviews"),
        employeeList: $("employeeList"),
        reviewList: $("reviewList"),
        seedButton: $("seedButton"),
        resetButton: $("resetButton"),

        cTx: $("cTx"),
        cStore: $("cStore"),
        cAmount: $("cAmount"),
        cChannel: $("cChannel"),
        cAvatar: $("cAvatar"),
        cEmployee: $("cEmployee"),
        cRole: $("cRole"),
        customerTitle: $("customerTitle"),
        customerReviewForm: $("customerReviewForm"),
        comment: $("comment"),
        thanksPanel: $("thanksPanel"),
        thanksRef: $("thanksRef"),
        needHelpButton: $("needHelpButton"),

        toast: $("toast"),
      };

      let generatedUrl = "";
      let currentRating = 0;
      let currentContext = null;

      function uid() {
        if (crypto?.randomUUID) return crypto.randomUUID();
        return `id-${Date.now()}-${Math.random().toString(36).slice(2)}`;
      }

      function toast(message) {
        if (!el.toast) return;
        el.toast.textContent = message;
        el.toast.classList.add("show");
        clearTimeout(el.toast._timer);
        el.toast._timer = setTimeout(() => el.toast.classList.remove("show"), 2200);
      }

      function getEmployee(id) {
        return employees.find((employee) => employee.id === id) || employees[0];
      }

      function money(value) {
        return new Intl.NumberFormat("en-IN", {
          style: "currency",
          currency: "INR",
          maximumFractionDigits: 0,
        }).format(Number(value || 0));
      }

      function timeLabel(iso) {
        return new Date(iso).toLocaleString("en-IN", {
          day: "2-digit",
          month: "short",
          hour: "2-digit",
          minute: "2-digit",
        });
      }

      function txId() {
        const now = new Date();
        const d = String(now.getDate()).padStart(2, "0");
        const m = String(now.getMonth() + 1).padStart(2, "0");
        const r = Math.random().toString(36).slice(2, 8).toUpperCase();
        return `SL-${d}${m}-${r}`;
      }

      function getReviews() {
        try {
          return JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]");
        } catch {
          return [];
        }
      }

      function saveReviews(reviews) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(reviews));
      }

      function reviewExists(transactionId) {
        return getReviews().some((review) => review.transactionId === transactionId);
      }

      function buildReviewUrl({ employeeId, transactionId, store, amount, channel }) {
        const url = new URL(`${window.location.origin}/serviceloop/`);
        url.searchParams.set("review", "1");
        url.searchParams.set("employee", employeeId);
        url.searchParams.set("tx", transactionId);
        url.searchParams.set("store", store);
        url.searchParams.set("amount", amount);
        url.searchParams.set("channel", channel);
        return url.toString();
      }

      function populateEmployees() {
        if (!el.employeeSelect) return;
        el.employeeSelect.innerHTML = employees
          .map((employee) => `<option value="${employee.id}">${employee.name} — ${employee.zone}</option>`)
          .join("");
      }

      function generateReviewLink() {
        const transactionId = txId();
        const employeeId = el.employeeSelect.value;
        const store = el.storeSelect.value;
        const amount = Number(el.amountInput.value || 0);
        const channel = el.channelSelect.value;

        generatedUrl = buildReviewUrl({ employeeId, transactionId, store, amount, channel });

        el.generatedLink.textContent = generatedUrl;
        el.generatedChannel.textContent = channel;
        el.openReviewLink.href = generatedUrl;
        el.qrImage.src = `https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=${encodeURIComponent(generatedUrl)}`;
        el.qrBox.style.display = "grid";

        toast("Customer review page generated");
      }

      async function copyLink() {
        if (!generatedUrl) return;

        try {
          await navigator.clipboard.writeText(generatedUrl);
          toast("Review link copied");
        } catch {
          toast("Copy failed. Select the link manually.");
        }
      }

      function calculateEmployeeStats(employee, reviews) {
        const own = reviews.filter((review) => review.employeeId === employee.id);
        const count = own.length;
        const average = count ? own.reduce((sum, review) => sum + review.rating, 0) / count : 0;
        const positive = own.filter((review) => review.rating >= 4).length;
        const low = own.filter((review) => review.rating <= 2).length;
        const score = Math.max(0, Math.round(average * 18 + positive * 7 - low * 10));
        const incentive = score * 25;

        return { count, average, positive, low, score, incentive };
      }

      function renderDashboard() {
        if (!el.totalReviews) return;

        const reviews = getReviews();
        const total = reviews.length;
        const average = total ? reviews.reduce((sum, review) => sum + review.rating, 0) / total : 0;
        const positive = reviews.filter((review) => review.rating >= 4).length;
        const flagged = reviews.filter((review) => review.rating <= 2).length;

        el.totalReviews.textContent = total;
        el.averageRating.textContent = average.toFixed(1);
        el.positiveReviews.textContent = positive;
        el.flaggedReviews.textContent = flagged;

        el.employeeList.innerHTML = employees
          .map((employee) => ({ ...employee, stats: calculateEmployeeStats(employee, reviews) }))
          .sort((a, b) => b.stats.score - a.stats.score)
          .map((employee) => {
            const avg = employee.stats.count ? employee.stats.average.toFixed(1) : "—";
            return `
              <div class="employee-card">
                <div class="avatar">${employee.initials}</div>
                <div>
                  <strong>${employee.name}</strong>
                  <small>${employee.role} · ${employee.zone}<br />${employee.stats.count} reviews · ${avg} average · ${money(employee.stats.incentive)} demo incentive</small>
                </div>
                <div class="score">
                  <span class="badge ${employee.stats.low ? "red" : "green"}">${employee.stats.low ? `${employee.stats.low} flag` : "clean"}</span>
                  <strong>${employee.stats.score}</strong>
                  <small>score</small>
                </div>
              </div>
            `;
          })
          .join("");

        const sorted = [...reviews].sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));

        el.reviewList.innerHTML =
          sorted.slice(0, 8).map((review) => {
            const traits = review.traits?.length ? review.traits.join(", ") : "No tags";
            const comment = review.comment ? `“${review.comment}”` : "No written comment.";
            const badge = review.rating <= 2 ? "red" : "green";

            return `
              <div class="review-card">
                <div style="display:flex; justify-content:space-between; gap:12px; align-items:center;">
                  <strong>${review.employeeName}</strong>
                  <span class="badge ${badge}">${review.rating}/5</span>
                </div>
                <small>
                  ${review.store} · ${review.transactionId} · ${timeLabel(review.createdAt)}<br />
                  ${traits}<br />
                  ${comment}
                </small>
              </div>
            `;
          }).join("") || `
            <div class="review-card">
              <strong>No reviews yet</strong>
              <small>Generate a customer review link and submit a review to populate this dashboard.</small>
            </div>
          `;
      }

      function seedReviews() {
        const sample = [
          {
            id: uid(),
            employeeId: "EMP-014",
            employeeName: "Aarav Malhotra",
            transactionId: "SL-0107-A82KLF",
            store: "North Wing - Electronics",
            amount: 5490,
            channel: "Receipt QR",
            rating: 5,
            traits: ["Helpful", "Product knowledge", "Clear communication"],
            comment: "Explained the options clearly and helped compare two products.",
            createdAt: new Date(Date.now() - 1000 * 60 * 18).toISOString(),
          },
          {
            id: uid(),
            employeeId: "EMP-021",
            employeeName: "Meera Kapoor",
            transactionId: "SL-0107-F92LQP",
            store: "Central Atrium - Fashion",
            amount: 3200,
            channel: "WhatsApp Link",
            rating: 5,
            traits: ["Fast service", "Helpful"],
            comment: "Very quick billing and polite service.",
            createdAt: new Date(Date.now() - 1000 * 60 * 46).toISOString(),
          },
          {
            id: uid(),
            employeeId: "EMP-033",
            employeeName: "Rohan Sen",
            transactionId: "SL-0107-Z18RMQ",
            store: "Food Court - Counter 4",
            amount: 780,
            channel: "SMS Link",
            rating: 2,
            traits: ["Needs improvement"],
            comment: "Order took longer than expected.",
            createdAt: new Date(Date.now() - 1000 * 60 * 120).toISOString(),
          },
        ];

        saveReviews(sample);
        renderDashboard();
        toast("Sample data loaded");
      }

      function setRating(value) {
        currentRating = value;
        $$(".star").forEach((button) => {
          button.classList.toggle("active", Number(button.dataset.rating) <= value);
        });
      }

      function setupCustomerMode() {
        const params = new URLSearchParams(window.location.search);
        if (params.get("review") !== "1") return;

        document.body.classList.add("customer-mode");

        const employee = getEmployee(params.get("employee"));
        const transactionId = params.get("tx") || txId();
        const store = params.get("store") || "Demo Store";
        const amount = Number(params.get("amount") || 0);
        const channel = params.get("channel") || "Review Link";

        currentContext = { employee, transactionId, store, amount, channel };

        el.cTx.textContent = transactionId;
        el.cStore.textContent = store;
        el.cAmount.textContent = money(amount);
        el.cChannel.textContent = channel;
        el.cAvatar.textContent = employee.initials;
        el.cEmployee.textContent = employee.name;
        el.cRole.textContent = `${employee.role} · ${employee.zone}`;
        el.customerTitle.textContent = `How was your experience with ${employee.name.split(" ")[0]}?`;

        if (reviewExists(transactionId)) {
          el.customerReviewForm.classList.add("hidden");
          el.thanksRef.textContent = transactionId;
          el.thanksPanel.classList.add("show");
        }
      }

      function submitCustomerReview(event) {
        event.preventDefault();

        if (!currentContext) return;

        if (!currentRating) {
          toast("Please select a rating first");
          return;
        }

        if (reviewExists(currentContext.transactionId)) {
          el.customerReviewForm.classList.add("hidden");
          el.thanksRef.textContent = currentContext.transactionId;
          el.thanksPanel.classList.add("show");
          return;
        }

        const traits = $$(".trait.active").map((item) => item.dataset.trait);

        const review = {
          id: uid(),
          employeeId: currentContext.employee.id,
          employeeName: currentContext.employee.name,
          transactionId: currentContext.transactionId,
          store: currentContext.store,
          amount: currentContext.amount,
          channel: currentContext.channel,
          rating: currentRating,
          traits,
          comment: el.comment.value.trim(),
          createdAt: new Date().toISOString(),
        };

        saveReviews([review, ...getReviews()]);
        el.customerReviewForm.classList.add("hidden");
        el.thanksRef.textContent = currentContext.transactionId;
        el.thanksPanel.classList.add("show");
        toast("Feedback submitted");
      }

      function bind() {
        el.generateButton?.addEventListener("click", generateReviewLink);
        el.copyButton?.addEventListener("click", copyLink);

        el.openSampleCustomer?.addEventListener("click", () => {
          const url = buildReviewUrl({
            employeeId: "EMP-014",
            transactionId: txId(),
            store: "North Wing - Electronics",
            amount: 2450,
            channel: "Demo Link",
          });
          window.open(url, "_blank");
        });

        el.seedButton?.addEventListener("click", seedReviews);

        el.resetButton?.addEventListener("click", () => {
          localStorage.removeItem(STORAGE_KEY);
          renderDashboard();
          toast("Demo data reset");
        });

        $$(".star").forEach((button) => {
          button.addEventListener("click", () => setRating(Number(button.dataset.rating)));
        });

        $$(".trait").forEach((button) => {
          button.addEventListener("click", () => button.classList.toggle("active"));
        });

        el.needHelpButton?.addEventListener("click", () => {
          setRating(2);
          const issueButton = document.querySelector('[data-trait="Needs improvement"]');
          issueButton?.classList.add("active");
          el.comment.focus();
          toast("Add a short note so the store can follow up");
        });

        el.customerReviewForm?.addEventListener("submit", submitCustomerReview);
      }

      function init() {
        populateEmployees();
        bind();
        setupCustomerMode();

        if (!document.body.classList.contains("customer-mode")) {
          renderDashboard();

          if (!getReviews().length) {
            seedReviews();
          }
        }
      }

      init();
    </script>
  </body>
</html>
