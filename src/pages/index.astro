---
const pageTitle = "AG Systems | Custom Technology Systems for Physical Operations";
const pageDescription =
  "AG Systems designs and builds practical technology systems for businesses that need software, dashboards, automation, connected hardware, and data workflows around real-world operations.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={pageDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>

    <style>
      :root {
        --bg: #f6f3ed;
        --bg-soft: #ebe6dc;
        --paper: #fffdf8;
        --ink: #111111;
        --muted: #5f5a52;
        --muted-2: #888176;
        --line: rgba(17, 17, 17, 0.12);
        --line-dark: rgba(17, 17, 17, 0.22);
        --black: #111111;
        --radius: 28px;
        --radius-small: 18px;
        --max: 1180px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        line-height: 1.5;
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .site {
        min-height: 100vh;
        overflow-x: hidden;
      }

      .wrap {
        width: min(var(--max), calc(100% - 40px));
        margin: 0 auto;
      }

      .header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(246, 243, 237, 0.88);
        backdrop-filter: blur(18px);
        border-bottom: 1px solid var(--line);
      }

      .nav {
        height: 78px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 28px;
      }

      .brand {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }

      .brand-name {
        font-size: 18px;
        font-weight: 760;
        letter-spacing: -0.04em;
      }

      .brand-line {
        font-size: 12px;
        color: var(--muted);
        letter-spacing: -0.01em;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 28px;
        font-size: 13px;
        color: var(--muted);
      }

      .nav-links a {
        transition:
          color 180ms ease,
          opacity 180ms ease;
      }

      .nav-links a:hover {
        color: var(--ink);
      }

      .nav-cta {
        color: var(--paper) !important;
        background: var(--black);
        padding: 11px 16px;
        border-radius: 999px;
        font-weight: 650;
      }

      .nav-cta:hover {
        opacity: 0.88;
      }

      .hero {
        padding: 104px 0 78px;
      }

      .hero-grid {
        display: grid;
        grid-template-columns: 1.3fr 0.7fr;
        gap: 64px;
        align-items: end;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: var(--muted);
        font-size: 13px;
        letter-spacing: 0.02em;
        margin-bottom: 26px;
      }

      .eyebrow::before {
        content: "";
        width: 34px;
        height: 1px;
        background: var(--ink);
        opacity: 0.45;
      }

      h1 {
        max-width: 900px;
        margin: 0;
        font-size: clamp(52px, 7vw, 104px);
        line-height: 0.94;
        letter-spacing: -0.075em;
        font-weight: 780;
      }

      .hero-copy {
        max-width: 620px;
        margin: 32px 0 0;
        color: var(--muted);
        font-size: clamp(18px, 2vw, 22px);
        line-height: 1.48;
        letter-spacing: -0.025em;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 38px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 20px;
        border-radius: 999px;
        border: 1px solid var(--line-dark);
        font-size: 14px;
        font-weight: 650;
        letter-spacing: -0.01em;
        transition:
          transform 180ms ease,
          opacity 180ms ease,
          background 180ms ease,
          border-color 180ms ease;
      }

      .button:hover {
        transform: translateY(-1px);
      }

      .button-primary {
        background: var(--black);
        color: var(--paper);
        border-color: var(--black);
      }

      .button-secondary {
        background: transparent;
        color: var(--ink);
      }

      .button-secondary:hover {
        border-color: var(--ink);
      }

      .hero-panel {
        border-top: 1px solid var(--line-dark);
        padding-top: 22px;
      }

      .hero-panel p {
        margin: 0;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.65;
      }

      .hero-panel strong {
        display: block;
        color: var(--ink);
        font-size: 15px;
        margin-bottom: 7px;
      }

      .section {
        padding: 84px 0;
        border-top: 1px solid var(--line);
      }

      .section-head {
        display: grid;
        grid-template-columns: 0.72fr 1.28fr;
        gap: 56px;
        align-items: start;
        margin-bottom: 42px;
      }

      .section-kicker {
        margin: 0;
        color: var(--muted-2);
        font-size: 13px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      h2 {
        margin: 0;
        font-size: clamp(34px, 4vw, 58px);
        line-height: 1;
        letter-spacing: -0.055em;
        font-weight: 760;
      }

      .section-copy {
        max-width: 680px;
        margin: 18px 0 0;
        color: var(--muted);
        font-size: 17px;
        line-height: 1.65;
        letter-spacing: -0.015em;
      }

      .build-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        border: 1px solid var(--line);
        background: var(--paper);
      }

      .build-card {
        min-height: 250px;
        padding: 30px;
        border-right: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      .build-card:nth-child(3n) {
        border-right: 0;
      }

      .build-card:nth-last-child(-n + 3) {
        border-bottom: 0;
      }

      .card-number {
        color: var(--muted-2);
        font-size: 13px;
      }

      .build-card h3,
      .system-card h3,
      .use-case h3 {
        margin: 0;
        font-size: 23px;
        line-height: 1.1;
        letter-spacing: -0.04em;
        font-weight: 720;
      }

      .build-card p,
      .system-card p,
      .use-case p {
        margin: 16px 0 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.65;
      }

      .systems-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
      }

      .system-card {
        min-height: 360px;
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 30px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition:
          transform 180ms ease,
          border-color 180ms ease;
      }

      .system-card:hover {
        transform: translateY(-3px);
        border-color: var(--line-dark);
      }

      .system-meta {
        display: flex;
        justify-content: space-between;
        gap: 18px;
        align-items: center;
        margin-bottom: 26px;
        color: var(--muted-2);
        font-size: 13px;
      }

      .system-status {
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 6px 10px;
        color: var(--muted);
      }

      .system-link {
        display: inline-flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-top: 26px;
        padding-top: 22px;
        border-top: 1px solid var(--line);
        color: var(--ink);
        font-size: 14px;
        font-weight: 700;
      }

      .system-link span {
        font-size: 18px;
        line-height: 1;
      }

      .use-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 12px;
      }

      .use-case {
        min-height: 210px;
        padding: 24px;
        border: 1px solid var(--line);
        border-radius: var(--radius-small);
        background: rgba(255, 253, 248, 0.56);
      }

      .process {
        background: var(--black);
        color: var(--paper);
      }

      .process .section {
        border-top: 0;
      }

      .process .section-kicker,
      .process .section-copy {
        color: rgba(255, 253, 248, 0.62);
      }

      .process-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        border: 1px solid rgba(255, 255, 255, 0.18);
      }

      .process-step {
        min-height: 230px;
        padding: 26px;
        border-right: 1px solid rgba(255, 255, 255, 0.18);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      .process-step:last-child {
        border-right: 0;
      }

      .process-step span {
        color: rgba(255, 253, 248, 0.42);
        font-size: 13px;
      }

      .process-step h3 {
        margin: 0;
        font-size: 24px;
        letter-spacing: -0.04em;
      }

      .process-step p {
        margin: 16px 0 0;
        color: rgba(255, 253, 248, 0.66);
        font-size: 14px;
        line-height: 1.6;
      }

      .contact {
        padding: 96px 0;
      }

      .contact-card {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 34px;
        padding: clamp(32px, 6vw, 70px);
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 60px;
        align-items: end;
      }

      .contact-card h2 {
        max-width: 720px;
      }

      .contact-card p {
        max-width: 620px;
        margin: 22px 0 0;
        color: var(--muted);
        font-size: 18px;
        line-height: 1.65;
      }

      .contact-list {
        display: grid;
        gap: 12px;
      }

      .contact-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        border-bottom: 1px solid var(--line);
        padding: 14px 0;
        font-size: 14px;
      }

      .contact-row span {
        color: var(--muted-2);
      }

      .contact-row a {
        font-weight: 650;
      }

      .footer {
        border-top: 1px solid var(--line);
        padding: 28px 0;
        color: var(--muted);
        font-size: 13px;
      }

      .footer-inner {
        display: flex;
        justify-content: space-between;
        gap: 24px;
        flex-wrap: wrap;
      }

      @media (max-width: 980px) {
        .hero-grid,
        .section-head,
        .contact-card {
          grid-template-columns: 1fr;
        }

        .hero {
          padding-top: 74px;
        }

        .build-grid,
        .systems-grid {
          grid-template-columns: 1fr;
        }

        .build-card,
        .build-card:nth-child(3n),
        .build-card:nth-last-child(-n + 3) {
          border-right: 0;
          border-bottom: 1px solid var(--line);
        }

        .build-card:last-child {
          border-bottom: 0;
        }

        .use-grid,
        .process-grid {
          grid-template-columns: 1fr;
        }

        .process-step {
          border-right: 0;
          border-bottom: 1px solid rgba(255, 255, 255, 0.18);
          min-height: 190px;
        }

        .process-step:last-child {
          border-bottom: 0;
        }
      }

      @media (max-width: 720px) {
        .wrap {
          width: min(100% - 28px, var(--max));
        }

        .nav {
          height: auto;
          padding: 18px 0;
          align-items: flex-start;
        }

        .brand-line {
          max-width: 220px;
        }

        .nav-links {
          display: none;
        }

        .hero {
          padding: 62px 0 56px;
        }

        h1 {
          font-size: clamp(46px, 14vw, 72px);
        }

        .hero-copy {
          font-size: 17px;
        }

        .section {
          padding: 62px 0;
        }

        .build-card,
        .system-card,
        .use-case {
          padding: 24px;
        }

        .contact {
          padding: 68px 0;
        }

        .contact-card {
          border-radius: 24px;
          padding: 28px;
        }

        .contact-row {
          align-items: flex-start;
          flex-direction: column;
          gap: 4px;
        }
      }
    </style>
  </head>

  <body>
    <div class="site">
      <header class="header">
        <div class="wrap nav">
          <a class="brand" href="/" aria-label="AG Systems home">
            <span class="brand-name">AG Systems</span>
            <span class="brand-line">A technology systems company by Aryadhar Gupta.</span>
          </a>

          <nav class="nav-links" aria-label="Primary navigation">
            <a href="#build">What We Build</a>
            <a href="#systems">Working Systems</a>
            <a href="#process">Process</a>
            <a class="nav-cta" href="#contact">Start a Project</a>
          </nav>
        </div>
      </header>

      <main>
        <section class="hero">
          <div class="wrap hero-grid">
            <div>
              <div class="eyebrow">Founder-led technology systems company</div>
              <h1>Custom technology systems for physical operations.</h1>
              <p class="hero-copy">
                AG Systems designs and builds practical technology systems for businesses that need software,
                dashboards, automation, connected hardware, and data workflows around real-world operations.
              </p>

              <div class="hero-actions">
                <a class="button button-primary" href="#systems">View Working Systems</a>
                <a class="button button-secondary" href="#contact">Start a Project</a>
              </div>
            </div>

            <aside class="hero-panel" aria-label="Company focus">
              <strong>Built around operations, not templates.</strong>
              <p>
                We work on systems where physical processes, business workflows, hardware, data, and decision-making
                need to connect into one reliable operating layer.
              </p>
            </aside>
          </div>
        </section>

        <section class="section" id="build">
          <div class="wrap">
            <div class="section-head">
              <p class="section-kicker">What We Build</p>
              <div>
                <h2>Technology infrastructure for businesses that operate in the real world.</h2>
                <p class="section-copy">
                  From connected devices to owner dashboards, AG Systems builds tools that sit close to the operation:
                  collecting data, controlling hardware, tracking activity, and making performance visible.
                </p>
              </div>
            </div>

            <div class="build-grid">
              <article class="build-card">
                <span class="card-number">01</span>
                <div>
                  <h3>IoT & Connected Hardware</h3>
                  <p>
                    Sensor-backed systems, device communication, remote control interfaces, and hardware-to-cloud
                    workflows.
                  </p>
                </div>
              </article>

              <article class="build-card">
                <span class="card-number">02</span>
                <div>
                  <h3>Owner Dashboards</h3>
                  <p>
                    Executive dashboards for live visibility across revenue, operations, devices, locations, and teams.
                  </p>
                </div>
              </article>

              <article class="build-card">
                <span class="card-number">03</span>
                <div>
                  <h3>Internal Tools</h3>
                  <p>
                    Custom web platforms for teams that need software designed around their actual operating process.
                  </p>
                </div>
              </article>

              <article class="build-card">
                <span class="card-number">04</span>
                <div>
                  <h3>Tracking & Workflow Systems</h3>
                  <p>
                    Systems for product movement, task status, transaction records, service flows, and operational logs.
                  </p>
                </div>
              </article>

              <article class="build-card">
                <span class="card-number">05</span>
                <div>
                  <h3>Monitoring Systems</h3>
                  <p>
                    Live monitoring interfaces for environmental data, facilities, machines, activity, and field
                    conditions.
                  </p>
                </div>
              </article>

              <article class="build-card">
                <span class="card-number">06</span>
                <div>
                  <h3>Automation & Data Pipelines</h3>
                  <p>
                    Data collection, API connections, automated reporting, alerts, and system-to-system workflows.
                  </p>
                </div>
              </article>
            </div>
          </div>
        </section>

        <section class="section" id="systems">
          <div class="wrap">
            <div class="section-head">
              <p class="section-kicker">Working Systems</p>
              <div>
                <h2>Proof through working builds.</h2>
                <p class="section-copy">
                  These systems are shown as proof-of-capability: live interfaces, connected workflows, and operational
                  concepts that can be adapted into commercial deployments.
                </p>
              </div>
            </div>

            <div class="systems-grid">
              <article class="system-card">
                <div>
                  <div class="system-meta">
                    <span>Revenue / Feedback / Incentives</span>
                    <span class="system-status">Working Demo</span>
                  </div>
                  <h3>ServiceLoop</h3>
                  <p>
                    A revenue, feedback, and incentive workflow system built for customer-facing businesses that need
                    employee-level service visibility.
                  </p>
                </div>
                <a class="system-link" href="/serviceloop/">
                  Open System
                  <span>→</span>
                </a>
              </article>

              <article class="system-card">
                <div>
                  <div class="system-meta">
                    <span>Connected Hardware</span>
                    <span class="system-status">Live Control</span>
                  </div>
                  <h3>Traffic Control</h3>
                  <p>
                    An internet-connected hardware control system proving remote control, device polling, live state,
                    and physical output through a web interface.
                  </p>
                </div>
                <a class="system-link" href="/traffic-control/">
                  Open System
                  <span>→</span>
                </a>
              </article>

              <article class="system-card">
                <div>
                  <div class="system-meta">
                    <span>Environmental Monitoring</span>
                    <span class="system-status">Live Dashboard</span>
                  </div>
                  <h3>Air Quality Monitoring</h3>
                  <p>
                    A live environmental monitoring dashboard showing how sensor readings can become a clean
                    owner-facing system for facilities and public spaces.
                  </p>
                </div>
                <a class="system-link" href="https://nirvanayours.com/" target="_blank" rel="noreferrer">
                  Open Live Dashboard
                  <span>→</span>
                </a>
              </article>
            </div>
          </div>
        </section>

        <section class="section" id="use-cases">
          <div class="wrap">
            <div class="section-head">
              <p class="section-kicker">Use Cases</p>
              <div>
                <h2>Built for operations where generic software does not fit.</h2>
                <p class="section-copy">
                  AG Systems is suited for businesses where the workflow is specific, the data is fragmented, or the
                  system needs to connect software with what is happening on the ground.
                </p>
              </div>
            </div>

            <div class="use-grid">
              <article class="use-case">
                <h3>Malls & Venues</h3>
                <p>Revenue visibility, feedback systems, footfall workflows, team performance, and owner dashboards.</p>
              </article>

              <article class="use-case">
                <h3>Facilities</h3>
                <p>Monitoring systems, maintenance workflows, sensor dashboards, and operational reporting.</p>
              </article>

              <article class="use-case">
                <h3>Environmental Projects</h3>
                <p>Air quality, field sensors, reporting interfaces, live dashboards, and data collection systems.</p>
              </article>

              <article class="use-case">
                <h3>Logistics</h3>
                <p>Tracking workflows, movement logs, dispatch visibility, and status dashboards.</p>
              </article>

              <article class="use-case">
                <h3>Custom Operations</h3>
                <p>Internal platforms for businesses whose processes cannot be solved cleanly by standard tools.</p>
              </article>
            </div>
          </div>
        </section>

        <div class="process" id="process">
          <section class="section">
            <div class="wrap">
              <div class="section-head">
                <p class="section-kicker">Process</p>
                <div>
                  <h2>From operational problem to deployed system.</h2>
                  <p class="section-copy">
                    The work starts by understanding the real process, then turning it into a system that can be used,
                    tested, improved, and scaled.
                  </p>
                </div>
              </div>

              <div class="process-grid">
                <article class="process-step">
                  <span>01</span>
                  <div>
                    <h3>Understand</h3>
                    <p>Map the workflow, users, data sources, devices, constraints, and commercial outcome.</p>
                  </div>
                </article>

                <article class="process-step">
                  <span>02</span>
                  <div>
                    <h3>Design</h3>
                    <p>Define the system architecture, dashboard structure, hardware flow, and user experience.</p>
                  </div>
                </article>

                <article class="process-step">
                  <span>03</span>
                  <div>
                    <h3>Build</h3>
                    <p>Develop the software, backend, interfaces, device communication, and required integrations.</p>
                  </div>
                </article>

                <article class="process-step">
                  <span>04</span>
                  <div>
                    <h3>Deploy</h3>
                    <p>Move the system into a real environment with testing, security, monitoring, and documentation.</p>
                  </div>
                </article>

                <article class="process-step">
                  <span>05</span>
                  <div>
                    <h3>Improve</h3>
                    <p>Use live feedback and operational data to refine the system into a stronger production tool.</p>
                  </div>
                </article>
              </div>
            </div>
          </section>
        </div>

        <section class="contact" id="contact">
          <div class="wrap">
            <div class="contact-card">
              <div>
                <p class="section-kicker">Start a Project</p>
                <h2>Build a custom system around your operation.</h2>
                <p>
                  For dashboards, connected hardware, monitoring systems, internal tools, automation, or operational
                  software, contact AG Systems with the process you want to improve.
                </p>

                <div class="hero-actions">
                  <a class="button button-primary" href="mailto:me@aryadhargupta.com">Start a Project</a>
                  <a class="button button-secondary" href="#systems">View Working Systems</a>
                </div>
              </div>

              <div class="contact-list">
                <div class="contact-row">
                  <span>Email</span>
                  <a href="mailto:me@aryadhargupta.com">me@aryadhargupta.com</a>
                </div>

                <div class="contact-row">
                  <span>Phone</span>
                  <a href="tel:+919560082697">+91 95600 82697</a>
                </div>

                <div class="contact-row">
                  <span>Location</span>
                  <a href="https://www.google.com/maps/search/Delhi,+India" target="_blank" rel="noreferrer">
                    Delhi, India
                  </a>
                </div>

                <div class="contact-row">
                  <span>GitHub</span>
                  <a href="https://github.com/aryadharg-max" target="_blank" rel="noreferrer">@aryadharg-max</a>
                </div>

                <div class="contact-row">
