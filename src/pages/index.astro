---
const pageTitle = "AG Systems | Custom Technology Systems for Physical Operations";
const pageDescription =
  "AG Systems builds custom operational technology systems, dashboards, connected hardware workflows, backend infrastructure, and ground-up technology solutions for physical businesses.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={pageDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>

    <style>
      :root {
        --paper: #f3eee5;
        --paper-2: #e9e1d3;
        --surface: #fffaf0;
        --ink: #15130f;
        --body: #3b372f;
        --muted: #70675b;
        --quiet: #9b9080;
        --rule: rgba(21, 19, 15, 0.15);
        --rule-strong: rgba(21, 19, 15, 0.34);
        --black: #15130f;
        --white: #fffaf0;
        --max: 1210px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background:
          radial-gradient(circle at top left, rgba(255, 250, 240, 0.72), transparent 34%),
          linear-gradient(180deg, var(--paper), #f6f1e8 46%, var(--paper));
        color: var(--ink);
        font-family:
          "Segoe UI", Inter, ui-sans-serif, system-ui, -apple-system,
          BlinkMacSystemFont, sans-serif;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        opacity: 0.16;
        background-image:
          linear-gradient(rgba(21, 19, 15, 0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(21, 19, 15, 0.025) 1px, transparent 1px);
        background-size: 34px 34px;
        mask-image: linear-gradient(to bottom, black, transparent 68%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .wrap {
        width: min(var(--max), calc(100% - 48px));
        margin: 0 auto;
      }

      .topbar {
        position: sticky;
        top: 0;
        z-index: 30;
        border-bottom: 1px solid var(--rule);
        background: rgba(243, 238, 229, 0.9);
        backdrop-filter: blur(16px);
      }

      .nav {
        min-height: 64px;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 28px;
        align-items: center;
      }

      .brand {
        display: flex;
        align-items: baseline;
        gap: 13px;
      }

      .brand-name {
        font-size: 18px;
        font-weight: 760;
        letter-spacing: -0.045em;
      }

      .brand-line {
        color: var(--muted);
        font-size: 13px;
        letter-spacing: -0.02em;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 22px;
        color: var(--muted);
        font-size: 13px;
      }

      .nav-links a {
        border-bottom: 1px solid transparent;
        padding-bottom: 2px;
      }

      .nav-links a:hover {
        color: var(--ink);
        border-color: var(--ink);
      }

      .nav-action {
        color: var(--white) !important;
        background: var(--black);
        padding: 9px 13px !important;
        border-bottom: 0 !important;
      }

      .hero {
        padding: 52px 0 36px;
        border-bottom: 1px solid var(--rule);
      }

      .hero-layout {
        display: grid;
        grid-template-columns: minmax(0, 1.52fr) minmax(315px, 0.72fr);
        gap: 54px;
        align-items: stretch;
      }

      .label {
        margin: 0 0 16px;
        color: var(--muted);
        font-size: 12px;
        letter-spacing: 0.07em;
        text-transform: uppercase;
      }

      .label::before {
        content: "";
        display: inline-block;
        width: 28px;
        height: 1px;
        margin-right: 10px;
        vertical-align: middle;
        background: var(--rule-strong);
      }

      h1,
      .section-title,
      .contact-panel h2,
      .hero-note h2,
      .principle h2 {
        font-family: Georgia, "Times New Roman", ui-serif, serif;
        font-weight: 520;
      }

      h1 {
        margin: 0;
        max-width: 900px;
        font-size: clamp(50px, 5.8vw, 84px);
        line-height: 0.94;
        letter-spacing: -0.068em;
      }

      .hero-copy {
        max-width: 765px;
        margin: 23px 0 0;
        color: var(--body);
        font-size: clamp(17px, 1.45vw, 20px);
        line-height: 1.52;
        letter-spacing: -0.022em;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 26px;
      }

      .button {
        min-height: 40px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 14px;
        border: 1px solid var(--rule-strong);
        color: var(--ink);
        background: transparent;
        font-size: 13px;
        font-weight: 650;
        letter-spacing: -0.01em;
      }

      .button:hover {
        background: var(--black);
        border-color: var(--black);
        color: var(--white);
      }

      .button-dark {
        background: var(--black);
        border-color: var(--black);
        color: var(--white);
      }

      .button-dark:hover {
        opacity: 0.86;
      }

      .hero-note {
        position: relative;
        border-top: 2px solid var(--ink);
        border-bottom: 1px solid var(--rule);
        padding: 20px 0 0;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      .hero-note h2 {
        margin: 0;
        max-width: 390px;
        font-size: 24px;
        line-height: 1.08;
        letter-spacing: -0.045em;
      }

      .note-text {
        max-width: 385px;
        margin: 14px 0 0;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.55;
      }

      .scope-list {
        margin: 30px 0 0;
        padding: 0;
        list-style: none;
        border-top: 1px solid var(--rule);
      }

      .scope-list li {
        display: grid;
        grid-template-columns: 92px 1fr;
        gap: 18px;
        padding: 10px 0;
        border-bottom: 1px solid var(--rule);
        font-size: 13px;
      }

      .scope-list span {
        color: var(--muted);
      }

      .scope-list strong {
        font-weight: 650;
      }

      .principle {
        border-bottom: 1px solid var(--rule);
        padding: 30px 0;
      }

      .principle-inner {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 48px;
        align-items: start;
      }

      .principle h2 {
        margin: 0;
        max-width: 560px;
        font-size: clamp(28px, 3vw, 44px);
        line-height: 1;
        letter-spacing: -0.055em;
      }

      .principle p {
        margin: 0;
        max-width: 610px;
        color: var(--body);
        font-size: 16px;
        line-height: 1.62;
        letter-spacing: -0.012em;
      }

      .section {
        padding: 52px 0;
        border-bottom: 1px solid var(--rule);
      }

      .section-grid {
        display: grid;
        grid-template-columns: 232px minmax(0, 1fr);
        gap: 48px;
      }

      .section-title {
        margin: 0;
        max-width: 850px;
        font-size: clamp(33px, 3.5vw, 54px);
        line-height: 0.98;
        letter-spacing: -0.055em;
      }

      .section-intro {
        margin: 13px 0 0;
        max-width: 765px;
        color: var(--muted);
        font-size: 16px;
        line-height: 1.58;
        letter-spacing: -0.012em;
      }

      .capabilities {
        margin-top: 28px;
        border-top: 1px solid var(--rule-strong);
      }

      .capability-row {
        display: grid;
        grid-template-columns: 0.46fr 1fr;
        gap: 38px;
        padding: 20px 0;
        border-bottom: 1px solid var(--rule);
      }

      .capability-row h3 {
        margin: 0;
        font-size: 20px;
        line-height: 1.16;
        letter-spacing: -0.04em;
        font-weight: 690;
      }

      .capability-row p {
        margin: 0;
        max-width: 725px;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.58;
      }

      .systems {
        display: grid;
        gap: 0;
        margin-top: 28px;
        border-top: 1px solid var(--rule-strong);
      }

      .system-row {
        display: grid;
        grid-template-columns: 158px minmax(0, 1fr) 170px;
        gap: 28px;
        align-items: center;
        padding: 23px 0;
        border-bottom: 1px solid var(--rule);
      }

      .system-type {
        color: var(--muted);
        font-size: 12px;
        letter-spacing: 0.075em;
        text-transform: uppercase;
        line-height: 1.42;
      }

      .system-row h3 {
        margin: 0;
        font-size: 23px;
        letter-spacing: -0.045em;
        line-height: 1.1;
        font-weight: 690;
      }

      .system-row p {
        max-width: 790px;
        margin: 8px 0 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.55;
      }

      .system-row a {
        justify-self: end;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 135px;
        min-height: 38px;
        border: 1px solid var(--rule-strong);
        font-size: 13px;
        font-weight: 650;
      }

      .system-row a:hover {
        background: var(--black);
        color: var(--white);
        border-color: var(--black);
      }

      .case-note {
        margin-top: 26px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        border-top: 1px solid var(--rule-strong);
        border-left: 1px solid var(--rule);
        background: rgba(255, 250, 240, 0.44);
      }

      .case-note > div {
        padding: 20px;
        border-right: 1px solid var(--rule);
        border-bottom: 1px solid var(--rule);
      }

      .case-note span {
        display: block;
        margin-bottom: 8px;
        color: var(--quiet);
        font-size: 12px;
        letter-spacing: 0.07em;
        text-transform: uppercase;
      }

      .case-note p {
        margin: 0;
        color: var(--body);
        font-size: 14px;
        line-height: 1.55;
      }

      .usecase-panel {
        display: grid;
        grid-template-columns: 1fr 1fr;
        margin-top: 28px;
        border-top: 1px solid var(--rule-strong);
        border-left: 1px solid var(--rule);
      }

      .usecase {
        min-height: 132px;
        padding: 20px;
        border-right: 1px solid var(--rule);
        border-bottom: 1px solid var(--rule);
        background: rgba(255, 250, 240, 0.42);
      }

      .usecase h3 {
        margin: 0;
        font-size: 18px;
        line-height: 1.2;
        letter-spacing: -0.035em;
        font-weight: 690;
      }

      .usecase p {
        margin: 9px 0 0;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.52;
      }

      .method {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        margin-top: 28px;
        border-top: 1px solid var(--rule-strong);
      }

      .method-step {
        min-height: 145px;
        padding: 18px 18px 0 0;
        border-right: 1px solid var(--rule);
      }

      .method-step:last-child {
        border-right: 0;
      }

      .method-step span {
        color: var(--quiet);
        font-size: 12px;
      }

      .method-step h3 {
        margin: 17px 0 8px;
        font-size: 18px;
        letter-spacing: -0.035em;
        font-weight: 690;
      }

      .method-step p {
        margin: 0;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.48;
      }

      .contact {
        padding: 50px 0 58px;
      }

      .contact-panel {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(330px, 0.7fr);
        gap: 48px;
        align-items: end;
        background: var(--black);
        color: var(--white);
        padding: 36px;
      }

      .contact-panel .label {
        color: rgba(255, 250, 240, 0.58);
      }

      .contact-panel .label::before {
        background: rgba(255, 250, 240, 0.34);
      }

      .contact-panel h2 {
        margin: 0;
        max-width: 720px;
        font-size: clamp(36px, 4.4vw, 62px);
        line-height: 0.95;
        letter-spacing: -0.06em;
      }

      .contact-panel p {
        max-width: 650px;
        margin: 18px 0 0;
        color: rgba(255, 250, 240, 0.72);
        font-size: 16px;
        line-height: 1.58;
      }

      .contact-panel .button {
        margin-top: 24px;
        color: var(--white);
        border-color: rgba(255, 250, 240, 0.38);
      }

      .contact-panel .button:hover {
        color: var(--black);
        background: var(--white);
        border-color: var(--white);
      }

      .contact-list {
        border-top: 1px solid rgba(255, 250, 240, 0.24);
      }

      .contact-item {
        display: grid;
        grid-template-columns: 88px 1fr;
        gap: 18px;
        padding: 12px 0;
        border-bottom: 1px solid rgba(255, 250, 240, 0.24);
        font-size: 13px;
      }

      .contact-item span {
        color: rgba(255, 250, 240, 0.48);
      }

      .contact-item a,
      .contact-item strong {
        color: var(--white);
        font-weight: 610;
      }

      .footer {
        padding: 22px 0;
        border-top: 1px solid var(--rule);
        color: var(--muted);
        font-size: 12px;
      }

      .footer-inner {
        display: flex;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
      }

      @media (max-width: 980px) {
        .hero-layout,
        .principle-inner,
        .section-grid,
        .contact-panel {
          grid-template-columns: 1fr;
        }

        .system-row {
          grid-template-columns: 1fr;
          gap: 14px;
        }

        .system-row a {
          justify-self: start;
        }

        .case-note {
          grid-template-columns: 1fr;
        }

        .method {
          grid-template-columns: 1fr;
        }

        .method-step {
          min-height: auto;
          padding: 17px 0;
          border-right: 0;
          border-bottom: 1px solid var(--rule);
        }

        .method-step:last-child {
          border-bottom: 0;
        }
      }

      @media (max-width: 720px) {
        .wrap {
          width: min(100% - 28px, var(--max));
        }

        .nav {
          min-height: auto;
          padding: 15px 0;
        }

        .brand {
          flex-direction: column;
          align-items: flex-start;
          gap: 3px;
        }

        .brand-line {
          max-width: 250px;
          font-size: 12px;
        }

        .nav-links {
          display: none;
        }

        .hero {
          padding: 40px 0 32px;
        }

        h1 {
          font-size: clamp(43px, 13vw, 64px);
        }

        .hero-copy {
          font-size: 16px;
        }

        .principle {
          padding: 28px 0;
        }

        .section {
          padding: 40px 0;
        }

        .section-grid {
          gap: 23px;
        }

        .capability-row {
          grid-template-columns: 1fr;
          gap: 9px;
          padding: 17px 0;
        }

        .usecase-panel {
          grid-template-columns: 1fr;
        }

        .contact {
          padding: 40px 0 48px;
        }

        .contact-panel {
          padding: 25px;
        }

        .contact-item {
          grid-template-columns: 1fr;
          gap: 3px;
        }
      }
    </style>
  </head>

  <body>
    <header class="topbar">
      <div class="wrap nav">
        <a class="brand" href="/" aria-label="AG Systems home">
          <span class="brand-name">AG Systems</span>
          <span class="brand-line">A technology systems company by Aryadhar Gupta.</span>
        </a>

        <nav class="nav-links" aria-label="Main navigation">
          <a href="#systems">Working Systems</a>
          <a href="#capabilities">Capabilities</a>
          <a href="#method">Method</a>
          <a class="nav-action" href="#contact">Start a Project</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="wrap hero-layout">
          <div>
            <p class="label">Operational technology / dashboards / connected systems</p>
            <h1>Custom technology systems for physical operations.</h1>
            <p class="hero-copy">
              AG Systems builds the software, dashboards, and connected hardware that give a physical operation
              visibility and control. Designed around how the business actually runs.
            </p>

            <div class="hero-actions">
              <a class="button button-dark" href="#systems">View Working Systems</a>
              <a class="button" href="#contact">Start a Project</a>
            </div>
          </div>

          <aside class="hero-note">
            <div>
              <h2>Founder-led systems work for businesses with specific operational problems.</h2>
              <p class="note-text">
                Built by Aryadhar Gupta for use cases where off-the-shelf software does not fit the process cleanly.
              </p>
            </div>

            <ul class="scope-list" aria-label="AG Systems focus areas">
              <li><span>Focus</span><strong>Physical operations</strong></li>
              <li><span>Output</span><strong>Working systems</strong></li>
              <li><span>Includes</span><strong>Software + hardware</strong></li>
              <li><span>Base</span><strong>Delhi, India</strong></li>
            </ul>
          </aside>
        </div>
      </section>

      <section class="principle">
        <div class="wrap principle-inner">
          <h2>When a business process needs its own system, AG Systems builds from the ground up.</h2>
          <p>
            The work can start at the hardware, the software, or the workflow itself. Instead of forcing a
            business into a generic tool, the tool is designed around the process.
          </p>
        </div>
      </section>

      <section class="section" id="systems">
        <div class="wrap section-grid">
          <div>
            <p class="label">Working Systems</p>
          </div>

          <div>
            <h2 class="section-title">Selected working systems and proof-of-capability builds.</h2>
            <p class="section-intro">
              Live systems, not mockups. Each one can be opened and used.
            </p>

            <div class="systems">
              <article class="system-row">
                <div class="system-type">Manufacturing / environment</div>
                <div>
                  <h3>Air Quality Monitoring for Nirvana Being</h3>
                  <p>
                    Client deployment: air-quality monitoring for Nirvana Being — device concept, backend,
                    and a live environmental dashboard.
                  </p>
                </div>
              <a href="/nirvana-being/">Read Case Study</a>
              </article>

              <article class="system-row">
                <div class="system-type">Connected hardware</div>
                <div>
                  <h3>Connected Hardware Control System</h3>
                  <p>
                    A live relay system controlled from this website. Secure command access, public state,
                    real physical output.
                  </p>
                </div>
                <a href="/traffic-control/">Open System</a>
              </article>

              <article class="system-row">
                <div class="system-type">Revenue / feedback</div>
                <div>
                  <h3>ServiceLoop</h3>
                  <p>
                    A feedback and staff-incentive workflow for customer-facing venues, linking transactions
                    to reviews and owner visibility.
                  </p>
                </div>
                <a href="/serviceloop/">Open System</a>
              </article>
            </div>

            <div class="case-note" aria-label="Nirvana Being AQM project scope">
              <div>
                <span>Project scope</span>
                <p>
                  The AQM build covers the full stack — physical device concept, backend, and
                  client-facing dashboard.
                </p>
              </div>

              <div>
                <span>Commercial fit</span>
                <p>
                  The same method applies to any business that needs a custom product or a live
                  operational dashboard.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="capabilities">
        <div class="wrap section-grid">
          <div>
            <p class="label">Capabilities</p>
          </div>

          <div>
            <h2 class="section-title">Systems that connect business workflows with live operational data.</h2>
            <p class="section-intro">
              The work sits between software, hardware, and the way the operation actually runs.
            </p>

            <div class="capabilities">
              <article class="capability-row">
                <h3>Ground-up system design</h3>
                <p>
                  When no existing tool fits, AG Systems designs the whole operating layer — workflow, interface,
                  and backend — as one system.
                </p>
              </article>

              <article class="capability-row">
                <h3>Owner dashboards</h3>
                <p>
                  Live views of revenue, devices, and operations, built for the person running the business.
                </p>
              </article>

              <article class="capability-row">
                <h3>IoT, monitoring, and connected hardware</h3>
                <p>
                  Sensors, remote control, and hardware-to-cloud communication, with reporting on what the
                  devices see.
                </p>
              </article>

              <article class="capability-row">
                <h3>Websites, portals, and backends</h3>
                <p>
                  Client-facing sites, internal tools, and the APIs and workflow tracking behind them.
                </p>
              </article>

              <article class="capability-row">
                <h3>Automation and integrations</h3>
                <p>
                  Alerts, automated reports, and connections between systems that currently need manual work.
                </p>
              </article>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="use-cases">
        <div class="wrap section-grid">
          <div>
            <p class="label">Use Cases</p>
          </div>

          <div>
            <h2 class="section-title">For operations where the software has to match the ground reality.</h2>
            <p class="section-intro">
              The strongest fit: a real process, manual tracking, and a workflow that needs to become measurable.
            </p>

            <div class="usecase-panel">
              <article class="usecase">
                <h3>Venues and retail</h3>
                <p>Customer feedback, staff incentives, and revenue visibility for owners.</p>
              </article>

              <article class="usecase">
                <h3>Facilities and environment</h3>
                <p>Sensor monitoring, equipment dashboards, and air-quality or field-data reporting.</p>
              </article>

              <article class="usecase">
                <h3>Custom products</h3>
                <p>Product ideas that need hardware logic, a backend, and a commercial web layer built together.</p>
              </article>

              <article class="usecase">
                <h3>Internal operations</h3>
                <p>Tracking, approvals, and management views for processes currently run on paper or spreadsheets.</p>
              </article>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="method">
        <div class="wrap section-grid">
          <div>
            <p class="label">Method</p>
          </div>

          <div>
            <h2 class="section-title">A practical build process from workflow to deployed system.</h2>
            <p class="section-intro">
              The goal is a clearer, more measurable operation — not software for its own sake.
            </p>

            <div class="method">
              <article class="method-step">
                <span>01</span>
                <h3>Map</h3>
