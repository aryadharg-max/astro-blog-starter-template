    <div class="command-palette" id="commandPalette" aria-hidden="true">
      <div class="command-card">
        <div class="command-head">
          <input class="command-input" id="commandInput" type="text" placeholder="Search sections and systems..." />
          <button class="close-btn" id="commandClose" type="button">Close</button>
        </div>
        <div class="command-body">
          <div class="command-list" id="commandList">
            <a href="#mission" data-command="mission control projects systems">
              <strong>Mission Control</strong><span>Projects grid</span>
            </a>
            <a href="#case-studies" data-command="case studies featured traffic racing biosphere">
              <strong>Case Studies</strong><span>Featured systems</span>
            </a>
            <a href="#fields" data-command="fields motorsport engineering environment business">
              <strong>Operating Fields</strong><span>Four focus areas</span>
            </a>
            <a href="#now" data-command="now current active queue">
              <strong>Now</strong><span>Current build queue</span>
            </a>
            <a href="/traffic-control/" data-command="traffic control lab signal nodemcu">
              <strong>Traffic Control</strong><span>Protected lab</span>
            </a>
            <a href="#contact" data-command="contact email instagram github phone">
              <strong>Contact</strong><span>Communication links</span>
            </a>
          </div>
