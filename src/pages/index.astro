    <script is:inline>
      const $ = (selector, root = document) => root.querySelector(selector);
      const $$ = (selector, root = document) => Array.from(root.querySelectorAll(selector));

      const progress = $("#progress");
      const clock = $("#clock");
      const dateLine = $("#dateLine");
      const year = $("#year");
      const navLinks = $("#navLinks");
      const menuBtn = $("#menuBtn");

      const projectModal = $("#projectModal");
      const modalClose = $("#modalClose");
      const modalTitle = $("#modalTitle");
      const modalSub = $("#modalSub");
      const modalSummary = $("#modalSummary");
      const modalDetails = $("#modalDetails");

      const commandPalette = $("#commandPalette");
      const commandOpen = $("#commandOpen");
      const commandClose = $("#commandClose");
      const commandInput = $("#commandInput");
      const commandItems = $$("#commandList a");

      const cases = {
        traffic: {
          title: "Traffic Signal Build",
          copy:
            "A physical relay-controlled traffic signal connected to a public website through a Cloudflare Worker, with protected commands, public visibility, stable local timing, and a timer mode for focus sessions.",
          problem: "Remote control without exposing the local device",
          system: "Website → Worker → KV → NodeMCU",
          next: "Reliability, logging, enclosure, fail-safe logic",
          link: "/traffic-control/",
        },
        racing: {
          title: "Motorsport Credibility",
          copy:
            "A structured driver platform that connects F4 testing, drift instruction, simulator work, Indian-driver positioning, and a sponsor-ready narrative.",
          problem: "Convert raw driving interest into visible credibility",
          system: "Track work → simulator → media kit → sponsor pathway",
          next: "Portfolio deck, testing calendar, content proof",
          link: "#contact",
        },
        biosphere: {
          title: "Rajaji Raghati Biosphere",
          copy:
            "A long-term restoration asset: land, ecology, biodiversity, native planting, fencing-first implementation, cost logic, and institutional storytelling.",
          problem: "Turn degraded land into a real ecological asset",
          system: "Land → protection → native planting → monitoring",
          next: "Phased execution, visual documentation, partners",
          link: "#contact",
        },
      };

      function updateProgress() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const percentage = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        progress.style.width = `${percentage}%`;
      }

      function updateClock() {
        const now = new Date();

        clock.textContent = now.toLocaleTimeString("en-IN", {
          hour: "2-digit",
          minute: "2-digit",
          hour12: false,
          timeZone: "Asia/Kolkata",
        });

        dateLine.textContent = now.toLocaleDateString("en-IN", {
          weekday: "long",
          day: "numeric",
          month: "long",
          year: "numeric",
          timeZone: "Asia/Kolkata",
        });
      }

      function animateCounters() {
        $$("[data-count]").forEach((node) => {
          const target = Number(node.dataset.count || 0);
          const duration = 1000;
          const start = performance.now();

          function tick(now) {
            const progressValue = Math.min(1, (now - start) / duration);
            const eased = 1 - Math.pow(1 - progressValue, 3);
            node.textContent = Math.round(target * eased);

            if (progressValue < 1) {
              requestAnimationFrame(tick);
            }
          }

          requestAnimationFrame(tick);
        });
      }

      function setupReveal() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12 }
        );

        $$(".reveal").forEach((node) => observer.observe(node));
      }

      function setupFilters() {
        const filters = $$(".filter");
        const cards = $$(".project-card");

        filters.forEach((filter) => {
          filter.addEventListener("click", () => {
            const value = filter.dataset.filter;

            filters.forEach((item) => item.classList.remove("active"));
            filter.classList.add("active");

            cards.forEach((card) => {
              const tags = card.dataset.tags || "";
              const show = value === "all" || tags.includes(value);
              card.classList.toggle("hidden", !show);
            });
          });
        });
      }

      function setupProjectModal() {
        $$(".project-card").forEach((card) => {
          const open = () => {
            modalTitle.textContent = card.dataset.title || "Project";
            modalSub.textContent = card.dataset.status || "System";
            modalSummary.textContent = card.dataset.summary || "";

            modalDetails.innerHTML = "";
            const details = (card.dataset.details || "")
              .split("|")
              .map((item) => item.trim())
              .filter(Boolean);

            details.forEach((item) => {
              const li = document.createElement("li");
              li.textContent = item;
              modalDetails.appendChild(li);
            });

            projectModal.classList.add("open");
            projectModal.setAttribute("aria-hidden", "false");
            document.body.classList.add("menu-open");
          };

          card.addEventListener("click", (event) => {
            if (event.target.closest("a")) return;
            open();
          });
        });

        function close() {
          projectModal.classList.remove("open");
          projectModal.setAttribute("aria-hidden", "true");
          document.body.classList.remove("menu-open");
        }

        modalClose.addEventListener("click", close);
        projectModal.addEventListener("click", (event) => {
          if (event.target === projectModal) close();
        });
      }

      function setupCases() {
        const tabs = $$(".case-tab");

        tabs.forEach((tab) => {
          tab.addEventListener("click", () => {
            const key = tab.dataset.case;
            const data = cases[key];

            if (!data) return;

            tabs.forEach((item) => item.classList.remove("active"));
            tab.classList.add("active");

            $("#caseTitle").textContent = data.title;
            $("#caseCopy").textContent = data.copy;
            $("#caseProblem").textContent = data.problem;
            $("#caseSystem").textContent = data.system;
            $("#caseNext").textContent = data.next;
            $("#caseLink").href = data.link;
          });
        });
      }

      function setupCommandPalette() {
        function open() {
          commandPalette.classList.add("open");
          commandPalette.setAttribute("aria-hidden", "false");
          document.body.classList.add("menu-open");
          commandInput.value = "";
          commandItems.forEach((item) => (item.style.display = "flex"));
          setTimeout(() => commandInput.focus(), 40);
        }

        function close() {
          commandPalette.classList.remove("open");
          commandPalette.setAttribute("aria-hidden", "true");
          document.body.classList.remove("menu-open");
        }

        commandOpen.addEventListener("click", open);
        commandClose.addEventListener("click", close);

        commandPalette.addEventListener("click", (event) => {
          if (event.target === commandPalette) close();
        });

        commandInput.addEventListener("input", () => {
          const query = commandInput.value.trim().toLowerCase();

          commandItems.forEach((item) => {
            const haystack = `${item.textContent} ${item.dataset.command}`.toLowerCase();
            item.style.display = haystack.includes(query) ? "flex" : "none";
          });
        });

        commandItems.forEach((item) => {
          item.addEventListener("click", close);
        });

        window.addEventListener("keydown", (event) => {
          const key = event.key.toLowerCase();

          if ((event.ctrlKey || event.metaKey) && key === "k") {
            event.preventDefault();
            open();
          }

          if (key === "escape") {
            close();
            projectModal.classList.remove("open");
            document.body.classList.remove("menu-open");
          }
        });
      }

      function setupMobileMenu() {
        menuBtn.addEventListener("click", () => {
          navLinks.classList.toggle("mobile-open");
        });

        $$("#navLinks a").forEach((link) => {
          link.addEventListener("click", () => {
            navLinks.classList.remove("mobile-open");
          });
        });
      }

      function init() {
        year.textContent = new Date().getFullYear();

        updateClock();
        updateProgress();
        setInterval(updateClock, 1000);

        setupReveal();
        setupFilters();
        setupProjectModal();
        setupCases();
        setupCommandPalette();
        setupMobileMenu();

        animateCounters();

        window.addEventListener("scroll", updateProgress, { passive: true });
      }

      init();
    </script>
  </body>
</html>
