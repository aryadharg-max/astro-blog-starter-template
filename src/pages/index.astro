---
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Aryadhar Gupta | Builder. Driver. Operator.</title>
    <meta
      name="description"
      content="Aryadhar Gupta — motorsport, engineering, environment, physical systems, product builds, and business operations."
    />

    <style>
      :root {
        --bg: #f4efe4;
        --bg-2: #ebe3d5;
        --text: #111111;
        --muted: #6f695f;
        --line: rgba(17, 17, 17, 0.12);
        --panel: rgba(255, 255, 255, 0.64);
        --panel-strong: rgba(255, 255, 255, 0.86);
        --dark: #101010;
        --navy: #0d2947;
        --navy-2: #061a2d;
        --gold: #b88a32;
        --green: #188f61;
        --red: #d34035;
        --yellow: #d6a91f;
        --blue: #1b5d91;
        --shadow: 0 34px 90px rgba(17, 17, 17, 0.12);
        --soft-shadow: 0 18px 50px rgba(17, 17, 17, 0.08);
        --radius-xl: 34px;
        --radius-lg: 24px;
        --radius-md: 16px;
        --max: 1440px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--text);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at 6% 0%, rgba(13, 41, 71, 0.18), transparent 34rem),
          radial-gradient(circle at 92% 12%, rgba(184, 138, 50, 0.18), transparent 30rem),
          radial-gradient(circle at 72% 94%, rgba(24, 143, 97, 0.12), transparent 38rem),
          linear-gradient(180deg, var(--bg), var(--bg-2));
        overflow-x: hidden;
      }

      body.menu-open {
        overflow: hidden;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button,
      input {
        font: inherit;
      }

      button {
        cursor: pointer;
      }

      .noise {
        position: fixed;
        inset: 0;
        z-index: -1;
        opacity: 0.23;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(17, 17, 17, 0.035) 1px, transparent 1px),
          linear-gradient(90deg, rgba(17, 17, 17, 0.035) 1px, transparent 1px);
        background-size: 42px 42px;
        mask-image: linear-gradient(to bottom, black, transparent 88%);
      }

      .progress {
        position: fixed;
        top: 0;
        left: 0;
        width: 0%;
        height: 3px;
        z-index: 100;
        background: linear-gradient(90deg, var(--navy), var(--gold));
      }

      .shell {
        width: min(var(--max), calc(100% - 32px));
        margin: 0 auto;
      }

      .nav {
        position: sticky;
        top: 12px;
        z-index: 80;
        margin-top: 12px;
      }

      .nav-inner {
        min-height: 64px;
        border: 1px solid var(--line);
        border-radius: 22px;
        background: rgba(244, 239, 228, 0.72);
        backdrop-filter: blur(24px) saturate(1.2);
        box-shadow: 0 16px 40px rgba(17, 17, 17, 0.08);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        padding: 10px 12px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: fit-content;
      }

      .brand-mark {
        width: 42px;
        height: 42px;
        border-radius: 15px;
        background:
          radial-gradient(circle at 30% 18%, rgba(255, 255, 255, 0.45), transparent 22px),
          linear-gradient(135deg, var(--navy), #081523);
        color: white;
        display: grid;
        place-items: center;
        font-weight: 950;
        letter-spacing: -0.08em;
        box-shadow: 0 14px 34px rgba(13, 41, 71, 0.26);
      }

      .brand-text strong {
        display: block;
        line-height: 1;
        letter-spacing: -0.04em;
      }

      .brand-text span {
        display: block;
        margin-top: 4px;
        font-size: 12px;
        color: var(--muted);
      }

      .nav-links {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        flex-wrap: wrap;
      }

      .nav-links a,
      .nav-command {
        border: 1px solid transparent;
        border-radius: 999px;
        padding: 10px 12px;
        color: var(--muted);
        background: transparent;
        transition: 0.18s ease;
        font-size: 13px;
        font-weight: 800;
      }

      .nav-links a:hover,
      .nav-command:hover {
        color: var(--text);
        border-color: var(--line);
        background: rgba(255, 255, 255, 0.54);
      }

      .nav-actions {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .nav-command {
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }

      .keycap {
        border: 1px solid var(--line);
        border-bottom-width: 2px;
        background: rgba(255, 255, 255, 0.72);
        border-radius: 8px;
        padding: 2px 6px;
        font-size: 11px;
        color: var(--text);
      }

      .menu-btn {
        display: none;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.66);
        border-radius: 14px;
        padding: 10px 12px;
        font-weight: 900;
      }

      .hero {
        padding: clamp(42px, 8vw, 110px) 0 38px;
        min-height: calc(100vh - 96px);
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 22px;
        align-items: stretch;
      }

      .hero-main,
      .hero-panel,
      .panel,
      .card,
      .case-shell,
      .contact-card {
        border: 1px solid var(--line);
        background: var(--panel);
        backdrop-filter: blur(24px);
        box-shadow: var(--shadow);
      }

      .hero-main {
        border-radius: var(--radius-xl);
        padding: clamp(24px, 5vw, 56px);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 680px;
        position: relative;
        overflow: hidden;
      }

      .hero-main::before {
        content: "";
        position: absolute;
        inset: 18px;
        border: 1px solid rgba(17, 17, 17, 0.08);
        border-radius: 26px;
        pointer-events: none;
      }

      .hero-main::after {
        content: "";
        position: absolute;
        width: 520px;
        height: 520px;
        border-radius: 50%;
        right: -260px;
        bottom: -260px;
        background: rgba(13, 41, 71, 0.08);
        pointer-events: none;
      }

      .hero-content {
        position: relative;
        z-index: 1;
      }

      .status-strip {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 28px;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.58);
        border-radius: 999px;
        padding: 9px 12px;
        color: var(--muted);
        font-size: 13px;
        font-weight: 800;
      }

      .pulse {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--green);
        box-shadow: 0 0 0 7px rgba(24, 143, 97, 0.12);
      }

      .hero h1 {
        margin: 0;
        font-size: clamp(54px, 9vw, 132px);
        line-height: 0.82;
        letter-spacing: -0.1em;
        max-width: 950px;
      }

      .hero h1 span {
        display: block;
      }

      .hero-copy {
        margin: 28px 0 0;
        max-width: 760px;
        color: var(--muted);
        font-size: clamp(17px, 2vw, 22px);
        line-height: 1.45;
      }

      .hero-copy strong {
        color: var(--text);
      }

      .hero-grid {
        position: relative;
        z-index: 1;
        margin-top: 42px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
      }

      .metric {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.58);
        border-radius: 20px;
        padding: 16px;
        min-height: 116px;
      }

      .metric span {
        display: block;
        color: var(--muted);
        font-size: 12px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.11em;
      }

      .metric strong {
        display: block;
        margin-top: 12px;
        font-size: clamp(26px, 3vw, 42px);
        letter-spacing: -0.07em;
      }

      .metric em {
        display: block;
        margin-top: 5px;
        color: var(--muted);
        font-style: normal;
        font-size: 13px;
      }

      .hero-actions {
        position: relative;
        z-index: 1;
        margin-top: 34px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .btn {
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 13px 16px;
        background: rgba(255, 255, 255, 0.66);
        color: var(--text);
        font-weight: 900;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition:
          transform 0.18s ease,
          box-shadow 0.18s ease,
          background 0.18s ease,
          border-color 0.18s ease;
      }

      .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 16px 36px rgba(17, 17, 17, 0.1);
        border-color: rgba(13, 41, 71, 0.24);
      }

      .btn.primary {
        background: linear-gradient(135deg, var(--navy), var(--navy-2));
        color: white;
        border-color: rgba(13, 41, 71, 0.7);
      }

      .btn.ghost {
        background: rgba(255, 255, 255, 0.42);
      }

      .hero-panel {
        border-radius: var(--radius-xl);
        padding: 18px;
        display: grid;
        gap: 14px;
        align-content: stretch;
        min-height: 680px;
      }

      .monitor {
        border-radius: 28px;
        background:
          radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.12), transparent 35%),
          linear-gradient(180deg, #121212, #070707);
        color: white;
        padding: 20px;
        min-height: 360px;
        display: grid;
        align-content: space-between;
        overflow: hidden;
        position: relative;
      }

      .monitor::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.045) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.045) 1px, transparent 1px);
        background-size: 32px 32px;
        opacity: 0.5;
        pointer-events: none;
      }

      .monitor-top,
      .monitor-bottom {
        position: relative;
        z-index: 1;
      }

      .monitor-kicker {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        color: rgba(255, 255, 255, 0.62);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.13em;
        font-weight: 900;
      }

      .clock {
        margin-top: 24px;
        font-size: clamp(40px, 6vw, 72px);
        line-height: 1;
        letter-spacing: -0.08em;
        font-weight: 950;
      }

      .date-line {
        color: rgba(255, 255, 255, 0.58);
        margin-top: 8px;
      }

      .focus-line {
        margin-top: 32px;
        display: grid;
        gap: 9px;
      }

      .focus-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 14px;
        padding: 10px 12px;
        background: rgba(255, 255, 255, 0.05);
      }

      .focus-item span {
        color: rgba(255, 255, 255, 0.62);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: 900;
      }

      .focus-item strong {
        text-align: right;
        font-size: 13px;
      }

      .signal-row {
        display: grid;
        grid-template-columns: repeat(24, 1fr);
        gap: 4px;
        margin-top: 24px;
      }

      .signal-row span {
        height: 28px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
        transform-origin: bottom;
        animation: signalWave 2.2s ease-in-out infinite;
      }

      .signal-row span:nth-child(3n) {
        animation-delay: 0.2s;
      }

      .signal-row span:nth-child(4n) {
        animation-delay: 0.42s;
      }

      .signal-row span:nth-child(5n) {
        animation-delay: 0.68s;
      }

      @keyframes signalWave {
        0%,
        100% {
          transform: scaleY(0.35);
          background: rgba(255, 255, 255, 0.12);
        }
        50% {
          transform: scaleY(1);
          background: rgba(255, 255, 255, 0.34);
        }
      }

      .mini-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
      }

      .mini-card {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.58);
        border-radius: 24px;
        padding: 18px;
        min-height: 150px;
      }

      .mini-card span {
        color: var(--muted);
        font-size: 12px;
        font-weight: 900;
        letter-spacing: 0.11em;
        text-transform: uppercase;
      }

      .mini-card strong {
        display: block;
        margin-top: 18px;
        font-size: 26px;
        letter-spacing: -0.06em;
      }

      .mini-card p {
        color: var(--muted);
        margin: 8px 0 0;
        line-height: 1.4;
        font-size: 14px;
      }

      section {
        padding: 54px 0;
      }

      .section-head {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: 20px;
      }

      .section-head h2 {
        margin: 0;
        font-size: clamp(34px, 5vw, 74px);
        line-height: 0.88;
        letter-spacing: -0.085em;
      }

      .section-head p {
        margin: 0;
        max-width: 540px;
        color: var(--muted);
        font-size: 16px;
        line-height: 1.5;
      }

      .filters {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 20px 0;
      }

      .filter {
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.5);
        padding: 10px 12px;
        color: var(--muted);
        font-weight: 900;
        font-size: 13px;
        transition: 0.18s ease;
      }

      .filter.active,
      .filter:hover {
        color: white;
        background: var(--navy);
        border-color: var(--navy);
      }

      .projects-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 14px;
      }

      .project-card {
        grid-column: span 4;
        min-height: 322px;
        border: 1px solid var(--line);
        border-radius: 28px;
        background: var(--panel);
        backdrop-filter: blur(22px);
        box-shadow: var(--soft-shadow);
        padding: 18px;
        display: grid;
        align-content: space-between;
        position: relative;
        overflow: hidden;
        transition:
          transform 0.2s ease,
          box-shadow 0.2s ease,
          opacity 0.2s ease;
      }

      .project-card.feature {
        grid-column: span 6;
        min-height: 360px;
      }

      .project-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow);
      }

      .project-card.hidden {
        display: none;
      }

      .project-card::after {
        content: "";
        position: absolute;
        inset: auto -100px -130px auto;
        width: 280px;
        height: 280px;
        border-radius: 50%;
        background: var(--orb, rgba(13, 41, 71, 0.08));
        pointer-events: none;
      }

      .project-top,
      .project-bottom {
        position: relative;
        z-index: 1;
      }

      .project-meta {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 18px;
      }

      .tag {
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.56);
        padding: 7px 9px;
        color: var(--muted);
        font-weight: 900;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      .tag.live {
        color: var(--green);
        border-color: rgba(24, 143, 97, 0.22);
      }

      .project-card h3 {
        margin: 0;
        font-size: clamp(24px, 3vw, 38px);
        letter-spacing: -0.075em;
        line-height: 0.94;
      }

      .project-card p {
        color: var(--muted);
        line-height: 1.5;
        margin: 14px 0 0;
      }

      .project-bottom {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        margin-top: 30px;
      }

      .project-bottom span {
        color: var(--muted);
        font-size: 13px;
        font-weight: 800;
      }

      .open-btn {
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 10px 12px;
        background: rgba(255, 255, 255, 0.66);
        font-weight: 900;
      }

      .case-shell {
        border-radius: var(--radius-xl);
        padding: 18px;
        display: grid;
        grid-template-columns: 0.88fr 1.12fr;
        gap: 14px;
      }

      .case-tabs {
        display: grid;
        gap: 10px;
      }

      .case-tab {
        border: 1px solid var(--line);
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.56);
        padding: 16px;
        text-align: left;
        transition: 0.18s ease;
      }

      .case-tab.active,
      .case-tab:hover {
        background: var(--navy);
        color: white;
        border-color: var(--navy);
      }

      .case-tab span {
        display: block;
        color: inherit;
        opacity: 0.65;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .case-tab strong {
        display: block;
        margin-top: 8px;
        font-size: 20px;
        letter-spacing: -0.04em;
      }

      .case-display {
        border-radius: 26px;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.45));
        border: 1px solid var(--line);
        padding: clamp(20px, 4vw, 42px);
        min-height: 500px;
        display: grid;
        align-content: space-between;
      }

      .case-display h3 {
        margin: 0;
        font-size: clamp(34px, 5vw, 72px);
        line-height: 0.9;
        letter-spacing: -0.085em;
      }

      .case-display p {
        color: var(--muted);
        font-size: 18px;
        line-height: 1.55;
        max-width: 820px;
      }

      .case-list {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        margin-top: 26px;
      }

      .case-list div {
        border: 1px solid var(--line);
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.58);
        padding: 14px;
      }

      .case-list span {
        display: block;
        color: var(--muted);
        font-size: 11px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      .case-list strong {
        display: block;
        margin-top: 8px;
        font-size: 16px;
        letter-spacing: -0.03em;
      }

      .fields-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
      }

      .field-card {
        border: 1px solid var(--line);
        background: var(--panel);
        border-radius: 28px;
        padding: 20px;
        box-shadow: var(--soft-shadow);
        min-height: 280px;
      }

      .field-card span {
        color: var(--muted);
        font-weight: 900;
        letter-spacing: 0.12em;
        font-size: 12px;
        text-transform: uppercase;
      }

      .field-card h3 {
        margin: 28px 0 0;
        font-size: 26px;
        letter-spacing: -0.06em;
      }

      .field-card p {
        color: var(--muted);
        line-height: 1.52;
      }

      .now-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 14px;
      }

      .panel {
        border-radius: var(--radius-xl);
        padding: 22px;
      }

      .queue {
        display: grid;
        gap: 10px;
      }

      .queue-item {
        display: grid;
        grid-template-columns: 130px 1fr auto;
        gap: 14px;
        align-items: center;
        border: 1px solid var(--line);
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.52);
        padding: 14px;
      }

      .queue-item span {
        color: var(--muted);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.11em;
        font-weight: 900;
      }

      .queue-item strong {
        letter-spacing: -0.03em;
      }

      .queue-item em {
        font-style: normal;
        color: var(--muted);
        font-size: 13px;
      }

      .lab-card {
        background: #111;
        color: white;
        border-radius: var(--radius-xl);
        padding: 24px;
        min-height: 100%;
        display: grid;
        align-content: space-between;
        position: relative;
        overflow: hidden;
      }

      .lab-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
        background-size: 28px 28px;
        opacity: 0.45;
      }

      .lab-card > * {
        position: relative;
        z-index: 1;
      }

      .lab-card h3 {
        margin: 0;
        font-size: 38px;
        letter-spacing: -0.08em;
      }

      .lab-card p {
        color: rgba(255, 255, 255, 0.62);
        line-height: 1.5;
      }

      .lab-links {
        display: grid;
        gap: 10px;
        margin-top: 22px;
      }

      .lab-links a {
        border: 1px solid rgba(255, 255, 255, 0.13);
        border-radius: 16px;
        padding: 12px;
        background: rgba(255, 255, 255, 0.06);
        display: flex;
        justify-content: space-between;
        gap: 12px;
      }

      .timeline {
        display: grid;
        gap: 10px;
      }

      .timeline-item {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.52);
        border-radius: 22px;
        padding: 18px;
        display: grid;
        grid-template-columns: 120px 1fr;
        gap: 16px;
      }

      .timeline-item span {
        color: var(--muted);
        font-weight: 950;
        letter-spacing: -0.04em;
      }

      .timeline-item strong {
        display: block;
        font-size: 20px;
        letter-spacing: -0.045em;
      }

      .timeline-item p {
        color: var(--muted);
        margin: 6px 0 0;
        line-height: 1.45;
      }

      .contact-card {
        border-radius: var(--radius-xl);
        padding: clamp(24px, 5vw, 54px);
        display: grid;
        grid-template-columns: 1fr 0.9fr;
        gap: 20px;
      }

      .contact-card h2 {
        margin: 0;
        font-size: clamp(42px, 7vw, 96px);
        line-height: 0.86;
        letter-spacing: -0.09em;
      }

      .contact-card p {
        color: var(--muted);
        font-size: 18px;
        line-height: 1.5;
      }

      .contact-links {
        display: grid;
        gap: 10px;
      }

      .contact-links a,
      .contact-links div {
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 16px;
        background: rgba(255, 255, 255, 0.58);
        display: flex;
        justify-content: space-between;
        gap: 16px;
        font-weight: 900;
      }

      .footer {
        padding: 28px 0 42px;
        color: var(--muted);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
        font-size: 14px;
      }

      .reveal {
        opacity: 0;
        transform: translateY(18px);
        transition:
          opacity 0.55s ease,
          transform 0.55s ease;
      }

      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }

      .modal,
      .command-palette {
        position: fixed;
        inset: 0;
        z-index: 120;
        display: none;
        place-items: center;
        padding: 18px;
        background: rgba(16, 16, 16, 0.42);
        backdrop-filter: blur(18px);
      }

      .modal.open,
      .command-palette.open {
        display: grid;
      }

      .modal-card,
      .command-card {
        width: min(760px, 100%);
        max-height: min(760px, calc(100vh - 40px));
        overflow: auto;
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 28px;
        background: rgba(244, 239, 228, 0.94);
        box-shadow: var(--shadow);
      }

      .modal-head,
      .command-head {
        position: sticky;
        top: 0;
        background: rgba(244, 239, 228, 0.88);
        backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--line);
        padding: 18px;
        display: flex;
        justify-content: space-between;
        gap: 14px;
      }

      .modal-body,
      .command-body {
        padding: 18px;
      }

      .close-btn {
        border: 1px solid var(--line);
        border-radius: 14px;
        background: white;
        padding: 10px 12px;
        font-weight: 950;
      }

      .modal-title {
        margin: 0;
        font-size: 34px;
        letter-spacing: -0.075em;
      }

      .modal-sub {
        color: var(--muted);
        margin: 4px 0 0;
      }

      .modal-body p {
        color: var(--muted);
        line-height: 1.55;
        font-size: 16px;
      }

      .detail-list {
        display: grid;
        gap: 10px;
        margin-top: 18px;
      }

      .detail-list li {
        list-style: none;
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 13px;
        background: rgba(255, 255, 255, 0.56);
      }

      .command-input {
        width: 100%;
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 16px;
        background: white;
        outline: none;
        font-weight: 800;
      }

      .command-list {
        display: grid;
        gap: 8px;
        margin-top: 14px;
      }

      .command-list a {
        border: 1px solid var(--line);
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.62);
        padding: 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }

      .command-list span {
        color: var(--muted);
        font-size: 13px;
      }

      @media (max-width: 1100px) {
        .hero,
        .case-shell,
        .now-grid,
        .contact-card {
          grid-template-columns: 1fr;
        }

        .hero-main,
        .hero-panel {
          min-height: auto;
        }

        .project-card,
        .project-card.feature {
          grid-column: span 6;
        }

        .fields-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (max-width: 760px) {
        .nav-links,
        .nav-command {
          display: none;
        }

        .menu-btn {
          display: inline-flex;
        }

        .nav-links.mobile-open {
          position: fixed;
          left: 16px;
          right: 16px;
          top: 90px;
          display: grid;
          gap: 8px;
          border: 1px solid var(--line);
          border-radius: 22px;
          background: rgba(244, 239, 228, 0.94);
          backdrop-filter: blur(20px);
          padding: 12px;
          box-shadow: var(--shadow);
        }

        .nav-links.mobile-open a {
          display: block;
          padding: 14px;
        }

        .hero-grid,
        .mini-grid,
        .case-list,
        .fields-grid {
          grid-template-columns: 1fr;
        }

        .project-card,
        .project-card.feature {
          grid-column: span 12;
        }

        .section-head {
          align-items: start;
          flex-direction: column;
        }

        .queue-item,
        .timeline-item {
          grid-template-columns: 1fr;
        }

        .hero h1 {
          font-size: clamp(58px, 19vw, 92px);
        }
      }
    </style>
  </head>

