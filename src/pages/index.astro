    <script is:inline>
      const $ = (selector, root = document) => root.querySelector(selector);
      const $$ = (selector, root = document) => Array.from(root.querySelectorAll(selector));

      const progress = $("#progress");
      const year = $("#year");
      const navLinks = $("#navLinks");
      const menuBtn = $("#menuBtn");

      const projectModal = $("#projectModal");
      const modalClose = $("#modalClose");
      const modalTitle = $("#modalTitle");
      const modalSub = $("#modalSub");
      const modalSummary = $("#modalSummary");
      const modalDetails = $("#modalDetails");

      const commandPalette = $("#commandPalette");
      const commandOpen = $("#commandOpen");
      const commandClose = $("#commandClose");
      const commandInput = $("#commandInput");
      const commandItems = $$("#commandList a");

      const caseData = {
        iot: {
          kicker: "Live IoT System",
          title: "Traffic Light Control",
          copy:
            "A connected control system linking a physical traffic light setup to a web interface, Cloudflare Worker, live state, password-protected commands, and local hardware logic.",
          objective: "Control physical hardware remotely without exposing the local device.",
          architecture: "Website → Worker → KV state → ESP8266 polling loop.",
          proof: "A live control panel connected to a real relay-based lighting system.",
          next: "IoT control, device dashboards, connected hardware, and automation prototypes.",
          link: "/traffic-control/",
          button: "Open Live Demo →",
        },
        tracking: {
          kicker: "Operations System",
          title: "Product & Asset Tracking",
          copy:
            "A custom system layer for businesses that need to track products, assets, inventory, batches, movement, or operational status across a workflow.",
          objective: "Make products, assets, and movement visible instead of scattered across messages or manual records.",
          architecture: "IDs or QR codes → status updates → database → dashboard → reports.",
          proof: "A clear operational interface for status, ownership, movement, and exceptions.",
          next: "Manufacturing, warehousing, service businesses, logistics teams, and product operations.",
          link: "#contact",
          button: "Start This Build →",
        },
        monitoring: {
          kicker: "Oversight System",
          title: "Monitoring Dashboard",
          copy:
            "A monitoring and visibility system for authorized site oversight, camera-linked review, event logs, alerts, and operational reporting.",
          objective: "Give a business better visibility over sites, workflows, events, equipment, or field conditions.",
          architecture: "Cameras or sensors → event layer → dashboard → alerts → records.",
          proof: "A practical monitoring layer that helps teams see, respond, and document activity.",
          next: "Site monitoring, process oversight, environmental data, field systems, and controlled surveillance use cases.",
          link: "#contact",
          button: "Discuss Monitoring →",
        },
      };

      function updateProgress() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const percentage = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        progress.style.width = `${percentage}%`;
      }

      function setupReveal() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12 }
        );

        $$(".reveal").forEach((node) => observer.observe(node));
      }

      function setupFilters() {
        const filters = $$(".filter");
        const cards = $$(".project-card");

        filters.forEach((filter) => {
          filter.addEventListener("click", () => {
            const value = filter.dataset.filter;

            filters.forEach((item) => item.classList.remove("active"));
            filter.classList.add("active");

            cards.forEach((card) => {
              const tags = card.dataset.tags || "";
              const show = value === "all" || tags.includes(value);
              card.classList.toggle("hidden", !show);
            });
          });
        });
      }

      function setupProjectModal() {
        $$(".project-card").forEach((card) => {
          card.addEventListener("click", (event) => {
            if (event.target.closest("a")) return;

            modalTitle.textContent = card.dataset.title || "System";
            modalSub.textContent = card.dataset.status || "Capability";
            modalSummary.textContent = card.dataset.summary || "";

            modalDetails.innerHTML = "";
            const details = (card.dataset.details || "")
              .split("|")
              .map((item) => item.trim())
              .filter(Boolean);

            details.forEach((item) => {
              const li = document.createElement("li");
              li.textContent = item;
              modalDetails.appendChild(li);
            });

            projectModal.classList.add("open");
            projectModal.setAttribute("aria-hidden", "false");
            document.body.classList.add("locked");
          });
        });

        function close() {
          projectModal.classList.remove("open");
          projectModal.setAttribute("aria-hidden", "true");
          document.body.classList.remove("locked");
        }

        modalClose.addEventListener("click", close);
        projectModal.addEventListener("click", (event) => {
          if (event.target === projectModal) close();
        });
      }

      function setupCases() {
        const tabs = $$(".case-tab");

        tabs.forEach((tab) => {
          tab.addEventListener("click", () => {
            const data = caseData[tab.dataset.case];
            if (!data) return;

            tabs.forEach((item) => item.classList.remove("active"));
            tab.classList.add("active");

            $("#caseKicker").textContent = data.kicker;
            $("#caseTitle").textContent = data.title;
            $("#caseCopy").textContent = data.copy;
            $("#caseObjective").textContent = data.objective;
            $("#caseArchitecture").textContent = data.architecture;
            $("#caseProof").textContent = data.proof;
            $("#caseNext").textContent = data.next;
            $("#caseLink").href = data.link;
            $("#caseLink").textContent = data.button;
          });
        });
      }

      function setupCommandPalette() {
        function open() {
          commandPalette.classList.add("open");
          commandPalette.setAttribute("aria-hidden", "false");
          document.body.classList.add("locked");
          commandInput.value = "";
          commandItems.forEach((item) => (item.style.display = "flex"));
          setTimeout(() => commandInput.focus(), 40);
        }

        function close() {
          commandPalette.classList.remove("open");
          commandPalette.setAttribute("aria-hidden", "true");
          document.body.classList.remove("locked");
        }

        commandOpen?.addEventListener("click", open);
        commandClose.addEventListener("click", close);

        commandPalette.addEventListener("click", (event) => {
          if (event.target === commandPalette) close();
        });

        commandInput.addEventListener("input", () => {
          const query = commandInput.value.trim().toLowerCase();

          commandItems.forEach((item) => {
            const haystack = `${item.textContent} ${item.dataset.command}`.toLowerCase();
            item.style.display = haystack.includes(query) ? "flex" : "none";
          });
        });

        commandItems.forEach((item) => {
          item.addEventListener("click", close);
        });

        window.addEventListener("keydown", (event) => {
          const key = event.key.toLowerCase();

          if ((event.ctrlKey || event.metaKey) && key === "k") {
            event.preventDefault();
            if (window.innerWidth > 820) open();
          }

          if (key === "escape") {
            close();
            projectModal.classList.remove("open");
            document.body.classList.remove("locked");
          }
        });
      }

      function setupMobileMenu() {
        menuBtn.addEventListener("click", () => {
          navLinks.classList.toggle("mobile-open");
        });

        $$("#navLinks a").forEach((link) => {
          link.addEventListener("click", () => {
            navLinks.classList.remove("mobile-open");
          });
        });
      }

      function init() {
        year.textContent = new Date().getFullYear();

        updateProgress();
        setupReveal();
        setupFilters();
        setupProjectModal();
        setupCases();
        setupCommandPalette();
        setupMobileMenu();

        window.addEventListener("scroll", updateProgress, { passive: true });
      }

      init();
    </script>
  </body>
