---
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Aryadhar Gupta | Custom Technology Systems</title>
    <meta
      name="description"
      content="Aryadhar Gupta builds custom technology systems for businesses and operational projects, including IoT solutions, web platforms, control dashboards, product tracking systems, surveillance and monitoring tools, logistics technology, CAD/CAM workflows, and hands-on physical builds."
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT,WONK@9..144,400..850,0..100,0..1&family=IBM+Plex+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --bg: #f2ede3;
        --bg-2: #e8dece;
        --text: #11110f;
        --muted: #716a60;
        --line: rgba(17, 17, 15, 0.12);
        --line-strong: rgba(17, 17, 15, 0.22);
        --panel: rgba(255, 255, 255, 0.64);
        --panel-strong: rgba(255, 255, 255, 0.82);
        --navy: #0b243f;
        --navy-2: #071623;
        --red: #d63d31;
        --gold: #ad7e2b;
        --green: #177a55;
        --dark: #10100e;
        --shadow: 0 26px 72px rgba(17, 17, 15, 0.1);
        --soft-shadow: 0 14px 36px rgba(17, 17, 15, 0.07);
        --radius-xl: 30px;
        --radius-lg: 24px;
        --radius-md: 16px;
        --max: 1360px;
        --display: "Fraunces", Georgia, serif;
        --body: "Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --mono: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--text);
        font-family: var(--body);
        background:
          linear-gradient(120deg, rgba(11, 36, 63, 0.065), transparent 25rem),
          linear-gradient(240deg, rgba(214, 61, 49, 0.045), transparent 24rem),
          linear-gradient(180deg, var(--bg), var(--bg-2));
        overflow-x: hidden;
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
      }

      body.locked {
        overflow: hidden;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button,
      input {
        font: inherit;
      }

      button {
        cursor: pointer;
      }

      .grid-noise {
        position: fixed;
        inset: 0;
        z-index: -1;
        opacity: 0.16;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(17, 17, 15, 0.034) 1px, transparent 1px),
          linear-gradient(90deg, rgba(17, 17, 15, 0.034) 1px, transparent 1px);
        background-size: 48px 48px;
        mask-image: linear-gradient(to bottom, black 0%, rgba(0, 0, 0, 0.7) 48%, transparent 96%);
      }

      .progress {
        position: fixed;
        top: 0;
        left: 0;
        width: 0%;
        height: 3px;
        z-index: 200;
        background: linear-gradient(90deg, var(--red), var(--gold), var(--navy));
        box-shadow: 0 0 16px rgba(214, 61, 49, 0.2);
      }

      .shell {
        width: min(var(--max), calc(100% - 32px));
        margin: 0 auto;
      }

      .nav {
        position: sticky;
        top: 12px;
        z-index: 100;
        margin-top: 12px;
      }

      .nav-inner {
        min-height: 62px;
        border: 1px solid var(--line);
        border-radius: 20px;
        background: rgba(242, 237, 227, 0.82);
        backdrop-filter: blur(22px) saturate(1.2);
        box-shadow: 0 14px 32px rgba(17, 17, 15, 0.07);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        padding: 10px 12px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: fit-content;
      }

      .brand-mark {
        width: 40px;
        height: 40px;
        border-radius: 14px;
        background:
          radial-gradient(circle at 30% 18%, rgba(255, 255, 255, 0.42), transparent 22px),
          linear-gradient(135deg, var(--navy), var(--navy-2));
        color: white;
        display: grid;
        place-items: center;
        font-weight: 950;
        letter-spacing: -0.08em;
        box-shadow: 0 12px 28px rgba(11, 36, 63, 0.24);
      }

      .brand-text strong {
        display: block;
        line-height: 1;
        letter-spacing: -0.04em;
      }

      .brand-text span {
        display: block;
        margin-top: 4px;
        font-size: 12px;
        color: var(--muted);
      }

      .nav-links {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        flex-wrap: wrap;
      }

      .nav-links a,
      .command-trigger {
        border: 1px solid transparent;
        border-radius: 999px;
        padding: 9px 11px;
        color: var(--muted);
        background: transparent;
        transition: 0.18s ease;
        font-size: 13px;
        font-weight: 800;
      }

      .nav-links a:hover,
      .command-trigger:hover {
        color: var(--text);
        border-color: var(--line);
        background: rgba(255, 255, 255, 0.58);
      }

      .command-trigger {
        display: inline-flex;
        align-items: center;
        gap: 7px;
      }

      .keycap {
        border: 1px solid var(--line);
        border-bottom-width: 2px;
        background: rgba(255, 255, 255, 0.72);
        border-radius: 8px;
        padding: 2px 6px;
        font-family: var(--mono);
        font-size: 11px;
        color: var(--text);
      }

      .menu-btn {
        display: none;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.66);
        border-radius: 14px;
        padding: 10px 12px;
        font-weight: 900;
      }

      .hero {
        padding: clamp(38px, 6.2vw, 82px) 0 38px;
        min-height: calc(100vh - 96px);
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(350px, 0.9fr);
        gap: 16px;
        align-items: stretch;
      }

      .glass {
        border: 1px solid var(--line);
        background: var(--panel);
        backdrop-filter: blur(22px);
        box-shadow: var(--shadow);
      }

      .hero-main {
        border-radius: var(--radius-xl);
        padding: clamp(24px, 4.4vw, 50px);
        min-height: 640px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
      }

      .hero-main::before {
        content: "";
        position: absolute;
        inset: 18px;
        border: 1px solid rgba(17, 17, 15, 0.075);
        border-radius: 24px;
        pointer-events: none;
      }

      .system-line {
        position: absolute;
        left: -12%;
        bottom: 18%;
        width: 130%;
        height: 76px;
        pointer-events: none;
        opacity: 0.58;
        background:
          linear-gradient(105deg, transparent 0 12%, rgba(214, 61, 49, 0.14) 12% 13%, transparent 13% 22%, rgba(214, 61, 49, 0.42) 22% 23%, transparent 23% 100%),
          linear-gradient(105deg, transparent 0 45%, rgba(11, 36, 63, 0.09) 45% 46%, transparent 46% 100%);
        transform: rotate(-7deg);
      }

      .hero-content,
      .hero-proof {
        position: relative;
        z-index: 1;
      }

      .status-strip {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 26px;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.62);
        border-radius: 999px;
        padding: 8px 11px;
        color: var(--muted);
        font-size: 12px;
        font-weight: 800;
      }

      .pulse {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--green);
        box-shadow: 0 0 0 7px rgba(23, 122, 85, 0.12);
      }

      .hero-kicker {
        margin: 0 0 14px;
        font-family: var(--mono);
        color: var(--red);
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
      }

      .hero h1 {
        margin: 0;
        max-width: 980px;
        font-family: var(--display);
        font-size: clamp(50px, 7.2vw, 108px);
        font-weight: 720;
        line-height: 0.86;
        letter-spacing: -0.07em;
        text-wrap: balance;
      }

      .hero h1 em {
        font-style: italic;
        font-weight: 500;
        color: var(--red);
      }

      .hero-copy {
        margin: 28px 0 0;
        max-width: 820px;
        color: var(--muted);
        font-size: clamp(16px, 1.55vw, 20px);
        line-height: 1.58;
      }

      .hero-copy strong {
        color: var(--text);
      }

      .hero-actions {
        margin-top: 30px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .btn {
        border: 1px solid var(--line);
        border-radius: 15px;
        padding: 12px 15px;
        background: rgba(255, 255, 255, 0.68);
        color: var(--text);
        font-weight: 850;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition:
          transform 0.16s ease,
          box-shadow 0.16s ease,
          background 0.16s ease,
          border-color 0.16s ease;
      }

      .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 14px 30px rgba(17, 17, 15, 0.09);
        border-color: var(--line-strong);
      }

      .btn.primary {
        background: linear-gradient(135deg, var(--navy), var(--navy-2));
        color: white;
        border-color: rgba(11, 36, 63, 0.7);
      }

      .btn.redline {
        color: white;
        background: linear-gradient(135deg, var(--red), #8f1e19);
        border-color: rgba(214, 61, 49, 0.5);
      }

      .hero-proof {
        margin-top: 42px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
      }

      .proof-tile {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.6);
        border-radius: 18px;
        padding: 15px;
        min-height: 122px;
        display: grid;
        align-content: space-between;
        transition:
          transform 0.18s ease,
          border-color 0.18s ease,
          background 0.18s ease;
      }

      .proof-tile:hover {
        transform: translateY(-3px);
        border-color: rgba(214, 61, 49, 0.22);
        background: rgba(255, 255, 255, 0.78);
      }

      .proof-tile span {
        font-family: var(--mono);
        color: var(--muted);
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.11em;
      }

      .proof-tile strong {
        display: block;
        margin-top: 16px;
        font-size: 15px;
        line-height: 1.22;
        letter-spacing: -0.035em;
      }

      .ops-panel {
        border-radius: var(--radius-xl);
        padding: 16px;
        min-height: 640px;
        display: grid;
        gap: 14px;
      }

      .ops-board {
        border-radius: 26px;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.055), transparent),
          #10100e;
        color: white;
        padding: 20px;
        min-height: 400px;
        display: grid;
        align-content: space-between;
        overflow: hidden;
        position: relative;
      }

      .ops-board::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
        background-size: 34px 34px;
        opacity: 0.38;
        pointer-events: none;
      }

      .ops-board > * {
        position: relative;
        z-index: 1;
      }

      .ops-topline {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        color: rgba(255, 255, 255, 0.62);
        font-family: var(--mono);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.13em;
        font-weight: 700;
      }

      .ops-title {
        margin-top: 22px;
      }

      .ops-title h2 {
        margin: 0;
        font-family: var(--display);
        font-size: clamp(40px, 4.4vw, 64px);
        line-height: 0.88;
        letter-spacing: -0.065em;
        font-weight: 700;
      }

      .ops-title p {
        color: rgba(255, 255, 255, 0.64);
        line-height: 1.55;
        margin: 15px 0 0;
        font-size: 15px;
      }

      .ops-focus {
        display: grid;
        gap: 10px;
        margin-top: 26px;
      }

      .ops-item {
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 17px;
        padding: 13px;
        background: rgba(255, 255, 255, 0.055);
        display: grid;
        grid-template-columns: 84px 1fr auto;
        gap: 12px;
        align-items: center;
      }

      .ops-item span {
        color: rgba(255, 255, 255, 0.58);
        font-family: var(--mono);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-weight: 700;
      }

      .ops-item strong {
        font-size: 14px;
        line-height: 1.25;
      }

      .ops-item em {
        font-style: normal;
        color: rgba(255, 255, 255, 0.54);
        font-size: 12px;
      }

      .signal-bars {
        margin-top: 22px;
        display: grid;
        grid-template-columns: repeat(28, 1fr);
        gap: 4px;
        align-items: end;
        height: 60px;
      }

      .signal-bars span {
        height: 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
        animation: signal 2.8s ease-in-out infinite;
      }

      .signal-bars span:nth-child(4n) {
        animation-delay: 0.22s;
      }

      .signal-bars span:nth-child(5n) {
        animation-delay: 0.38s;
      }

      .signal-bars span:nth-child(7n) {
        animation-delay: 0.58s;
        background: rgba(214, 61, 49, 0.32);
      }

      @keyframes signal {
        0%,
        100% {
          height: 12px;
        }
        50% {
          height: 54px;
        }
      }

      .side-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
      }

      .side-card {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.6);
        border-radius: 22px;
        padding: 17px;
        min-height: 164px;
      }

      .side-card span {
        color: var(--muted);
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.11em;
        text-transform: uppercase;
      }

      .side-card strong {
        display: block;
        margin-top: 20px;
        font-family: var(--display);
        font-size: 28px;
        line-height: 0.94;
        letter-spacing: -0.055em;
      }

      .side-card p {
        color: var(--muted);
        margin: 10px 0 0;
        line-height: 1.45;
        font-size: 14px;
      }

      section {
        padding: 50px 0;
      }

      .section-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: 20px;
      }

      .section-head h2 {
        margin: 0;
        font-family: var(--display);
        font-size: clamp(38px, 5.2vw, 76px);
        line-height: 0.86;
        letter-spacing: -0.07em;
        font-weight: 700;
        text-wrap: balance;
      }

      .section-head p {
        margin: 0;
        max-width: 610px;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.6;
      }

      .filters-wrap {
        margin: 18px 0;
        overflow-x: auto;
        padding-bottom: 4px;
        scrollbar-width: thin;
      }

      .filters {
        display: flex;
        gap: 8px;
        min-width: max-content;
      }

      .filter {
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.56);
        padding: 9px 12px;
        color: var(--muted);
        font-weight: 850;
        font-size: 12px;
        transition: 0.18s ease;
      }

      .filter.active,
      .filter:hover {
        color: white;
        background: var(--navy);
        border-color: var(--navy);
      }

      .projects-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 14px;
      }

      .project-card {
        grid-column: span 4;
        min-height: 320px;
        border: 1px solid var(--line);
        border-radius: 26px;
        background: var(--panel);
        backdrop-filter: blur(22px);
        box-shadow: var(--soft-shadow);
        padding: 18px;
        display: grid;
        align-content: space-between;
        position: relative;
        overflow: hidden;
        transition:
          transform 0.18s ease,
          box-shadow 0.18s ease,
          border-color 0.18s ease,
          background 0.18s ease,
          opacity 0.18s ease;
      }

      .project-card.feature {
        grid-column: span 6;
        min-height: 360px;
      }

      .project-card::before {
        content: "";
        position: absolute;
        inset: 0 0 auto 0;
        height: 4px;
        background: var(--accent, var(--navy));
        opacity: 0;
        transition: opacity 0.18s ease;
      }

      .project-card::after {
        content: "";
        position: absolute;
        inset: auto -110px -150px auto;
        width: 290px;
        height: 290px;
        border-radius: 50%;
        background: var(--orb, rgba(11, 36, 63, 0.08));
        pointer-events: none;
        transition: transform 0.22s ease, opacity 0.22s ease;
      }

      .project-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow);
        border-color: rgba(214, 61, 49, 0.24);
        background: rgba(255, 255, 255, 0.76);
      }

      .project-card:hover::before {
        opacity: 1;
      }

      .project-card:hover::after {
        transform: scale(1.06);
        opacity: 0.86;
      }

      .project-card.hidden {
        display: none;
      }

      .project-top,
      .project-bottom {
        position: relative;
        z-index: 1;
      }

      .project-meta {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 17px;
      }

      .tag {
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.58);
        padding: 6px 8px;
        color: var(--muted);
        font-family: var(--mono);
        font-weight: 700;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.09em;
      }

      .tag.live {
        color: var(--green);
        border-color: rgba(23, 122, 85, 0.24);
      }

      .project-card h3 {
        margin: 0;
        font-family: var(--display);
        font-size: clamp(28px, 3vw, 42px);
        letter-spacing: -0.065em;
        line-height: 0.93;
        font-weight: 700;
      }

      .project-card p {
        color: var(--muted);
        line-height: 1.55;
        margin: 15px 0 0;
        font-size: 15px;
      }

      .project-bottom {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        margin-top: 28px;
      }

      .project-bottom span {
        color: var(--muted);
        font-size: 13px;
        font-weight: 800;
      }

      .open-btn {
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 9px 11px;
        background: rgba(255, 255, 255, 0.66);
        font-weight: 850;
      }

      .live-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
      }

      .live-card {
        border: 1px solid var(--line);
        border-radius: var(--radius-xl);
        background: var(--panel);
        backdrop-filter: blur(24px);
        box-shadow: var(--soft-shadow);
        padding: 22px;
        min-height: 330px;
        display: grid;
        align-content: space-between;
        position: relative;
        overflow: hidden;
      }

      .live-card::before {
        content: "";
        position: absolute;
        inset: 0 0 auto 0;
        height: 4px;
        background: var(--accent, var(--green));
      }

      .live-card::after {
        content: "";
        position: absolute;
        right: -130px;
        bottom: -170px;
        width: 330px;
        height: 330px;
        border-radius: 50%;
        background: var(--orb, rgba(23, 122, 85, 0.12));
        pointer-events: none;
      }

      .live-card > * {
        position: relative;
        z-index: 1;
      }

      .live-card h3 {
        margin: 16px 0 0;
        font-family: var(--display);
        font-size: clamp(32px, 3.7vw, 50px);
        line-height: 0.92;
        letter-spacing: -0.07em;
      }

      .live-card p {
        color: var(--muted);
        line-height: 1.6;
        font-size: 15px;
      }

      .live-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .timeline-list {
        display: grid;
        gap: 10px;
      }

      .timeline-item {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.56);
        border-radius: 22px;
        padding: 17px;
        display: grid;
        grid-template-columns: 150px 1fr;
        gap: 18px;
      }

      .timeline-item span {
        color: var(--red);
        font-family: var(--mono);
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-size: 11px;
      }

      .timeline-item strong {
        display: block;
        font-size: 18px;
        letter-spacing: -0.04em;
      }

      .timeline-item p {
        color: var(--muted);
        margin: 6px 0 0;
        line-height: 1.5;
        font-size: 15px;
      }

      .contact-card {
        border: 1px solid var(--line);
        background: var(--panel);
        border-radius: var(--radius-xl);
        padding: clamp(24px, 4.5vw, 48px);
        box-shadow: var(--shadow);
        display: grid;
        grid-template-columns: 1fr 0.9fr;
        gap: 22px;
      }

      .contact-card h2 {
        margin: 0;
        font-family: var(--display);
        font-size: clamp(42px, 6vw, 84px);
        line-height: 0.86;
        letter-spacing: -0.075em;
        font-weight: 700;
      }

      .contact-card p {
        color: var(--muted);
        font-size: 17px;
        line-height: 1.6;
      }

      .contact-links {
        display: grid;
        gap: 10px;
      }

      .contact-links a,
      .contact-links div {
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 15px;
        background: rgba(255, 255, 255, 0.6);
        display: flex;
        justify-content: space-between;
        gap: 16px;
        font-weight: 850;
        transition: 0.18s ease;
      }

      .contact-links a:hover {
        transform: translateY(-2px);
        border-color: rgba(214, 61, 49, 0.24);
        background: rgba(255, 255, 255, 0.8);
      }

      .contact-links span {
        color: var(--muted);
      }

      .footer {
        padding: 26px 0 40px;
        color: var(--muted);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
        font-size: 14px;
      }

      .reveal {
        opacity: 0;
        transform: translateY(16px);
        transition:
          opacity 0.55s ease,
          transform 0.55s ease;
      }

      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }

      .modal,
      .command-palette {
        position: fixed;
        inset: 0;
        z-index: 220;
        display: none;
        place-items: center;
        padding: 18px;
        background: rgba(16, 16, 14, 0.42);
        backdrop-filter: blur(18px);
      }

      .modal.open,
      .command-palette.open {
        display: grid;
      }

      .modal-card,
      .command-card {
        width: min(760px, 100%);
        max-height: min(760px, calc(100vh - 40px));
        overflow: auto;
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 26px;
        background: rgba(242, 237, 227, 0.96);
        box-shadow: var(--shadow);
      }

      .modal-head,
      .command-head {
        position: sticky;
        top: 0;
        background: rgba(242, 237, 227, 0.9);
        backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--line);
        padding: 18px;
        display: flex;
        justify-content: space-between;
        gap: 14px;
      }

      .modal-body,
      .command-body {
        padding: 18px;
      }

      .close-btn {
        border: 1px solid var(--line);
        border-radius: 14px;
        background: white;
        padding: 10px 12px;
        font-weight: 900;
      }

      .modal-title {
        margin: 0;
        font-family: var(--display);
        font-size: 38px;
        letter-spacing: -0.07em;
        line-height: 0.92;
      }

      .modal-sub {
        color: var(--muted);
        margin: 4px 0 0;
      }

      .modal-body p {
        color: var(--muted);
        line-height: 1.6;
        font-size: 16px;
      }

      .detail-list {
        display: grid;
        gap: 10px;
        margin-top: 18px;
        padding: 0;
      }

      .detail-list li {
        list-style: none;
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 13px;
        background: rgba(255, 255, 255, 0.58);
        color: var(--text);
      }

      .modal-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 20px;
      }

      .command-input {
        width: 100%;
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 15px;
        background: white;
        outline: none;
        font-weight: 800;
      }

      .command-list {
        display: grid;
        gap: 8px;
        margin-top: 14px;
      }

      .command-list a {
        border: 1px solid var(--line);
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.62);
        padding: 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }

      .command-list span {
        color: var(--muted);
        font-size: 13px;
      }

      @media (max-width: 1160px) {
        .hero,
        .contact-card {
          grid-template-columns: 1fr;
        }

        .hero-main,
        .ops-panel {
          min-height: auto;
        }

        .project-card,
        .project-card.feature {
          grid-column: span 6;
        }

        .live-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (max-width: 820px) {
        .nav-links,
        .command-trigger {
          display: none;
        }

        .menu-btn {
          display: inline-flex;
        }

        .nav-links.mobile-open {
          position: fixed;
          left: 16px;
          right: 16px;
          top: 90px;
          display: grid;
          gap: 8px;
          border: 1px solid var(--line);
          border-radius: 22px;
          background: rgba(242, 237, 227, 0.96);
          backdrop-filter: blur(20px);
          padding: 12px;
          box-shadow: var(--shadow);
        }

        .nav-links.mobile-open a {
          display: block;
          padding: 14px;
        }

        .hero-proof,
        .side-grid,
        .live-grid {
          grid-template-columns: 1fr 1fr;
        }

        .project-card,
        .project-card.feature {
          grid-column: span 12;
        }

        .section-head {
          align-items: flex-start;
          flex-direction: column;
        }

        .timeline-item {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 560px) {
        .shell {
          width: min(100% - 20px, var(--max));
        }

        .hero {
          padding-top: 34px;
        }

        .hero h1 {
          font-size: clamp(50px, 15.5vw, 76px);
        }

        .hero-proof,
        .side-grid,
        .live-grid {
          grid-template-columns: 1fr;
        }

        .ops-item {
          grid-template-columns: 1fr;
          gap: 6px;
        }

        .contact-links a,
        .contact-links div {
          flex-direction: column;
        }
      }
    </style>
