---
const pageTitle = "AG Systems | Custom Technology Systems for Physical Operations";
const pageDescription =
  "AG Systems builds custom software, dashboards, connected hardware workflows, and operational technology systems for businesses with real-world processes.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={pageDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>

    <style>
      :root {
        --page: #f7f4ee;
        --panel: #fffdf8;
        --ink: #111111;
        --soft-ink: #3c3832;
        --muted: #6e675d;
        --faint: #9b9285;
        --line: rgba(17, 17, 17, 0.14);
        --line-strong: rgba(17, 17, 17, 0.28);
        --dark: #111111;
        --max: 1220px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: var(--page);
        color: var(--ink);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .wrap {
        width: min(var(--max), calc(100% - 48px));
        margin: 0 auto;
      }

      .topbar {
        border-bottom: 1px solid var(--line);
        background: rgba(247, 244, 238, 0.92);
        backdrop-filter: blur(14px);
        position: sticky;
        top: 0;
        z-index: 20;
      }

      .nav {
        min-height: 66px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 28px;
      }

      .brand {
        display: flex;
        align-items: baseline;
        gap: 14px;
      }

      .brand-name {
        font-size: 18px;
        font-weight: 780;
        letter-spacing: -0.04em;
      }

      .brand-line {
        color: var(--muted);
        font-size: 13px;
        letter-spacing: -0.02em;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 24px;
        color: var(--muted);
        font-size: 13px;
      }

      .nav-links a:hover {
        color: var(--ink);
      }

      .nav-action {
        color: var(--panel) !important;
        background: var(--dark);
        padding: 9px 14px;
        border-radius: 2px;
        font-weight: 650;
      }

      .hero {
        padding: 58px 0 42px;
        border-bottom: 1px solid var(--line);
      }

      .hero-layout {
        display: grid;
        grid-template-columns: minmax(0, 1.55fr) minmax(320px, 0.75fr);
        gap: 54px;
        align-items: stretch;
      }

      .label {
        margin: 0 0 18px;
        color: var(--muted);
        font-size: 12px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        max-width: 850px;
        font-size: clamp(44px, 5.25vw, 76px);
        line-height: 0.98;
        letter-spacing: -0.065em;
        font-weight: 790;
      }

      .hero-copy {
        max-width: 760px;
        margin: 24px 0 0;
        color: var(--soft-ink);
        font-size: clamp(17px, 1.55vw, 21px);
        line-height: 1.5;
        letter-spacing: -0.025em;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 28px;
      }

      .button {
        min-height: 42px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 15px;
        border: 1px solid var(--line-strong);
        border-radius: 2px;
        font-size: 13px;
        font-weight: 680;
        letter-spacing: -0.01em;
      }

      .button-dark {
        background: var(--dark);
        color: var(--panel);
        border-color: var(--dark);
      }

      .button:hover {
        opacity: 0.82;
      }

      .hero-note {
        border: 1px solid var(--line);
        background: rgba(255, 253, 248, 0.62);
        padding: 22px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      .hero-note h2 {
        margin: 0;
        font-size: 19px;
        line-height: 1.15;
        letter-spacing: -0.04em;
      }

      .note-text {
        margin: 14px 0 0;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.55;
      }

      .scope-list {
        margin: 30px 0 0;
        padding: 0;
        list-style: none;
        border-top: 1px solid var(--line);
      }

      .scope-list li {
        display: flex;
        justify-content: space-between;
        gap: 18px;
        padding: 11px 0;
        border-bottom: 1px solid var(--line);
        font-size: 13px;
      }

      .scope-list span {
        color: var(--muted);
      }

      .section {
        padding: 58px 0;
        border-bottom: 1px solid var(--line);
      }

      .section-grid {
        display: grid;
        grid-template-columns: 260px minmax(0, 1fr);
        gap: 48px;
      }

      .section-title {
        margin: 0;
        font-size: clamp(30px, 3.2vw, 48px);
        line-height: 1.02;
        letter-spacing: -0.055em;
        font-weight: 760;
      }

      .section-intro {
        margin: 12px 0 0;
        max-width: 760px;
        color: var(--muted);
        font-size: 16px;
        line-height: 1.6;
        letter-spacing: -0.015em;
      }

      .capabilities {
        border-top: 1px solid var(--line-strong);
        margin-top: 30px;
      }

      .capability-row {
        display: grid;
        grid-template-columns: 0.52fr 1fr;
        gap: 38px;
        padding: 22px 0;
        border-bottom: 1px solid var(--line);
      }

      .capability-row h3 {
        margin: 0;
        font-size: 21px;
        line-height: 1.15;
        letter-spacing: -0.04em;
        font-weight: 730;
      }

      .capability-row p {
        margin: 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.6;
      }

      .systems {
        display: grid;
        gap: 12px;
        margin-top: 30px;
      }

      .system-row {
        display: grid;
        grid-template-columns: 170px minmax(0, 1fr) 180px;
        gap: 28px;
        align-items: center;
        background: var(--panel);
        border: 1px solid var(--line);
        padding: 22px;
      }

      .system-type {
        color: var(--muted);
        font-size: 12px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        line-height: 1.45;
      }

      .system-row h3 {
        margin: 0;
        font-size: 24px;
        letter-spacing: -0.045em;
        line-height: 1.1;
      }

      .system-row p {
        margin: 8px 0 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.55;
      }

      .system-row a {
        justify-self: end;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 145px;
        min-height: 38px;
        border: 1px solid var(--line-strong);
        font-size: 13px;
        font-weight: 680;
        border-radius: 2px;
      }

      .system-row a:hover {
        background: var(--dark);
        color: var(--panel);
        border-color: var(--dark);
      }

      .usecase-panel {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        margin-top: 30px;
        border: 1px solid var(--line);
        background: var(--panel);
      }

      .usecase {
        min-height: 142px;
        padding: 22px;
        border-right: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
      }

      .usecase:nth-child(2n) {
        border-right: 0;
      }

      .usecase:nth-last-child(-n + 2) {
        border-bottom: 0;
      }

      .usecase h3 {
        margin: 0;
        font-size: 18px;
        line-height: 1.2;
        letter-spacing: -0.035em;
      }

      .usecase p {
        margin: 10px 0 0;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.55;
      }

      .method {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        margin-top: 30px;
        border-top: 1px solid var(--line-strong);
      }

      .method-step {
        padding: 20px 18px 0 0;
        border-right: 1px solid var(--line);
        min-height: 150px;
      }

      .method-step:last-child {
        border-right: 0;
      }

      .method-step span {
        color: var(--faint);
        font-size: 12px;
      }

      .method-step h3 {
        margin: 18px 0 8px;
        font-size: 18px;
        letter-spacing: -0.035em;
      }

      .method-step p {
        margin: 0;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.5;
      }

      .contact {
        padding: 54px 0 64px;
      }

      .contact-panel {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(330px, 0.7fr);
        gap: 48px;
        align-items: end;
        background: var(--dark);
        color: var(--panel);
        padding: 38px;
      }

      .contact-panel .label {
        color: rgba(255, 253, 248, 0.58);
      }

      .contact-panel h2 {
        margin: 0;
        max-width: 700px;
        font-size: clamp(34px, 4.2vw, 58px);
        line-height: 1;
        letter-spacing: -0.055em;
      }

      .contact-panel p {
        margin: 18px 0 0;
        max-width: 650px;
        color: rgba(255, 253, 248, 0.72);
        font-size: 16px;
        line-height: 1.6;
      }

      .contact-panel .button {
        border-color: rgba(255, 253, 248, 0.35);
        color: var(--panel);
        margin-top: 24px;
      }

      .contact-panel .button:hover {
        background: var(--panel);
        color: var(--dark);
      }

      .contact-list {
        border-top: 1px solid rgba(255, 253, 248, 0.22);
      }

      .contact-item {
        display: grid;
        grid-template-columns: 90px 1fr;
        gap: 18px;
        padding: 12px 0;
        border-bottom: 1px solid rgba(255, 253, 248, 0.22);
        font-size: 13px;
      }

      .contact-item span {
        color: rgba(255, 253, 248, 0.48);
      }

      .contact-item a,
      .contact-item strong {
        color: var(--panel);
        font-weight: 620;
      }

      .footer {
        padding: 22px 0;
        border-top: 1px solid var(--line);
        color: var(--muted);
        font-size: 12px;
      }

      .footer-inner {
        display: flex;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
      }

      @media (max-width: 980px) {
        .hero-layout,
        .section-grid,
        .contact-panel {
          grid-template-columns: 1fr;
        }

        .system-row {
          grid-template-columns: 1fr;
          gap: 14px;
        }

        .system-row a {
          justify-self: start;
        }

        .method {
          grid-template-columns: 1fr;
        }

        .method-step {
          min-height: auto;
          padding: 18px 0;
          border-right: 0;
          border-bottom: 1px solid var(--line);
        }

        .method-step:last-child {
          border-bottom: 0;
        }
      }

      @media (max-width: 720px) {
        .wrap {
          width: min(100% - 28px, var(--max));
        }

        .nav {
          min-height: auto;
          align-items: flex-start;
          padding: 16px 0;
        }

        .brand {
          flex-direction: column;
          gap: 3px;
        }

        .brand-line {
          max-width: 250px;
          font-size: 12px;
        }

        .nav-links {
          display: none;
        }

        .hero {
          padding: 42px 0 34px;
        }

        h1 {
          font-size: clamp(42px, 13vw, 62px);
        }

        .hero-copy {
          font-size: 16px;
        }

        .section {
          padding: 42px 0;
        }

        .section-grid {
          gap: 24px;
        }

        .capability-row {
          grid-template-columns: 1fr;
          gap: 10px;
          padding: 18px 0;
        }

        .usecase-panel {
          grid-template-columns: 1fr;
        }

        .usecase,
        .usecase:nth-child(2n),
        .usecase:nth-last-child(-n + 2) {
          border-right: 0;
          border-bottom: 1px solid var(--line);
        }

        .usecase:last-child {
          border-bottom: 0;
        }

        .contact {
          padding: 42px 0 50px;
        }

        .contact-panel {
          padding: 26px;
        }

        .contact-item {
          grid-template-columns: 1fr;
          gap: 3px;
        }
      }
    </style>
  </head>

  <body>
    <header class="topbar">
      <div class="wrap nav">
        <a class="brand" href="/" aria-label="AG Systems home">
          <span class="brand-name">AG Systems</span>
          <span class="brand-line">A technology systems company by Aryadhar Gupta.</span>
        </a>

        <nav class="nav-links" aria-label="Main navigation">
          <a href="#capabilities">Capabilities</a>
          <a href="#systems">Working Systems</a>
          <a href="#method">Method</a>
          <a class="nav-action" href="#contact">Start a Project</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="wrap hero-layout">
          <div>
            <p class="label">Operational technology / dashboards / connected systems</p>
            <h1>Custom technology systems for physical operations.</h1>
            <p class="hero-copy">
              AG Systems builds practical software, dashboards, connected hardware workflows, and data systems for
              businesses where real-world operations need better visibility, control, and structure.
            </p>

            <div class="hero-actions">
              <a class="button button-dark" href="#systems">View Working Systems</a>
              <a class="button" href="#contact">Start a Project</a>
            </div>
          </div>

          <aside class="hero-note">
            <div>
              <h2>Founder-led systems work for businesses with specific operational problems.</h2>
              <p class="note-text">
                Built by Aryadhar Gupta for use cases where off-the-shelf software does not fit the process cleanly.
              </p>
            </div>

            <ul class="scope-list" aria-label="AG Systems focus areas">
              <li><span>Focus</span><strong>Physical operations</strong></li>
              <li><span>Output</span><strong>Working systems</strong></li>
              <li><span>Includes</span><strong>Software + hardware</strong></li>
              <li><span>Base</span><strong>Delhi, India</strong></li>
            </ul>
          </aside>
        </div>
      </section>

      <section class="section" id="capabilities">
        <div class="wrap section-grid">
          <div>
            <p class="label">Capabilities</p>
          </div>

          <div>
            <h2 class="section-title">Systems that connect business workflows with live operational data.</h2>
            <p class="section-intro">
              The work sits between software development, hardware communication, data workflows, dashboards, and
              operational design.
            </p>

            <div class="capabilities">
              <article class="capability-row">
                <h3>Owner dashboards</h3>
                <p>
                  Live dashboards for revenue, devices, teams, locations, feedback, environmental data, and operational
                  activity.
                </p>
              </article>

              <article class="capability-row">
                <h3>IoT and connected hardware</h3>
                <p>
                  Sensor systems, remote control interfaces, device polling, hardware-to-cloud communication, and
                  physical output control.
                </p>
              </article>

              <article class="capability-row">
                <h3>Internal tools</h3>
                <p>
                  Custom web tools for businesses whose process is too specific for generic SaaS platforms or manual
                  spreadsheets.
                </p>
              </article>

              <article class="capability-row">
                <h3>Tracking and workflow systems</h3>
                <p>
                  Transaction-linked workflows, product movement, task status, staff activity, service records, and
                  operational logs.
                </p>
              </article>

              <article class="capability-row">
                <h3>Monitoring and reporting</h3>
                <p>
                  Systems for facilities, environmental conditions, machines, field data, performance reporting, and
                  exception visibility.
                </p>
              </article>

              <article class="capability-row">
                <h3>Automation and integrations</h3>
                <p>
                  API connections, automated reporting, alerts, backend logic, data cleanup, and system-to-system
                  workflows.
                </p>
              </article>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="systems">
        <div class="wrap section-grid">
          <div>
            <p class="label">Working Systems</p>
          </div>

          <div>
            <h2 class="section-title">Selected working systems and proof-of-capability builds.</h2>
            <p class="section-intro">
              These systems demonstrate the type of operational infrastructure AG Systems can design, build, and adapt
              into client-specific deployments.
            </p>

            <div class="systems">
              <article class="system-row">
                <div class="system-type">Revenue / feedback</div>
                <div>
                  <h3>ServiceLoop</h3>
                  <p>
                    A customer feedback and employee incentive workflow for customer-facing venues, designed to connect
                    transactions, reviews, staff mapping, and owner visibility.
                  </p>
                </div>
                <a href="/serviceloop/">Open System</a>
              </article>

              <article class="system-row">
                <div class="system-type">Connected hardware</div>
                <div>
                  <h3>Traffic Control</h3>
                  <p>
                    A web-controlled hardware system demonstrating live state, device polling, remote commands, and
                    physical output through internet-connected control.
                  </p>
                </div>
                <a href="/traffic-control/">Open System</a>
              </article>

              <article class="system-row">
                <div class="system-type">Environmental data</div>
                <div>
                  <h3>Air Quality Monitoring</h3>
                  <p>
                    A live air-quality monitoring dashboard showing how sensor data can be converted into a usable
                    interface for facilities, schools, malls, and public environments.
                  </p>
                </div>
                <a href="https://nirvanayours.com/" target="_blank" rel="noreferrer">Open Dashboard</a>
              </article>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="use-cases">
        <div class="wrap section-grid">
          <div>
            <p class="label">Use Cases</p>
          </div>

          <div>
            <h2 class="section-title">For operations where the software has to match the ground reality.</h2>
            <p class="section-intro">
              The strongest fit is a business with a real process, fragmented data, manual tracking, connected hardware,
              or a workflow that needs to become measurable.
            </p>

            <div class="usecase-panel">
              <article class="usecase">
                <h3>Malls and entertainment venues</h3>
                <p>Revenue visibility, customer feedback, staff-linked incentives, footfall workflows, and owner views.</p>
              </article>

              <article class="usecase">
                <h3>Facilities and buildings</h3>
                <p>Monitoring, maintenance workflows, sensor dashboards, equipment visibility, and reporting layers.</p>
              </article>

              <article class="usecase">
                <h3>Environmental projects</h3>
                <p>Air-quality systems, field sensors, public dashboards, data logging, and reporting infrastructure.</p>
              </article>

              <article class="usecase">
                <h3>Logistics and movement</h3>
                <p>Tracking workflows, dispatch visibility, status logs, product movement, and exception reporting.</p>
              </article>

              <article class="usecase">
                <h3>Internal operations</h3>
                <p>Tools for teams, approvals, task states, data entry, records, process control, and management views.</p>
              </article>

              <article class="usecase">
                <h3>Custom hardware workflows</h3>
                <p>Interfaces that connect devices, control outputs, collect readings, and expose live system state.</p>
              </article>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="method">
        <div class="wrap section-grid">
          <div>
            <p class="label">Method</p>
          </div>

          <div>
            <h2 class="section-title">A practical build process from workflow to deployed system.</h2>
            <p class="section-intro">
              The goal is not to add software for the sake of software. The goal is to make the operation clearer,
              faster, more measurable, or easier to control.
            </p>

            <div class="method">
              <article class="method-step">
                <span>01</span>
                <h3>Map</h3>
                <p>Understand the process, users, data, devices, and commercial objective.</p>
              </article>

              <article class="method-step">
                <span>02</span>
                <h3>Design</h3>
                <p>Define the system flow, interfaces, data structure, and operating logic.</p>
              </article>

              <article class="method-step">
                <span>03</span>
                <h3>Build</h3>
                <p>Develop the software, backend, dashboards, integrations, and device communication.</p>
              </article>

              <article class="method-step">
                <span>04</span>
                <h3>Deploy</h3>
                <p>Put the system into a real environment with testing, security, and documentation.</p>
              </article>

              <article class="method-step">
                <span>05</span>
                <h3>Improve</h3>
                <p>Use live feedback and operational data to refine the system after deployment.</p>
              </article>
            </div>
          </div>
        </div>
      </section>

      <section class="contact" id="contact">
        <div class="wrap">
          <div class="contact-panel">
            <div>
              <p class="label">Start a Project</p>
              <h2>Build a system around your operation.</h2>
              <p>
                For dashboards, internal tools, monitoring systems, connected hardware, automation, or custom operational
                software, send the process you want to improve.
              </p>
              <a class="button" href="mailto:me@aryadhargupta.com">Start a Project</a>
            </div>

            <div class="contact-list">
              <div class="contact-item">
                <span>Email</span>
                <a href="mailto:me@aryadhargupta.com">me@aryadhargupta.com</a>
              </div>

              <div class="contact-item">
                <span>Phone</span>
                <a href="tel:+919560082697">+91 95600 82697</a>
              </div>

              <div class="contact-item">
                <span>Location</span>
                <strong>Delhi, India</strong>
              </div>

              <div class="contact-item">
                <span>GitHub</span>
                <a href="https://github.com/aryadharg-max" target="_blank" rel="noreferrer">@aryadharg-max</a>
              </div>

              <div class="contact-item">
                <span>Instagram</span>
                <a href="https://instagram.com/aryadhargupta" target="_blank" rel="noreferrer">@aryadhargupta</a>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="wrap footer-inner">
        <span>© {new Date().getFullYear()} AG Systems.</span>
        <span>A technology systems company by Aryadhar Gupta.</span>
      </div>
    </footer>
  </body>
</html>
