---
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Traffic Control | Aryadhar Gupta</title>

    <style>
      :root {
        --bg: #f5f2ea;
        --panel: rgba(255, 255, 255, 0.72);
        --panel-solid: #ffffff;
        --text: #121212;
        --muted: #716d64;
        --line: rgba(18, 18, 18, 0.1);
        --blue: #102f52;
        --blue-2: #071b30;
        --red: #e53935;
        --yellow: #ffc928;
        --green: #19a765;
        --black: #111111;
        --shadow: 0 30px 90px rgba(0, 0, 0, 0.1);
        --soft-shadow: 0 18px 50px rgba(0, 0, 0, 0.07);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        color: var(--text);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(16, 47, 82, 0.11), transparent 34rem),
          radial-gradient(circle at bottom right, rgba(25, 167, 101, 0.09), transparent 34rem),
          var(--bg);
      }

      button,
      input {
        font: inherit;
      }

      button {
        cursor: pointer;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .shell {
        width: min(1440px, calc(100% - 32px));
        margin: 0 auto;
        padding: 22px 0 40px;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        margin-bottom: 18px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .mark {
        width: 44px;
        height: 44px;
        border-radius: 16px;
        background: var(--blue);
        color: white;
        display: grid;
        place-items: center;
        font-weight: 900;
        letter-spacing: -0.06em;
      }

      .brand small {
        display: block;
        color: var(--muted);
        margin-top: 2px;
      }

      .status-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: flex-end;
      }

      .chip {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.62);
        backdrop-filter: blur(18px);
        border-radius: 999px;
        padding: 9px 12px;
        font-size: 13px;
        color: var(--muted);
        display: inline-flex;
        gap: 7px;
        align-items: center;
      }

      .chip strong {
        color: var(--text);
      }

      .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #999;
      }

      .dot.online {
        background: var(--green);
        box-shadow: 0 0 0 6px rgba(25, 167, 101, 0.12);
      }

      .dot.offline {
        background: var(--red);
        box-shadow: 0 0 0 6px rgba(229, 57, 53, 0.12);
      }

      .deck {
        min-height: calc(100vh - 120px);
        display: grid;
        grid-template-columns: 1fr 410px;
        gap: 18px;
      }

      .stage {
        border: 1px solid var(--line);
        border-radius: 36px;
        background: rgba(255, 255, 255, 0.55);
        backdrop-filter: blur(24px);
        box-shadow: var(--shadow);
        padding: clamp(22px, 4vw, 52px);
        display: grid;
        grid-template-rows: auto 1fr auto;
        overflow: hidden;
        position: relative;
      }

      .stage::after {
        content: "";
        position: absolute;
        inset: auto -120px -160px auto;
        width: 420px;
        height: 420px;
        border-radius: 50%;
        background: rgba(16, 47, 82, 0.06);
        pointer-events: none;
      }

      .hero {
        position: relative;
        z-index: 1;
      }

      .eyebrow {
        margin: 0 0 10px;
        color: var(--blue);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 12px;
        font-weight: 900;
      }

      h1 {
        margin: 0;
        font-size: clamp(44px, 8vw, 104px);
        line-height: 0.86;
        letter-spacing: -0.085em;
      }

      .mode-line {
        margin-top: 16px;
        color: var(--muted);
        font-size: clamp(16px, 2vw, 20px);
      }

      .mode-line strong {
        color: var(--text);
      }

      .visual-zone {
        position: relative;
        z-index: 1;
        display: grid;
        place-items: center;
        padding: 28px 0;
      }

      .signal {
        width: min(330px, 74vw);
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.09), transparent),
          #101010;
        border-radius: 56px;
        padding: 34px;
        display: grid;
        gap: 28px;
        box-shadow:
          inset 0 0 0 1px rgba(255, 255, 255, 0.08),
          0 55px 120px rgba(0, 0, 0, 0.25);
      }

      .lamp {
        aspect-ratio: 1;
        border-radius: 50%;
        opacity: 0.25;
        transition: 0.2s ease;
        position: relative;
        box-shadow:
          inset 0 12px 26px rgba(255, 255, 255, 0.14),
          inset 0 -16px 24px rgba(0, 0, 0, 0.36);
      }

      .lamp::after {
        content: "";
        position: absolute;
        inset: 17%;
        border-radius: inherit;
        background: rgba(255, 255, 255, 0.2);
        filter: blur(4px);
      }

      .lamp.red {
        background: var(--red);
      }

      .lamp.yellow {
        background: var(--yellow);
      }

      .lamp.green {
        background: var(--green);
      }

      .lamp.on {
        opacity: 1;
        transform: scale(1.025);
      }

      .lamp.red.on {
        box-shadow:
          0 0 44px rgba(229, 57, 53, 0.72),
          0 0 120px rgba(229, 57, 53, 0.32);
      }

      .lamp.yellow.on {
        box-shadow:
          0 0 44px rgba(255, 201, 40, 0.8),
          0 0 120px rgba(255, 201, 40, 0.35);
      }

      .lamp.green.on {
        box-shadow:
          0 0 44px rgba(25, 167, 101, 0.72),
          0 0 120px rgba(25, 167, 101, 0.3);
      }

      .phase {
        position: relative;
        z-index: 1;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.64);
        border-radius: 24px;
        padding: 18px;
      }

      .phase-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        margin-bottom: 12px;
      }

      .phase-head strong {
        font-size: 18px;
        letter-spacing: -0.04em;
      }

      .phase-head span {
        color: var(--muted);
      }

      .bar {
        height: 10px;
        background: rgba(0, 0, 0, 0.08);
        border-radius: 999px;
        overflow: hidden;
      }

      .bar-fill {
        height: 100%;
        width: 0%;
        border-radius: inherit;
        background: var(--blue);
        transition: width 0.2s linear;
      }

      .timeline {
        display: grid;
        grid-template-columns: var(--red-fr, 10fr) var(--yellow-fr, 5fr) var(--green-fr, 15fr);
        gap: 3px;
        margin-top: 10px;
      }

      .timeline span {
        height: 8px;
        border-radius: 999px;
      }

      .timeline span:nth-child(1) {
        background: var(--red);
      }

      .timeline span:nth-child(2) {
        background: var(--yellow);
      }

      .timeline span:nth-child(3) {
        background: var(--green);
      }

      .control {
        border: 1px solid var(--line);
        border-radius: 36px;
        background: rgba(255, 255, 255, 0.72);
        backdrop-filter: blur(24px);
        box-shadow: var(--soft-shadow);
        padding: 18px;
        display: grid;
        align-content: start;
        gap: 14px;
      }

      .control-title {
        padding: 8px 4px 0;
      }

      .control-title h2 {
        margin: 0;
        font-size: 24px;
        letter-spacing: -0.055em;
      }

      .control-title p {
        margin: 6px 0 0;
        color: var(--muted);
        line-height: 1.45;
        font-size: 14px;
      }

      .primary-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
      }

      .btn {
        border: 1px solid var(--line);
        background: var(--panel-solid);
        color: var(--text);
        min-height: 58px;
        border-radius: 20px;
        padding: 14px 15px;
        font-weight: 900;
        letter-spacing: -0.02em;
        transition:
          transform 0.16s ease,
          box-shadow 0.16s ease,
          border-color 0.16s ease,
          background 0.16s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
      }

      .btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 16px 34px rgba(0, 0, 0, 0.09);
        border-color: rgba(16, 47, 82, 0.22);
      }

      .btn:active {
        transform: translateY(0);
      }

      .btn.auto {
        grid-column: 1 / -1;
        min-height: 74px;
        background: var(--blue);
        color: white;
        border-color: var(--blue);
        font-size: 18px;
      }

      .btn.red {
        color: var(--red);
      }

      .btn.yellow {
        color: #8b6500;
      }

      .btn.green {
        color: var(--green);
      }

      .btn.off {
        color: var(--black);
      }

      .btn.small {
        min-height: 44px;
        border-radius: 15px;
        font-size: 13px;
        padding: 10px 12px;
      }

      .btn.danger {
        background: var(--red);
        color: white;
        border-color: var(--red);
      }

      .btn.dark {
        background: var(--black);
        color: white;
        border-color: var(--black);
      }

      .indicator {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: currentColor;
      }

      .timing-card,
      .advanced {
        border: 1px solid var(--line);
        border-radius: 26px;
        background: rgba(255, 255, 255, 0.58);
        padding: 16px;
      }

      .timing-card h3,
      .advanced h3 {
        margin: 0 0 12px;
        font-size: 15px;
        letter-spacing: -0.03em;
      }

      .time-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
      }

      label {
        display: block;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.09em;
        color: var(--muted);
        font-weight: 900;
        margin-bottom: 6px;
      }

      input {
        width: 100%;
        border: 1px solid var(--line);
        background: var(--panel-solid);
        color: var(--text);
        border-radius: 14px;
        padding: 12px;
        outline: none;
      }

      input:focus {
        border-color: rgba(16, 47, 82, 0.35);
        box-shadow: 0 0 0 4px rgba(16, 47, 82, 0.08);
      }

      .preset-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 7px;
        margin-top: 10px;
      }

      .toggle {
        display: flex;
        align-items: flex-start;
        gap: 9px;
        color: var(--muted);
        font-size: 13px;
        margin-top: 12px;
        line-height: 1.35;
      }

      .toggle input {
        width: auto;
        margin-top: 2px;
      }

      .danger-zone {
        display: grid;
        gap: 8px;
      }

      .hold {
        position: relative;
        overflow: hidden;
      }

      .hold::after {
        content: "";
        position: absolute;
        inset: auto 0 0;
        height: 5px;
        width: var(--hold-progress, 0%);
        background: rgba(255, 255, 255, 0.72);
        transition: width 0.04s linear;
      }

      details {
        border: 1px solid var(--line);
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.5);
        overflow: hidden;
      }

      summary {
        cursor: pointer;
        padding: 15px;
        font-weight: 900;
        letter-spacing: -0.03em;
      }

      .advanced-content {
        padding: 0 15px 15px;
        display: grid;
        gap: 10px;
      }

      .advanced-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 8px;
      }

      pre {
        margin: 0;
        max-height: 200px;
        overflow: auto;
        background: #101010;
        color: #f1f1f1;
        border-radius: 14px;
        padding: 14px;
        font-size: 12px;
        line-height: 1.5;
      }

      .toast {
        position: fixed;
        right: 18px;
        bottom: 18px;
        background: #101010;
        color: white;
        padding: 14px 16px;
        border-radius: 18px;
        box-shadow: var(--shadow);
        opacity: 0;
        transform: translateY(16px);
        pointer-events: none;
        transition: 0.2s ease;
        z-index: 20;
        max-width: 360px;
      }

      .toast.show {
        opacity: 1;
        transform: translateY(0);
      }

      @media (max-width: 1050px) {
        .deck {
          grid-template-columns: 1fr;
        }

        .control {
          order: -1;
        }
      }

      @media (max-width: 620px) {
        .shell {
          width: min(100% - 18px, 1440px);
          padding-top: 12px;
        }

        .topbar {
          align-items: flex-start;
          flex-direction: column;
        }

        .status-row {
          justify-content: flex-start;
        }

        .stage,
        .control {
          border-radius: 26px;
        }

        .primary-grid,
        .time-grid,
        .preset-row,
        .advanced-grid {
          grid-template-columns: 1fr;
        }

        .signal {
          width: min(250px, 76vw);
          border-radius: 42px;
          padding: 25px;
          gap: 22px;
        }

        .phase-head {
          align-items: flex-start;
          flex-direction: column;
        }
      }
    </style>
  </head>

  <body>
    <div class="shell">
      <header class="topbar">
        <a href="/" class="brand">
          <div class="mark">AG</div>
          <div>
            <strong>Traffic Control</strong>
            <small>aryadhargupta.com</small>
          </div>
        </a>

        <div class="status-row">
          <span class="chip">
            <span class="dot offline" id="onlineDot"></span>
            <strong id="backendStatus">Syncing</strong>
          </span>
          <span class="chip">Mode <strong id="topMode">—</strong></span>
          <span class="chip">Updated <strong id="updatedAgo">—</strong></span>
          <a class="chip" href="/">← Portfolio</a>
        </div>
      </header>

      <main class="deck">
        <section class="stage">
          <div class="hero">
            <p class="eyebrow">Live relay command deck</p>
            <h1 id="mainTitle">Standby</h1>
            <div class="mode-line">
              Current command: <strong id="modeText">Loading</strong>
            </div>
          </div>

          <div class="visual-zone">
            <div class="signal">
              <div class="lamp red" id="lampRed"></div>
              <div class="lamp yellow" id="lampYellow"></div>
              <div class="lamp green" id="lampGreen"></div>
            </div>
          </div>

          <div class="phase">
            <div class="phase-head">
              <div>
                <strong id="phaseName">Waiting for backend</strong>
                <span id="phaseDetail">—</span>
              </div>
              <strong id="countdown">—</strong>
            </div>
            <div class="bar">
              <div class="bar-fill" id="barFill"></div>
            </div>
            <div class="timeline" id="timeline">
              <span></span>
              <span></span>
              <span></span>
            </div>
          </div>
        </section>

        <aside class="control">
          <div class="control-title">
            <h2>Command</h2>
            <p>Direct controls. No clutter. Every button sends a real command to the backend.</p>
          </div>

          <div class="primary-grid">
            <button class="btn auto" data-mode="auto" type="button">
              Auto Cycle
            </button>

            <button class="btn red" data-mode="red" type="button">
              <span class="indicator"></span> Red
            </button>

            <button class="btn yellow" data-mode="yellow" type="button">
              <span class="indicator"></span> Yellow
            </button>

            <button class="btn green" data-mode="green" type="button">
              <span class="indicator"></span> Green
            </button>

            <button class="btn off" data-mode="off" type="button">
              <span class="indicator"></span> Off
            </button>
          </div>

          <div class="timing-card">
            <h3>Auto Timing</h3>

            <div class="time-grid">
              <div>
                <label for="redTime">Red</label>
                <input id="redTime" type="number" min="1" max="120" value="10" />
              </div>

              <div>
                <label for="yellowTime">Yellow</label>
                <input id="yellowTime" type="number" min="1" max="120" value="5" />
              </div>

              <div>
                <label for="greenTime">Green</label>
                <input id="greenTime" type="number" min="1" max="120" value="15" />
              </div>
            </div>

            <div class="preset-row">
              <button class="btn small" data-preset="standard" type="button">Std</button>
              <button class="btn small" data-preset="fast" type="button">Fast</button>
              <button class="btn small" data-preset="longGreen" type="button">Flow</button>
              <button class="btn small" data-preset="balanced" type="button">Even</button>
            </div>

            <label class="toggle">
              <input id="timedReturn" type="checkbox" checked />
              Manual colour returns to Auto after its timer
            </label>
          </div>

          <div class="danger-zone">
            <button class="btn danger hold" id="emergencyOff" type="button">
              Hold to Kill All
            </button>
            <button class="btn dark" id="demoButton" type="button">
              Demo Sweep
            </button>
          </div>

          <details>
            <summary>Advanced</summary>

            <div class="advanced-content">
              <div>
                <label for="controlPin">Control PIN</label>
                <input id="controlPin" type="password" placeholder="Only if enabled in Worker" />
              </div>

              <div class="advanced-grid">
                <button class="btn small" id="refreshButton" type="button">Refresh</button>
                <button class="btn small" id="copyStateButton" type="button">Copy State</button>
              </div>

              <pre id="rawState">Waiting for state...</pre>
            </div>
          </details>
        </aside>
      </main>
    </div>

    <div class="toast" id="toast"></div>

    <script is:inline>
      const API_BASE = "https://traffic-light-api.gunshots2005.workers.dev";

      const $ = (id) => document.getElementById(id);

      const el = {
        onlineDot: $("onlineDot"),
        backendStatus: $("backendStatus"),
        topMode: $("topMode"),
        updatedAgo: $("updatedAgo"),
        mainTitle: $("mainTitle"),
        modeText: $("modeText"),
        lampRed: $("lampRed"),
        lampYellow: $("lampYellow"),
        lampGreen: $("lampGreen"),
        phaseName: $("phaseName"),
        phaseDetail: $("phaseDetail"),
        countdown: $("countdown"),
        barFill: $("barFill"),
        timeline: $("timeline"),
        redTime: $("redTime"),
        yellowTime: $("yellowTime"),
        greenTime: $("greenTime"),
        timedReturn: $("timedReturn"),
        emergencyOff: $("emergencyOff"),
        demoButton: $("demoButton"),
        controlPin: $("controlPin"),
        refreshButton: $("refreshButton"),
        copyStateButton: $("copyStateButton"),
        rawState: $("rawState"),
        toast: $("toast"),
      };

      let state = {
        mode: "auto",
        red: 10,
        yellow: 5,
        green: 15,
        startupCheckMs: 1500,
        updatedAt: null,
        revision: 0,
        source: "initial",
      };

      let backendOnline = false;
      let returnTimer = null;
      let demoTimer = null;
      let holdTimer = null;
      let holdProgressTimer = null;

      function toast(message) {
        el.toast.textContent = message;
        el.toast.classList.add("show");

        clearTimeout(el.toast._timer);
        el.toast._timer = setTimeout(() => {
          el.toast.classList.remove("show");
        }, 2200);
      }

      function modeLabel(mode) {
        const m = String(mode || "").toLowerCase();

        if (m === "auto") return "Auto Cycle";
        if (m === "red") return "Red Hold";
        if (m === "yellow") return "Yellow Hold";
        if (m === "green") return "Green Hold";
        if (m === "off") return "All Off";

        return "Unknown";
      }

      function titleFor(mode) {
        const m = String(mode || "").toLowerCase();

        if (m === "auto") return "Auto";
        if (m === "red") return "Red";
        if (m === "yellow") return "Yellow";
        if (m === "green") return "Green";
        if (m === "off") return "Killed";

        return "Standby";
      }

      function timeAgo(iso) {
        if (!iso) return "never";

        const diff = Math.max(0, Date.now() - Date.parse(iso));
        const s = Math.floor(diff / 1000);

        if (s < 5) return "now";
        if (s < 60) return `${s}s ago`;

        const m = Math.floor(s / 60);
        if (m < 60) return `${m}m ago`;

        return `${Math.floor(m / 60)}h ago`;
      }

      function numberFrom(input, fallback) {
        const n = Number(input.value);

        if (!Number.isFinite(n)) return fallback;

        return Math.min(Math.max(Math.round(n), 1), 120);
      }

      function timings() {
        return {
          red: numberFrom(el.redTime, state.red || 10),
          yellow: numberFrom(el.yellowTime, state.yellow || 5),
          green: numberFrom(el.greenTime, state.green || 15),
        };
      }

      function savePin() {
        localStorage.setItem("traffic-control-pin", el.controlPin.value || "");
      }

      function loadPin() {
        el.controlPin.value = localStorage.getItem("traffic-control-pin") || "";
      }

      function setBackendStatus(online) {
        backendOnline = online;

        el.onlineDot.classList.toggle("online", online);
        el.onlineDot.classList.toggle("offline", !online);
        el.backendStatus.textContent = online ? "Online" : "Offline";
      }

      function getAutoPhase() {
        const startup = state.startupCheckMs || 1500;
        const redMs = (state.red || 10) * 1000;
        const yellowMs = (state.yellow || 5) * 1000;
        const greenMs = (state.green || 15) * 1000;

        const total = startup + redMs + yellowMs + greenMs;
        const start = state.updatedAt ? Date.parse(state.updatedAt) : Date.now();

        let elapsed = (Date.now() - start) % total;
        if (elapsed < 0) elapsed = 0;

        if (elapsed < startup) {
          return {
            name: "Startup Check",
            detail: "Hardware lights all ON briefly",
            color: "all",
            elapsed,
            duration: startup,
          };
        }

        elapsed -= startup;

        if (elapsed < redMs) {
          return {
            name: "Red Phase",
            detail: "Auto stop phase",
            color: "red",
            elapsed,
            duration: redMs,
          };
        }

        elapsed -= redMs;

        if (elapsed < yellowMs) {
          return {
            name: "Yellow Phase",
            detail: "Auto warning phase",
            color: "yellow",
            elapsed,
            duration: yellowMs,
          };
        }

        elapsed -= yellowMs;

        return {
          name: "Green Phase",
          detail: "Auto flow phase",
          color: "green",
          elapsed,
          duration: greenMs,
        };
      }

      function setLampVisual(mode) {
        const m = String(mode || "off").toLowerCase();

        el.lampRed.classList.remove("on");
        el.lampYellow.classList.remove("on");
        el.lampGreen.classList.remove("on");

        if (m === "red") el.lampRed.classList.add("on");
        if (m === "yellow") el.lampYellow.classList.add("on");
        if (m === "green") el.lampGreen.classList.add("on");

        if (m === "auto") {
          const phase = getAutoPhase();

          if (phase.color === "all") {
            el.lampRed.classList.add("on");
            el.lampYellow.classList.add("on");
            el.lampGreen.classList.add("on");
          }

          if (phase.color === "red") el.lampRed.classList.add("on");
          if (phase.color === "yellow") el.lampYellow.classList.add("on");
          if (phase.color === "green") el.lampGreen.classList.add("on");
        }
      }

      function renderPhase() {
        if (state.mode !== "auto") {
          el.phaseName.textContent = modeLabel(state.mode);
          el.phaseDetail.textContent =
            state.mode === "off" ? "All relays commanded OFF" : "Manual command active";
          el.countdown.textContent = "hold";
          el.barFill.style.width = "100%";
          return;
        }

        const phase = getAutoPhase();
        const percent = Math.min(100, Math.max(0, (phase.elapsed / phase.duration) * 100));
        const remaining = Math.ceil((phase.duration - phase.elapsed) / 1000);

        el.phaseName.textContent = phase.name;
        el.phaseDetail.textContent = phase.detail;
        el.countdown.textContent = `${remaining}s`;
        el.barFill.style.width = `${percent}%`;
      }

      function render() {
        const label = modeLabel(state.mode);

        el.topMode.textContent = label;
        el.updatedAgo.textContent = timeAgo(state.updatedAt);
        el.mainTitle.textContent = titleFor(state.mode);
        el.modeText.textContent = label;

if (!document.activeElement || !["redTime", "yellowTime", "greenTime"].includes(document.activeElement.id)) {
  if (!el.redTime.dataset.edited) el.redTime.value = state.red ?? 10;
  if (!el.yellowTime.dataset.edited) el.yellowTime.value = state.yellow ?? 5;
  if (!el.greenTime.dataset.edited) el.greenTime.value = state.green ?? 15;

        el.timeline.style.setProperty("--red-fr", `${state.red || 10}fr`);
        el.timeline.style.setProperty("--yellow-fr", `${state.yellow || 5}fr`);
        el.timeline.style.setProperty("--green-fr", `${state.green || 15}fr`);

        setLampVisual(state.mode);
        renderPhase();
      }

      async function loadState() {
        try {
          const res = await fetch(`${API_BASE}/api/state`, {
            method: "GET",
            cache: "no-store",
          });

          const data = await res.json();
          el.rawState.textContent = JSON.stringify(data, null, 2);

          if (!res.ok || !data.ok) {
            throw new Error(data.error || "State request failed");
          }

          state = data.state;
          setBackendStatus(true);
          render();
        } catch (error) {
          setBackendStatus(false);
          el.rawState.textContent = String(error);
        }
      }

      async function sendCommand(mode, options = {}) {
        savePin();

        const body = {
          mode,
          ...timings(),
          source: options.source || "streamlined-command-deck",
        };

        const pin = el.controlPin.value || "";

        if (pin) {
          body.controlPin = pin;
        }

        try {
          const res = await fetch(`${API_BASE}/api/command`, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "X-Control-Pin": pin,
            },
            body: JSON.stringify(body),
          });

          const data = await res.json();
          el.rawState.textContent = JSON.stringify(data, null, 2);

          if (!res.ok || !data.ok) {
            throw new Error(data.error || "Command failed");
          }

          state = data.state;
delete el.redTime.dataset.edited;
delete el.yellowTime.dataset.edited;
delete el.greenTime.dataset.edited;
          setBackendStatus(true);
          render();

          toast(`${modeLabel(mode)} sent`);

          return data;
        } catch (error) {
          toast(error.message || "Command failed");
          throw error;
        }
      }

      function clearReturnTimer() {
        if (returnTimer) {
          clearTimeout(returnTimer);
          returnTimer = null;
        }
      }

      function scheduleReturn(mode) {
        clearReturnTimer();

        if (!el.timedReturn.checked) return;
        if (!["red", "yellow", "green"].includes(mode)) return;

        const t = timings();
        const seconds = t[mode] || 5;

        returnTimer = setTimeout(() => {
          sendCommand("auto", {
            source: "timed-return",
          });
        }, seconds * 1000);

        toast(`${modeLabel(mode)} → Auto in ${seconds}s`);
      }

      async function runDemo() {
        clearReturnTimer();

        const steps = [
          { mode: "red", wait: 3500 },
          { mode: "yellow", wait: 1800 },
          { mode: "green", wait: 3500 },
          { mode: "off", wait: 1200 },
          { mode: "auto", wait: 0 },
        ];

        let i = 0;

        const next = async () => {
          const step = steps[i];
          await sendCommand(step.mode, { source: "demo-sweep" });

          i++;

          if (i >= steps.length) {
            demoTimer = null;
            return;
          }

          demoTimer = setTimeout(next, step.wait);
        };

        if (demoTimer) {
          clearTimeout(demoTimer);
          demoTimer = null;
          toast("Demo stopped");
          return;
        }

        toast("Demo sweep started");
        next();
      }

      function applyPreset(name) {
        const presets = {
          standard: { red: 10, yellow: 5, green: 15 },
          fast: { red: 3, yellow: 1, green: 3 },
          longGreen: { red: 8, yellow: 3, green: 30 },
          balanced: { red: 12, yellow: 4, green: 12 },
        };

        const p = presets[name];
        if (!p) return;

        el.redTime.value = p.red;
        el.yellowTime.value = p.yellow;
        el.greenTime.value = p.green;

        toast("Preset loaded");
      }

      function startEmergencyHold() {
        let progress = 0;

        el.emergencyOff.style.setProperty("--hold-progress", "0%");

        holdProgressTimer = setInterval(() => {
          progress += 8;
          el.emergencyOff.style.setProperty("--hold-progress", `${Math.min(progress, 100)}%`);
        }, 50);

        holdTimer = setTimeout(() => {
          clearEmergencyHold();
          clearReturnTimer();
          if (demoTimer) clearTimeout(demoTimer);

          sendCommand("off", {
            source: "hold-to-kill",
          });
        }, 700);
      }

      function clearEmergencyHold() {
        if (holdTimer) clearTimeout(holdTimer);
        if (holdProgressTimer) clearInterval(holdProgressTimer);

        holdTimer = null;
        holdProgressTimer = null;

        el.emergencyOff.style.setProperty("--hold-progress", "0%");
      }

      function bind() {
[el.redTime, el.yellowTime, el.greenTime].forEach((input) => {
  input.addEventListener("input", () => {
    input.dataset.edited = "true";
  });
});
        document.querySelectorAll("[data-mode]").forEach((button) => {
          button.addEventListener("click", async () => {
            const mode = button.dataset.mode;
            clearReturnTimer();
            await sendCommand(mode);
            scheduleReturn(mode);
          });
        });

        document.querySelectorAll("[data-preset]").forEach((button) => {
          button.addEventListener("click", () => {
            applyPreset(button.dataset.preset);
          });
        });

        el.refreshButton.addEventListener("click", () => {
          loadState();
          toast("Refreshed");
        });

        el.copyStateButton.addEventListener("click", async () => {
          await navigator.clipboard.writeText(el.rawState.textContent);
          toast("State copied");
        });

        el.demoButton.addEventListener("click", runDemo);

        el.controlPin.addEventListener("change", savePin);

        el.emergencyOff.addEventListener("pointerdown", startEmergencyHold);
        el.emergencyOff.addEventListener("pointerup", clearEmergencyHold);
        el.emergencyOff.addEventListener("pointerleave", clearEmergencyHold);
        el.emergencyOff.addEventListener("pointercancel", clearEmergencyHold);

        window.addEventListener("keydown", (event) => {
          const tag = document.activeElement?.tagName?.toLowerCase();
          if (tag === "input" || tag === "textarea") return;

          const k = event.key.toLowerCase();

          if (k === "r") sendCommand("red");
          if (k === "y") sendCommand("yellow");
          if (k === "g") sendCommand("green");
          if (k === "o") sendCommand("off");
          if (k === "a") sendCommand("auto");
        });
      }

      function startLoops() {
        loadState();
        setInterval(loadState, 2500);

        setInterval(() => {
          renderPhase();
          setLampVisual(state.mode);
          el.updatedAgo.textContent = timeAgo(state.updatedAt);
        }, 250);
      }

      function init() {
        loadPin();
        bind();
        startLoops();
      }

      init();
    </script>
  </body>
</html>
