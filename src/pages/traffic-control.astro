---

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Traffic Control | AG Systems</title>

    <style>
      :root {
        --paper: #f3eee5;
        --surface: #fffaf0;
        --ink: #15130f;
        --body: #3b372f;
        --muted: #70675b;
        --quiet: #9b9080;
        --rule: rgba(21, 19, 15, 0.15);
        --rule-strong: rgba(21, 19, 15, 0.34);
        --black: #15130f;
        --white: #fffaf0;

        --red: #b72b25;
        --yellow: #b98512;
        --green: #168754;
        --blue: #15130f;

        --max: 1220px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top left, rgba(255, 250, 240, 0.7), transparent 34%),
          linear-gradient(180deg, var(--paper), #f6f1e8 48%, var(--paper));
        color: var(--ink);
        font-family:
          "Segoe UI", Inter, ui-sans-serif, system-ui, -apple-system,
          BlinkMacSystemFont, sans-serif;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        opacity: 0.13;
        background-image:
          linear-gradient(rgba(21, 19, 15, 0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(21, 19, 15, 0.025) 1px, transparent 1px);
        background-size: 34px 34px;
        mask-image: linear-gradient(to bottom, black, transparent 68%);
      }

      button,
      input,
      select {
        font: inherit;
      }

      button {
        cursor: pointer;
      }

      button:disabled,
      input:disabled,
      select:disabled {
        opacity: 0.42;
        cursor: not-allowed;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .shell {
        position: relative;
        z-index: 1;
        width: min(var(--max), calc(100% - 48px));
        margin: 0 auto;
        padding: 0 0 42px;
      }

      .topbar {
        min-height: 64px;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 28px;
        align-items: center;
        border-bottom: 1px solid var(--rule);
        margin-bottom: 28px;
      }

      .brand {
        display: flex;
        align-items: baseline;
        gap: 13px;
      }

      .mark {
        display: none;
      }

      .brand strong {
        font-size: 18px;
        font-weight: 760;
        letter-spacing: -0.045em;
      }

      .brand small {
        color: var(--muted);
        font-size: 13px;
        letter-spacing: -0.02em;
      }

      .status-row {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 18px;
        color: var(--muted);
        font-size: 13px;
      }

      .chip {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        color: var(--muted);
        border-bottom: 1px solid transparent;
        padding-bottom: 2px;
      }

      .chip strong {
        color: var(--ink);
        font-weight: 650;
      }

      a.chip:hover {
        color: var(--ink);
        border-color: var(--ink);
      }

      .dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--quiet);
      }

      .dot.online {
        background: var(--green);
      }

      .dot.offline {
        background: var(--red);
      }

      .deck {
        display: grid;
        grid-template-columns: minmax(0, 1.08fr) 390px;
        gap: 36px;
        align-items: start;
      }

      .stage {
        min-height: calc(100vh - 154px);
        display: grid;
        grid-template-rows: auto 1fr auto;
        padding: 0 0 28px;
        border-bottom: 1px solid var(--rule);
      }

      .hero {
        padding: 18px 0 24px;
        border-bottom: 1px solid var(--rule);
      }

      .eyebrow {
        margin: 0 0 14px;
        color: var(--muted);
        font-size: 12px;
        letter-spacing: 0.07em;
        text-transform: uppercase;
      }

      .eyebrow::before {
        content: "";
        display: inline-block;
        width: 28px;
        height: 1px;
        margin-right: 10px;
        vertical-align: middle;
        background: var(--rule-strong);
      }

      h1 {
        margin: 0;
        font-family: Georgia, "Times New Roman", ui-serif, serif;
        font-size: clamp(56px, 8vw, 116px);
        line-height: 0.86;
        letter-spacing: -0.075em;
        font-weight: 520;
      }

      .mode-line {
        max-width: 680px;
        margin-top: 16px;
        color: var(--muted);
        font-size: 17px;
        line-height: 1.55;
        letter-spacing: -0.015em;
      }

      .mode-line strong {
        color: var(--ink);
        font-weight: 650;
      }

      .visual-zone {
        display: grid;
        place-items: center;
        padding: 34px 0;
      }

      .signal {
        width: min(300px, 72vw);
        padding: 22px;
        display: grid;
        gap: 18px;
        background: var(--black);
        border: 1px solid rgba(255, 250, 240, 0.18);
      }

      .lamp {
        aspect-ratio: 1;
        border-radius: 50%;
        opacity: 0.14;
        transition:
          opacity 0.18s ease,
          transform 0.18s ease,
          box-shadow 0.18s ease;
        position: relative;
        border: 1px solid rgba(255, 250, 240, 0.12);
        background: #403a32;
      }

      .lamp::before {
        content: "";
        position: absolute;
        inset: 11%;
        border-radius: inherit;
        border: 1px solid rgba(255, 250, 240, 0.12);
      }

      .lamp::after {
        content: "";
        position: absolute;
        inset: 26%;
        border-radius: inherit;
        background: rgba(255, 250, 240, 0.2);
        filter: blur(5px);
        opacity: 0.18;
      }

      .lamp.red {
        background: var(--red);
      }

      .lamp.yellow {
        background: var(--yellow);
      }

      .lamp.green {
        background: var(--green);
      }

      .lamp.on {
        opacity: 1;
        transform: scale(1.018);
      }

      .lamp.red.on {
        box-shadow:
          0 0 0 8px rgba(183, 43, 37, 0.1),
          0 22px 60px rgba(183, 43, 37, 0.26);
      }

      .lamp.yellow.on {
        box-shadow:
          0 0 0 8px rgba(185, 133, 18, 0.12),
          0 22px 60px rgba(185, 133, 18, 0.26);
      }

      .lamp.green.on {
        box-shadow:
          0 0 0 8px rgba(22, 135, 84, 0.12),
          0 22px 60px rgba(22, 135, 84, 0.26);
      }

      .phase {
        border-top: 1px solid var(--rule-strong);
        padding-top: 20px;
      }

      .phase-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: 14px;
      }

      .phase-head strong {
        display: block;
        font-size: 22px;
        line-height: 1.1;
        letter-spacing: -0.045em;
        font-weight: 690;
      }

      .phase-head span {
        display: block;
        margin-top: 4px;
        color: var(--muted);
        font-size: 14px;
      }

      #countdown {
        color: var(--ink);
        font-variant-numeric: tabular-nums;
      }

      .bar {
        height: 7px;
        background: rgba(21, 19, 15, 0.08);
        overflow: hidden;
      }

      .bar-fill {
        height: 100%;
        width: 0%;
        background: var(--black);
        transition: width 0.2s linear;
      }

      .timeline {
        display: grid;
        grid-template-columns: var(--green-fr, 15fr) var(--yellow-fr, 5fr) var(--red-fr, 10fr);
        gap: 3px;
        margin-top: 9px;
      }

      .timeline span {
        height: 6px;
      }

      .timeline span:nth-child(1) {
        background: var(--green);
      }

      .timeline span:nth-child(2) {
        background: var(--yellow);
      }

      .timeline span:nth-child(3) {
        background: var(--red);
      }

      .control {
        position: sticky;
        top: 18px;
        display: grid;
        align-content: start;
        gap: 14px;
        padding-left: 28px;
        border-left: 1px solid var(--rule);
      }

      .control-title {
        padding-bottom: 8px;
        border-bottom: 1px solid var(--rule-strong);
      }

      .control-title h2 {
        margin: 0;
        font-family: Georgia, "Times New Roman", ui-serif, serif;
        font-size: 34px;
        line-height: 1;
        letter-spacing: -0.055em;
        font-weight: 520;
      }

      .control-title p {
        margin: 8px 0 0;
        color: var(--muted);
        line-height: 1.5;
        font-size: 14px;
      }

      .lock {
        display: grid;
        grid-template-columns: 1fr 92px;
        gap: 8px;
      }

      .primary-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
      }

      .btn {
        min-height: 46px;
        border: 1px solid var(--rule);
        background: transparent;
        color: var(--ink);
        padding: 11px 12px;
        font-weight: 650;
        letter-spacing: -0.015em;
        transition:
          background 0.16s ease,
          color 0.16s ease,
          border-color 0.16s ease,
          opacity 0.16s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
      }

      .btn:hover:not(:disabled) {
        background: var(--black);
        color: var(--white);
        border-color: var(--black);
      }

      .btn.auto {
        grid-column: 1 / -1;
        min-height: 54px;
        background: var(--black);
        color: var(--white);
        border-color: var(--black);
        font-size: 15px;
      }

      .btn.auto:hover:not(:disabled) {
        opacity: 0.84;
      }

      .btn.red {
        color: var(--red);
      }

      .btn.yellow {
        color: var(--yellow);
      }

      .btn.green {
        color: var(--green);
      }

      .btn.red:hover:not(:disabled),
      .btn.yellow:hover:not(:disabled),
      .btn.green:hover:not(:disabled),
      .btn.off:hover:not(:disabled) {
        color: var(--white);
      }

      .btn.small {
        min-height: 38px;
        font-size: 13px;
        padding: 9px 10px;
      }

      .btn.danger {
        background: var(--red);
        color: var(--white);
        border-color: var(--red);
      }

      .btn.danger:hover:not(:disabled) {
        opacity: 0.84;
      }

      .indicator {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: currentColor;
      }

      .card {
        padding: 14px 0 0;
        border-top: 1px solid var(--rule);
      }

      .card h3 {
        margin: 0 0 11px;
        font-size: 15px;
        line-height: 1.2;
        letter-spacing: -0.03em;
        font-weight: 690;
      }

      .time-grid,
      .two-grid,
      .colour-row {
        display: grid;
        gap: 8px;
      }

      .time-grid {
        grid-template-columns: repeat(3, 1fr);
      }

      .two-grid {
        grid-template-columns: 1fr 1fr;
      }

      .colour-row {
        grid-template-columns: repeat(3, 1fr);
        margin-bottom: 10px;
      }

      label {
        display: block;
        margin-bottom: 5px;
        color: var(--muted);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.075em;
      }

      input,
      select {
        width: 100%;
        border: 1px solid var(--rule);
        background: rgba(255, 250, 240, 0.56);
        color: var(--ink);
        padding: 10px 10px;
        outline: none;
        border-radius: 0;
      }

      input:focus,
      select:focus {
        border-color: var(--rule-strong);
        background: var(--surface);
      }

      .preset-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 7px;
        margin-top: 9px;
      }

      .timer-ring {
        --progress: 0deg;
        width: 138px;
        height: 138px;
        border-radius: 50%;
        margin: 2px auto 14px;
        background:
          radial-gradient(circle at center, var(--paper) 0 57%, transparent 58%),
          conic-gradient(var(--black) var(--progress), rgba(21, 19, 15, 0.08) 0);
        display: grid;
        place-items: center;
      }

      .timer-ring strong {
        font-size: 23px;
        letter-spacing: -0.05em;
        font-variant-numeric: tabular-nums;
      }

      .selectable.active {
        border-color: var(--black);
        background: var(--black);
        color: var(--white);
      }

      .hold {
        position: relative;
        overflow: hidden;
      }

      .hold::after {
        content: "";
        position: absolute;
        inset: auto 0 0;
        height: 4px;
        width: var(--hold-progress, 0%);
        background: rgba(255, 250, 240, 0.72);
        transition: width 0.04s linear;
      }

      details {
        border-top: 1px solid var(--rule);
      }

      summary {
        cursor: pointer;
        padding: 14px 0;
        font-weight: 690;
        letter-spacing: -0.03em;
      }

      .advanced-content {
        padding: 0 0 4px;
        display: grid;
        gap: 10px;
      }

      pre {
        margin: 0;
        max-height: 190px;
        overflow: auto;
        background: var(--black);
        color: var(--white);
        padding: 13px;
        font-size: 12px;
        line-height: 1.5;
      }

      .toast {
        position: fixed;
        right: 18px;
        bottom: 18px;
        z-index: 80;
        max-width: 360px;
        background: var(--black);
        color: var(--white);
        padding: 13px 15px;
        opacity: 0;
        transform: translateY(12px);
        pointer-events: none;
        transition: 0.2s ease;
      }

      .toast.show {
        opacity: 1;
        transform: translateY(0);
      }

      @media (max-width: 1050px) {
        .deck {
          grid-template-columns: 1fr;
        }

        .control {
          position: static;
          order: -1;
          padding-left: 0;
          padding-bottom: 24px;
          border-left: 0;
          border-bottom: 1px solid var(--rule);
        }

        .stage {
          min-height: auto;
        }
      }

      @media (max-width: 720px) {
        .shell {
          width: min(100% - 28px, var(--max));
          padding-bottom: 30px;
        }

        .topbar {
          min-height: auto;
          grid-template-columns: 1fr;
          gap: 12px;
          padding: 15px 0;
          margin-bottom: 18px;
        }

        .brand {
          flex-direction: column;
          align-items: flex-start;
          gap: 3px;
        }

        .brand small {
          font-size: 12px;
        }

        .status-row {
          justify-content: flex-start;
          gap: 10px 16px;
          flex-wrap: wrap;
        }

        .hero {
          padding: 22px 0 20px;
        }

        h1 {
          font-size: clamp(48px, 17vw, 76px);
        }

        .mode-line {
          font-size: 15px;
        }

        .visual-zone {
          padding: 24px 0;
        }

        .signal {
          width: min(238px, 76vw);
          padding: 18px;
          gap: 15px;
        }

        .phase-head {
          align-items: flex-start;
          flex-direction: column;
          gap: 8px;
        }

        .primary-grid,
        .time-grid,
        .preset-row,
        .two-grid,
        .colour-row,
        .lock {
          grid-template-columns: 1fr;
        }

        .timer-ring {
          width: 126px;
          height: 126px;
        }
      }
    </style>
  </head>

  <body>
    <div class="shell">
      <header class="topbar">
        <a href="/" class="brand">
          <div class="mark">AG</div>
          <div>
            <strong>Traffic Control</strong>
            <small>AG Systems / connected hardware control</small>
          </div>
        </a>

        <div class="status-row">
          <span class="chip">
            <span class="dot offline" id="onlineDot"></span>
            <strong id="backendStatus">Syncing</strong>
          </span>
          <span class="chip">Mode <strong id="topMode">—</strong></span>
          <span class="chip">Access <strong id="lockStatus">Locked</strong></span>
          <span class="chip">Updated <strong id="updatedAgo">—</strong></span>
          <a class="chip" href="/">← AG Systems</a>
        </div>
      </header>

      <main class="deck">
        <section class="stage">
          <div class="hero">
            <p class="eyebrow">Live relay command system</p>
            <h1 id="mainTitle">Standby</h1>
            <div class="mode-line">
              Current command: <strong id="modeText">Loading</strong>
            </div>
          </div>

          <div class="visual-zone">
            <div class="signal">
              <div class="lamp red" id="lampRed"></div>
              <div class="lamp yellow" id="lampYellow"></div>
              <div class="lamp green" id="lampGreen"></div>
            </div>
          </div>

          <div class="phase">
            <div class="phase-head">
              <div>
                <strong id="phaseName">Waiting for backend</strong>
                <span id="phaseDetail">—</span>
              </div>
              <strong id="countdown">—</strong>
            </div>
            <div class="bar">
              <div class="bar-fill" id="barFill"></div>
            </div>
            <div class="timeline" id="timeline">
              <span></span>
              <span></span>
              <span></span>
            </div>
          </div>
        </section>

        <aside class="control">
          <div class="control-title">
            <h2>Command</h2>
            <p>Public status view. Password-protected controls.</p>
          </div>

          <div class="lock">
            <input id="controlPin" type="password" placeholder="Password" />
            <button class="btn small" id="unlockButton" type="button">Unlock</button>
          </div>

          <div class="primary-grid">
            <button class="btn auto control-action" data-mode="auto" type="button">Auto Cycle</button>
            <button class="btn green control-action" data-mode="green" type="button"><span class="indicator"></span> Green</button>
            <button class="btn yellow control-action" data-mode="yellow" type="button"><span class="indicator"></span> Yellow</button>
            <button class="btn red control-action" data-mode="red" type="button"><span class="indicator"></span> Red</button>
            <button class="btn off control-action" data-mode="off" type="button"><span class="indicator"></span> Off</button>
          </div>

          <div class="card">
            <h3>Auto Timing</h3>

            <div class="time-grid">
              <div>
                <label for="greenTime">Green</label>
                <input class="control-action" id="greenTime" type="number" min="1" max="120" value="15" />
              </div>

              <div>
                <label for="yellowTime">Yellow</label>
                <input class="control-action" id="yellowTime" type="number" min="1" max="120" value="5" />
              </div>

              <div>
                <label for="redTime">Red</label>
                <input class="control-action" id="redTime" type="number" min="1" max="120" value="10" />
              </div>
            </div>

            <div class="preset-row">
              <button class="btn small control-action" data-preset="standard" type="button">Std</button>
              <button class="btn small control-action" data-preset="fast" type="button">Fast</button>
              <button class="btn small control-action" data-preset="longGreen" type="button">Flow</button>
              <button class="btn small control-action" data-preset="balanced" type="button">Even</button>
            </div>
          </div>

          <div class="card">
            <h3>Timer Alarm</h3>

            <div class="timer-ring" id="timerRing">
              <strong id="timerText">—</strong>
            </div>

            <div class="colour-row">
              <button class="btn small selectable active control-action" data-timer-color="green" type="button">Green</button>
              <button class="btn small selectable control-action" data-timer-color="yellow" type="button">Yellow</button>
              <button class="btn small selectable control-action" data-timer-color="red" type="button">Red</button>
            </div>

            <div class="two-grid">
              <div>
                <label for="timerHours">Hours</label>
                <input class="control-action" id="timerHours" type="number" min="0" max="2" value="0" />
              </div>

              <div>
                <label for="timerMinutes">Minutes</label>
                <input class="control-action" id="timerMinutes" type="number" min="0" max="59" value="30" />
              </div>
            </div>

            <div style="height: 10px"></div>

            <div>
              <label for="timerEndMode">Finish</label>
              <select class="control-action" id="timerEndMode">
                <option value="yellow">Yellow</option>
                <option value="green">Green</option>
                <option value="red">Red</option>
                <option value="off">Off</option>
                <option value="auto">Auto</option>
              </select>
            </div>

            <div style="height: 10px"></div>

            <button class="btn auto control-action" id="startTimerButton" type="button">Start Timer</button>
          </div>

          <button class="btn danger hold control-action" id="emergencyOff" type="button">Hold to Kill All</button>

          <details>
            <summary>Advanced</summary>

            <div class="advanced-content">
              <div class="two-grid">
                <button class="btn small" id="refreshButton" type="button">Refresh</button>
                <button class="btn small" id="copyStateButton" type="button">Copy State</button>
              </div>

              <pre id="rawState">Waiting for state...</pre>
            </div>
          </details>
        </aside>
      </main>
    </div>

    <div class="toast" id="toast"></div>

    <script is:inline>
      const API_BASE = "https://traffic-light-api.gunshots2005.workers.dev";

      const $ = (id) => document.getElementById(id);

      const el = {
        onlineDot: $("onlineDot"),
        backendStatus: $("backendStatus"),
        topMode: $("topMode"),
        lockStatus: $("lockStatus"),
        updatedAgo: $("updatedAgo"),
        mainTitle: $("mainTitle"),
        modeText: $("modeText"),

        lampRed: $("lampRed"),
        lampYellow: $("lampYellow"),
        lampGreen: $("lampGreen"),

        phaseName: $("phaseName"),
        phaseDetail: $("phaseDetail"),
        countdown: $("countdown"),
        barFill: $("barFill"),
        timeline: $("timeline"),

        redTime: $("redTime"),
        yellowTime: $("yellowTime"),
        greenTime: $("greenTime"),

        timerRing: $("timerRing"),
        timerText: $("timerText"),
        timerHours: $("timerHours"),
        timerMinutes: $("timerMinutes"),
        timerEndMode: $("timerEndMode"),
        startTimerButton: $("startTimerButton"),

        emergencyOff: $("emergencyOff"),
        controlPin: $("controlPin"),
        unlockButton: $("unlockButton"),
        refreshButton: $("refreshButton"),
        copyStateButton: $("copyStateButton"),
        rawState: $("rawState"),
        toast: $("toast"),
      };

      let unlocked = false;
      let selectedTimerColor = "green";
      let timerColorDirty = false;

      let state = {
        mode: "auto",
        red: 10,
        yellow: 5,
        green: 15,
        startupCheckMs: 1500,
        timerColor: "green",
        timerSeconds: 1800,
        timerEndMode: "yellow",
        updatedAt: null,
        revision: 0,
        source: "initial",
      };

      let holdTimer = null;
      let holdProgressTimer = null;

      function toast(message) {
        el.toast.textContent = message;
        el.toast.classList.add("show");

        clearTimeout(el.toast._timer);
        el.toast._timer = setTimeout(() => {
          el.toast.classList.remove("show");
        }, 2200);
      }

      function setUnlocked(value) {
        unlocked = value;

        el.lockStatus.textContent = unlocked ? "Unlocked" : "Locked";
        el.unlockButton.textContent = unlocked ? "Lock" : "Unlock";

        document.querySelectorAll(".control-action").forEach((item) => {
          item.disabled = !unlocked;
        });

        if (!unlocked) {
          el.controlPin.value = "";
        }
      }

      function modeLabel(mode) {
        const m = String(mode || "").toLowerCase();

        if (m === "auto") return "Auto Cycle";
        if (m === "timer") return "Timer";
        if (m === "green") return "Green Hold";
        if (m === "yellow") return "Yellow Hold";
        if (m === "red") return "Red Hold";
        if (m === "off") return "All Off";

        return "Unknown";
      }

      function titleFor(mode) {
        const m = String(mode || "").toLowerCase();

        if (m === "auto") return "Auto";
        if (m === "timer") return "Timer";
        if (m === "green") return "Green";
        if (m === "yellow") return "Yellow";
        if (m === "red") return "Red";
        if (m === "off") return "Killed";

        return "Standby";
      }

      function timeAgo(iso) {
        if (!iso) return "never";

        const diff = Math.max(0, Date.now() - Date.parse(iso));
        const s = Math.floor(diff / 1000);

        if (s < 5) return "now";
        if (s < 60) return `${s}s ago`;

        const m = Math.floor(s / 60);
        if (m < 60) return `${m}m ago`;

        return `${Math.floor(m / 60)}h ago`;
      }

      function numberFrom(input, fallback, min, max) {
        const n = Number(input.value);

        if (!Number.isFinite(n)) return fallback;

        return Math.min(Math.max(Math.round(n), min), max);
      }

      function autoTimings() {
        return {
          red: numberFrom(el.redTime, state.red || 10, 1, 120),
          yellow: numberFrom(el.yellowTime, state.yellow || 5, 1, 120),
          green: numberFrom(el.greenTime, state.green || 15, 1, 120),
        };
      }

      function timerSeconds() {
        const hours = numberFrom(el.timerHours, 0, 0, 2);
        const minutes = numberFrom(el.timerMinutes, 30, 0, 59);

        let total = hours * 3600 + minutes * 60;

        if (total < 1) total = 60;
        if (total > 7200) total = 7200;

        return total;
      }

      function formatDuration(seconds) {
        seconds = Math.max(0, Math.round(seconds));

        const h = Math.floor(seconds / 3600);
        const m = Math.floor((seconds % 3600) / 60);
        const s = seconds % 60;

        if (h > 0) {
          return `${h}:${String(m).padStart(2, "0")}:${String(s).padStart(2, "0")}`;
        }

        return `${m}:${String(s).padStart(2, "0")}`;
      }

      function setBackendStatus(online) {
        el.onlineDot.classList.toggle("online", online);
        el.onlineDot.classList.toggle("offline", !online);
        el.backendStatus.textContent = online ? "Online" : "Offline";
      }

      function getAutoPhase() {
        const startup = state.startupCheckMs || 1500;
        const greenMs = (state.green || 15) * 1000;
        const yellowMs = (state.yellow || 5) * 1000;
        const redMs = (state.red || 10) * 1000;

        const total = startup + greenMs + yellowMs + redMs;
        const start = state.updatedAt ? Date.parse(state.updatedAt) : Date.now();

        let elapsed = (Date.now() - start) % total;
        if (elapsed < 0) elapsed = 0;

        if (elapsed < startup) {
          return {
            name: "Startup Check",
            detail: "All lights active briefly",
            color: "all",
            elapsed,
            duration: startup,
          };
        }

        elapsed -= startup;

        if (elapsed < greenMs) {
          return {
            name: "Green Phase",
            detail: "Auto flow phase",
            color: "green",
            elapsed,
            duration: greenMs,
          };
        }

        elapsed -= greenMs;

        if (elapsed < yellowMs) {
          return {
            name: "Yellow Phase",
            detail: "Auto warning phase",
            color: "yellow",
            elapsed,
            duration: yellowMs,
          };
        }

        elapsed -= yellowMs;

        return {
          name: "Red Phase",
          detail: "Auto stop phase",
          color: "red",
          elapsed,
          duration: redMs,
        };
      }

      function getTimerPhase() {
        const durationMs = (state.timerSeconds || 1800) * 1000;
        const start = state.updatedAt ? Date.parse(state.updatedAt) : Date.now();

        const elapsed = Math.max(0, Date.now() - start);
        const complete = elapsed >= durationMs;

        return {
          complete,
          color: complete ? state.timerEndMode : state.timerColor,
          elapsed: Math.min(elapsed, durationMs),
          duration: durationMs,
          remaining: Math.max(0, durationMs - elapsed),
        };
      }

      function lightColor(color) {
        el.lampRed.classList.toggle("on", color === "red" || color === "all");
        el.lampYellow.classList.toggle("on", color === "yellow" || color === "all");
        el.lampGreen.classList.toggle("on", color === "green" || color === "all");
      }

      function setLampVisual(mode) {
        const m = String(mode || "off").toLowerCase();

        if (m === "green" || m === "yellow" || m === "red") {
          lightColor(m);
          return;
        }

        if (m === "auto") {
          lightColor(getAutoPhase().color);
          return;
        }

        if (m === "timer") {
          lightColor(getTimerPhase().color);
          return;
        }

        lightColor("off");
      }

      function renderPhase() {
        if (state.mode === "auto") {
          const phase = getAutoPhase();
          const percent = Math.min(100, Math.max(0, (phase.elapsed / phase.duration) * 100));
          const remaining = Math.ceil((phase.duration - phase.elapsed) / 1000);

          el.phaseName.textContent = phase.name;
          el.phaseDetail.textContent = phase.detail;
          el.countdown.textContent = `${remaining}s`;
          el.barFill.style.width = `${percent}%`;

          el.timerText.textContent = "—";
          el.timerRing.style.setProperty("--progress", "0deg");
          return;
        }

        if (state.mode === "timer") {
          const timer = getTimerPhase();
          const percent = Math.min(100, Math.max(0, (timer.elapsed / timer.duration) * 100));
          const degrees = percent * 3.6;

          el.phaseName.textContent = timer.complete ? "Timer Complete" : "Timer Running";
          el.phaseDetail.textContent = timer.complete
            ? `Finish state: ${modeLabel(state.timerEndMode)}`
            : `${modeLabel(state.timerColor)} for ${formatDuration(state.timerSeconds)}`;

          el.countdown.textContent = timer.complete
            ? "done"
            : formatDuration(Math.ceil(timer.remaining / 1000));

          el.barFill.style.width = `${percent}%`;

          el.timerText.textContent = timer.complete
            ? "Done"
            : formatDuration(Math.ceil(timer.remaining / 1000));

          el.timerRing.style.setProperty("--progress", `${degrees}deg`);
          return;
        }

        el.phaseName.textContent = modeLabel(state.mode);
        el.phaseDetail.textContent =
          state.mode === "off" ? "All relays commanded off" : "Manual command active";
        el.countdown.textContent = "hold";
        el.barFill.style.width = "100%";
        el.timerText.textContent = "—";
        el.timerRing.style.setProperty("--progress", "0deg");
      }

      function isFocused(...ids) {
        return ids.includes(document.activeElement?.id);
      }

      function syncInputsFromState() {
        if (!isFocused("greenTime") && !el.greenTime.dataset.dirty) {
          el.greenTime.value = state.green ?? 15;
        }

        if (!isFocused("yellowTime") && !el.yellowTime.dataset.dirty) {
          el.yellowTime.value = state.yellow ?? 5;
        }

        if (!isFocused("redTime") && !el.redTime.dataset.dirty) {
          el.redTime.value = state.red ?? 10;
        }

        if (
          !isFocused("timerHours", "timerMinutes") &&
          !el.timerHours.dataset.dirty &&
          !el.timerMinutes.dataset.dirty
        ) {
          const seconds = state.timerSeconds ?? 1800;
          el.timerHours.value = Math.floor(seconds / 3600);
          el.timerMinutes.value = Math.floor((seconds % 3600) / 60);
        }

        if (!isFocused("timerEndMode") && !el.timerEndMode.dataset.dirty) {
          el.timerEndMode.value = state.timerEndMode ?? "yellow";
        }

        if (!timerColorDirty) {
          selectedTimerColor = state.timerColor || selectedTimerColor;
        }

        renderTimerColorButtons();
      }

      function renderTimerColorButtons() {
        document.querySelectorAll("[data-timer-color]").forEach((button) => {
          button.classList.toggle("active", button.dataset.timerColor === selectedTimerColor);
        });
      }

      function clearDirtyInputs() {
        delete el.redTime.dataset.dirty;
        delete el.yellowTime.dataset.dirty;
        delete el.greenTime.dataset.dirty;
        delete el.timerHours.dataset.dirty;
        delete el.timerMinutes.dataset.dirty;
        delete el.timerEndMode.dataset.dirty;
        timerColorDirty = false;
      }

      function render() {
        const label = modeLabel(state.mode);

        el.topMode.textContent = label;
        el.updatedAgo.textContent = timeAgo(state.updatedAt);
        el.mainTitle.textContent = titleFor(state.mode);
        el.modeText.textContent = label;

        syncInputsFromState();

        el.timeline.style.setProperty("--green-fr", `${state.green || 15}fr`);
        el.timeline.style.setProperty("--yellow-fr", `${state.yellow || 5}fr`);
        el.timeline.style.setProperty("--red-fr", `${state.red || 10}fr`);

        setLampVisual(state.mode);
        renderPhase();
      }

      async function verifyPassword() {
        const pin = el.controlPin.value || "";

        try {
          const res = await fetch(`${API_BASE}/api/verify`, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "X-Control-Pin": pin,
            },
            body: JSON.stringify({ controlPin: pin }),
          });

          const data = await res.json();

          if (!res.ok || !data.ok) {
            throw new Error(data.error || "Access denied");
          }

          setUnlocked(true);
          toast("Unlocked");
        } catch (error) {
          setUnlocked(false);
          toast(error.message || "Access denied");
        }
      }

      async function loadState() {
        try {
          const res = await fetch(`${API_BASE}/api/state`, {
            method: "GET",
            cache: "no-store",
          });

          const data = await res.json();
          el.rawState.textContent = JSON.stringify(data, null, 2);

          if (!res.ok || !data.ok) {
            throw new Error(data.error || "State request failed");
          }

          state = data.state;
          setBackendStatus(true);
          render();
        } catch (error) {
          setBackendStatus(false);
          el.rawState.textContent = String(error);
        }
      }

      async function sendCommand(mode, extra = {}) {
        if (!unlocked) {
          toast("Locked");
          return;
        }

        const pin = el.controlPin.value || "";

        const body = {
          mode,
          ...autoTimings(),
          timerColor: selectedTimerColor,
          timerSeconds: timerSeconds(),
          timerEndMode: el.timerEndMode.value,
          source: extra.source || "control-centre",
          controlPin: pin,
        };

        try {
          const res = await fetch(`${API_BASE}/api/command`, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "X-Control-Pin": pin,
            },
            body: JSON.stringify(body),
          });

          const data = await res.json();
          el.rawState.textContent = JSON.stringify(data, null, 2);

          if (!res.ok || !data.ok) {
            throw new Error(data.error || "Command failed");
          }

          state = data.state;
          clearDirtyInputs();
          setBackendStatus(true);
          render();
          toast(`${modeLabel(mode)} sent`);
        } catch (error) {
          toast(error.message || "Command failed");
        }
      }

      function applyPreset(name) {
        const presets = {
          standard: { green: 15, yellow: 5, red: 10 },
          fast: { green: 3, yellow: 1, red: 3 },
          longGreen: { green: 30, yellow: 3, red: 8 },
          balanced: { green: 12, yellow: 4, red: 12 },
        };

        const p = presets[name];
        if (!p) return;

        el.greenTime.value = p.green;
        el.yellowTime.value = p.yellow;
        el.redTime.value = p.red;

        el.greenTime.dataset.dirty = "true";
        el.yellowTime.dataset.dirty = "true";
        el.redTime.dataset.dirty = "true";

        toast("Preset loaded");
      }

      function startEmergencyHold() {
        if (!unlocked) {
          toast("Locked");
          return;
        }

        let progress = 0;
        el.emergencyOff.style.setProperty("--hold-progress", "0%");

        holdProgressTimer = setInterval(() => {
          progress += 8;
          el.emergencyOff.style.setProperty("--hold-progress", `${Math.min(progress, 100)}%`);
        }, 50);

        holdTimer = setTimeout(() => {
          clearEmergencyHold();
          sendCommand("off", { source: "hold-to-kill" });
        }, 700);
      }

      function clearEmergencyHold() {
        if (holdTimer) clearTimeout(holdTimer);
        if (holdProgressTimer) clearInterval(holdProgressTimer);

        holdTimer = null;
        holdProgressTimer = null;

        el.emergencyOff.style.setProperty("--hold-progress", "0%");
      }

      function bind() {
        el.unlockButton.addEventListener("click", () => {
          if (unlocked) {
            setUnlocked(false);
          } else {
            verifyPassword();
          }
        });

        el.controlPin.addEventListener("keydown", (event) => {
          if (event.key === "Enter") verifyPassword();
        });

        document.querySelectorAll("[data-mode]").forEach((button) => {
          button.addEventListener("click", () => sendCommand(button.dataset.mode));
        });

        document.querySelectorAll("[data-preset]").forEach((button) => {
          button.addEventListener("click", () => applyPreset(button.dataset.preset));
        });

        document.querySelectorAll("[data-timer-color]").forEach((button) => {
          button.addEventListener("click", () => {
            selectedTimerColor = button.dataset.timerColor;
            timerColorDirty = true;
            renderTimerColorButtons();
          });
        });

        [
          el.greenTime,
          el.yellowTime,
          el.redTime,
          el.timerHours,
          el.timerMinutes,
          el.timerEndMode,
        ].forEach((input) => {
          input.addEventListener("input", () => {
            input.dataset.dirty = "true";
          });
        });

        el.startTimerButton.addEventListener("click", () => {
          sendCommand("timer", { source: "timer-alarm" });
        });

        el.refreshButton.addEventListener("click", () => {
          loadState();
          toast("Refreshed");
        });

        el.copyStateButton.addEventListener("click", async () => {
          await navigator.clipboard.writeText(el.rawState.textContent);
          toast("State copied");
        });

        el.emergencyOff.addEventListener("pointerdown", startEmergencyHold);
        el.emergencyOff.addEventListener("pointerup", clearEmergencyHold);
        el.emergencyOff.addEventListener("pointerleave", clearEmergencyHold);
        el.emergencyOff.addEventListener("pointercancel", clearEmergencyHold);

        window.addEventListener("keydown", (event) => {
          const tag = document.activeElement?.tagName?.toLowerCase();
          if (tag === "input" || tag === "textarea" || tag === "select") return;
          if (!unlocked) return;

          const k = event.key.toLowerCase();

          if (k === "g") sendCommand("green");
          if (k === "y") sendCommand("yellow");
          if (k === "r") sendCommand("red");
          if (k === "o") sendCommand("off");
          if (k === "a") sendCommand("auto");
        });
      }

      function startLoops() {
        loadState();
        setInterval(loadState, 1600);

        setInterval(() => {
          renderPhase();
          setLampVisual(state.mode);
          el.updatedAgo.textContent = timeAgo(state.updatedAt);
        }, 250);
      }

      function init() {
        setUnlocked(false);
        bind();
        startLoops();
      }

      init();
    </script>
  </body>
</html>
