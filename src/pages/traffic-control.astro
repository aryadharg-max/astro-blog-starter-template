---
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Traffic Light Control Centre | Aryadhar Gupta</title>

    <style>
      :root {
        --bg: #f6f4ef;
        --surface: #ffffff;
        --surface-2: #fdfbf7;
        --text: #151515;
        --muted: #6b675f;
        --line: rgba(20, 20, 20, 0.11);
        --accent: #12355b;
        --accent-2: #0b223b;
        --danger: #b42318;
        --danger-soft: #fff0ed;
        --ok: #137333;
        --ok-soft: #eaf7ee;
        --warn: #946200;
        --warn-soft: #fff6d8;
        --red: #e53935;
        --yellow: #ffbf1f;
        --green: #21a467;
        --black: #141414;
        --radius-xl: 28px;
        --radius-lg: 20px;
        --radius-md: 14px;
        --shadow: 0 24px 80px rgba(0, 0, 0, 0.08);
        --shadow-soft: 0 12px 40px rgba(0, 0, 0, 0.06);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background:
          radial-gradient(circle at top left, rgba(18, 53, 91, 0.08), transparent 32rem),
          radial-gradient(circle at bottom right, rgba(33, 164, 103, 0.08), transparent 30rem),
          var(--bg);
        color: var(--text);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button,
      input {
        font: inherit;
      }

      .page {
        width: min(1380px, calc(100% - 32px));
        margin: 0 auto;
        padding: 24px 0 52px;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 22px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .mark {
        width: 46px;
        height: 46px;
        border-radius: 16px;
        background: var(--accent);
        color: white;
        display: grid;
        place-items: center;
        font-weight: 800;
        letter-spacing: -0.05em;
      }

      .brand small {
        display: block;
        color: var(--muted);
        margin-top: 2px;
      }

      .top-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .pill,
      .chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.72);
        backdrop-filter: blur(16px);
        border-radius: 999px;
        padding: 10px 14px;
        font-size: 13px;
        color: var(--muted);
      }

      .pill strong,
      .chip strong {
        color: var(--text);
      }

      .back-link {
        color: var(--accent);
        font-weight: 700;
      }

      .hero {
        background: rgba(255, 255, 255, 0.76);
        border: 1px solid var(--line);
        border-radius: var(--radius-xl);
        padding: clamp(22px, 4vw, 44px);
        box-shadow: var(--shadow);
        overflow: hidden;
        position: relative;
      }

      .hero::after {
        content: "";
        position: absolute;
        inset: auto -10% -40% auto;
        width: 460px;
        height: 460px;
        border-radius: 50%;
        background: rgba(18, 53, 91, 0.06);
        pointer-events: none;
      }

      .hero-grid {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1.28fr 0.72fr;
        gap: 32px;
        align-items: center;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin: 0 0 14px;
        color: var(--accent);
        font-size: 13px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      .dot {
        width: 9px;
        height: 9px;
        border-radius: 999px;
        background: var(--ok);
        box-shadow: 0 0 0 6px rgba(19, 115, 51, 0.1);
      }

      h1 {
        margin: 0;
        max-width: 850px;
        font-size: clamp(38px, 7vw, 82px);
        line-height: 0.92;
        letter-spacing: -0.075em;
      }

      .hero p {
        max-width: 760px;
        margin: 18px 0 0;
        color: var(--muted);
        font-size: clamp(15px, 2vw, 18px);
        line-height: 1.7;
      }

      .status-stack {
        display: grid;
        gap: 12px;
      }

      .status-card {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.82);
        border-radius: var(--radius-lg);
        padding: 18px;
        box-shadow: var(--shadow-soft);
      }

      .status-card span {
        display: block;
        color: var(--muted);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 8px;
      }

      .status-card strong {
        display: block;
        font-size: 22px;
        letter-spacing: -0.04em;
      }

      .main-grid {
        display: grid;
        grid-template-columns: 0.92fr 1.08fr 0.78fr;
        gap: 18px;
        margin-top: 18px;
      }

      .panel {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.82);
        border-radius: var(--radius-xl);
        padding: 20px;
        box-shadow: var(--shadow-soft);
      }

      .panel-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 14px;
        margin-bottom: 16px;
      }

      .panel-title {
        margin: 0;
        font-size: 18px;
        letter-spacing: -0.035em;
      }

      .panel-subtitle {
        margin: 5px 0 0;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.5;
      }

      .lock-panel {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 10px;
        margin-bottom: 16px;
      }

      .input-group {
        display: grid;
        gap: 7px;
      }

      label {
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
      }

      input[type="number"],
      input[type="password"],
      input[type="text"] {
        width: 100%;
        border: 1px solid var(--line);
        background: var(--surface);
        border-radius: 14px;
        padding: 13px 14px;
        color: var(--text);
        outline: none;
        transition: 0.18s ease;
      }

      input:focus {
        border-color: rgba(18, 53, 91, 0.38);
        box-shadow: 0 0 0 4px rgba(18, 53, 91, 0.08);
      }

      .btn {
        border: 1px solid var(--line);
        background: var(--surface);
        color: var(--text);
        border-radius: 15px;
        padding: 13px 16px;
        cursor: pointer;
        font-weight: 800;
        transition:
          transform 0.18s ease,
          box-shadow 0.18s ease,
          border-color 0.18s ease,
          background 0.18s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        min-height: 48px;
      }

      .btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 14px 30px rgba(0, 0, 0, 0.08);
        border-color: rgba(18, 53, 91, 0.25);
      }

      .btn:active {
        transform: translateY(0);
      }

      .btn.primary {
        background: var(--accent);
        color: white;
        border-color: var(--accent);
      }

      .btn.dark {
        background: var(--black);
        color: white;
        border-color: var(--black);
      }

      .btn.danger {
        background: var(--danger);
        color: white;
        border-color: var(--danger);
      }

      .btn.ghost {
        background: transparent;
      }

      .btn.small {
        min-height: 40px;
        padding: 10px 13px;
        font-size: 13px;
      }

      .btn.full {
        width: 100%;
      }

      .btn[disabled] {
        opacity: 0.52;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
      }

      .mode-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
      }

      .mode-btn {
        min-height: 86px;
        justify-content: flex-start;
        padding: 16px;
        text-align: left;
      }

      .mode-dot {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        flex: 0 0 auto;
        background: var(--line);
      }

      .mode-btn.red .mode-dot {
        background: var(--red);
      }

      .mode-btn.yellow .mode-dot {
        background: var(--yellow);
      }

      .mode-btn.green .mode-dot {
        background: var(--green);
      }

      .mode-btn.off .mode-dot {
        background: #111;
      }

      .mode-btn.auto .mode-dot {
        background: linear-gradient(135deg, var(--red), var(--yellow), var(--green));
      }

      .mode-copy {
        display: grid;
        gap: 3px;
      }

      .mode-copy small {
        color: var(--muted);
        font-weight: 600;
      }

      .emergency {
        margin-top: 10px;
      }

      .timing-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
      }

      .preset-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 8px;
        margin-top: 14px;
      }

      .toggle-row {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 13px;
        background: var(--surface-2);
        margin-top: 14px;
      }

      .toggle-row input {
        margin-top: 3px;
      }

      .toggle-row strong {
        display: block;
        font-size: 13px;
      }

      .toggle-row small {
        display: block;
        color: var(--muted);
        margin-top: 3px;
        line-height: 1.4;
      }

      .traffic-wrap {
        display: grid;
        place-items: center;
        min-height: 520px;
      }

      .traffic-light {
        width: min(260px, 90%);
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.08), transparent),
          #101010;
        border-radius: 44px;
        padding: 28px;
        box-shadow:
          inset 0 0 0 1px rgba(255, 255, 255, 0.08),
          0 40px 90px rgba(0, 0, 0, 0.22);
        display: grid;
        gap: 24px;
        position: relative;
      }

      .traffic-light::before {
        content: "";
        position: absolute;
        left: 50%;
        bottom: -110px;
        transform: translateX(-50%);
        width: 34px;
        height: 110px;
        background: #151515;
        border-radius: 0 0 18px 18px;
      }

      .lamp {
        aspect-ratio: 1;
        border-radius: 50%;
        background: #2c2c2c;
        box-shadow:
          inset 0 10px 20px rgba(255, 255, 255, 0.08),
          inset 0 -12px 22px rgba(0, 0, 0, 0.35);
        position: relative;
        opacity: 0.32;
        transition:
          opacity 0.2s ease,
          transform 0.2s ease,
          box-shadow 0.2s ease;
      }

      .lamp::after {
        content: "";
        position: absolute;
        inset: 16%;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.18);
        filter: blur(3px);
      }

      .lamp.red {
        background: var(--red);
      }

      .lamp.yellow {
        background: var(--yellow);
      }

      .lamp.green {
        background: var(--green);
      }

      .lamp.on {
        opacity: 1;
        transform: scale(1.025);
      }

      .lamp.red.on {
        box-shadow:
          0 0 42px rgba(229, 57, 53, 0.72),
          0 0 100px rgba(229, 57, 53, 0.34);
      }

      .lamp.yellow.on {
        box-shadow:
          0 0 42px rgba(255, 191, 31, 0.82),
          0 0 100px rgba(255, 191, 31, 0.36);
      }

      .lamp.green.on {
        box-shadow:
          0 0 42px rgba(33, 164, 103, 0.72),
          0 0 100px rgba(33, 164, 103, 0.3);
      }

      .phase-card {
        width: 100%;
        margin-top: 28px;
        border: 1px solid var(--line);
        border-radius: var(--radius-lg);
        padding: 16px;
        background: var(--surface-2);
      }

      .phase-top {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 10px;
      }

      .phase-top strong {
        letter-spacing: -0.03em;
      }

      .phase-top span {
        color: var(--muted);
        font-size: 13px;
      }

      .bar {
        height: 10px;
        background: rgba(0, 0, 0, 0.08);
        border-radius: 999px;
        overflow: hidden;
      }

      .bar-fill {
        width: 0%;
        height: 100%;
        border-radius: 999px;
        background: var(--accent);
        transition: width 0.2s linear;
      }

      .mini-bars {
        display: grid;
        grid-template-columns: var(--r, 10fr) var(--y, 5fr) var(--g, 15fr);
        height: 8px;
        overflow: hidden;
        border-radius: 999px;
        margin-top: 12px;
      }

      .mini-bars span:nth-child(1) {
        background: var(--red);
      }

      .mini-bars span:nth-child(2) {
        background: var(--yellow);
      }

      .mini-bars span:nth-child(3) {
        background: var(--green);
      }

      .side-stack {
        display: grid;
        gap: 18px;
      }

      .metric-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
      }

      .metric {
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 14px;
        background: var(--surface-2);
      }

      .metric span {
        color: var(--muted);
        display: block;
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 7px;
      }

      .metric strong {
        font-size: 18px;
        letter-spacing: -0.035em;
      }

      .log {
        display: grid;
        gap: 8px;
        max-height: 280px;
        overflow: auto;
        padding-right: 3px;
      }

      .log-item {
        border: 1px solid var(--line);
        background: var(--surface-2);
        border-radius: 14px;
        padding: 11px;
        display: grid;
        gap: 4px;
      }

      .log-item strong {
        font-size: 13px;
      }

      .log-item span {
        color: var(--muted);
        font-size: 12px;
      }

      .diagnostics {
        margin-top: 18px;
      }

      details {
        border: 1px solid var(--line);
        border-radius: var(--radius-lg);
        background: rgba(255, 255, 255, 0.78);
        overflow: hidden;
      }

      summary {
        cursor: pointer;
        padding: 16px 18px;
        font-weight: 800;
      }

      pre {
        margin: 0;
        padding: 18px;
        overflow: auto;
        background: #111;
        color: #e9e9e9;
        font-size: 12px;
        line-height: 1.6;
      }

      .toast {
        position: fixed;
        right: 18px;
        bottom: 18px;
        background: #111;
        color: white;
        padding: 14px 16px;
        border-radius: 16px;
        box-shadow: var(--shadow);
        transform: translateY(18px);
        opacity: 0;
        pointer-events: none;
        transition: 0.22s ease;
        z-index: 50;
        max-width: 360px;
      }

      .toast.show {
        opacity: 1;
        transform: translateY(0);
      }

      .status-ok {
        color: var(--ok);
      }

      .status-warn {
        color: var(--warn);
      }

      .status-bad {
        color: var(--danger);
      }

      @media (max-width: 1120px) {
        .hero-grid,
        .main-grid {
          grid-template-columns: 1fr;
        }

        .traffic-wrap {
          min-height: auto;
        }
      }

      @media (max-width: 680px) {
        .page {
          width: min(100% - 20px, 1380px);
          padding-top: 12px;
        }

        .topbar,
        .panel-header,
        .phase-top {
          flex-direction: column;
          align-items: flex-start;
        }

        .mode-grid,
        .timing-grid,
        .preset-grid,
        .metric-grid,
        .lock-panel {
          grid-template-columns: 1fr;
        }

        .hero {
          border-radius: 22px;
        }

        .panel {
          border-radius: 22px;
        }

        .traffic-light {
          width: 220px;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <header class="topbar">
        <a class="brand" href="/">
          <div class="mark">AG</div>
          <div>
            <strong>Aryadhar Gupta</strong>
            <small>Connected hardware control</small>
          </div>
        </a>

        <div class="top-actions">
          <span class="pill">Backend: <strong id="backendText">Checking</strong></span>
          <span class="pill">Operator: <strong id="armText">Locked</strong></span>
          <a class="pill back-link" href="/">← Back to portfolio</a>
        </div>
      </header>

      <section class="hero">
        <div class="hero-grid">
          <div>
            <p class="eyebrow"><span class="dot"></span> Live Control Centre</p>
            <h1>Traffic Light Command System</h1>
            <p>
              A public-domain control interface connected to a Cloudflare Worker backend and a
              NodeMCU-controlled relay system. Designed for clean manual control, automatic cycling,
              diagnostics, and safe operation.
            </p>
          </div>

          <div class="status-stack">
            <div class="status-card">
              <span>Current mode</span>
              <strong id="heroMode">Loading</strong>
            </div>
            <div class="status-card">
              <span>Active phase</span>
              <strong id="heroPhase">Waiting</strong>
            </div>
            <div class="status-card">
              <span>Last command</span>
              <strong id="heroUpdated">—</strong>
            </div>
          </div>
        </div>
      </section>

      <main class="main-grid">
        <section class="panel">
          <div class="panel-header">
            <div>
              <h2 class="panel-title">Operator Access</h2>
              <p class="panel-subtitle">
                Arm the panel before sending commands. PIN becomes active when you set
                <strong>CONTROL_PIN</strong> in your Worker.
              </p>
            </div>
          </div>

          <div class="lock-panel">
            <div class="input-group">
              <label for="controlPin">Operator PIN</label>
              <input id="controlPin" type="password" placeholder="Optional for now" />
            </div>
            <button class="btn primary" id="armButton" type="button">Arm</button>
          </div>

          <button class="btn danger full emergency" id="emergencyOff" type="button">
            Emergency All Off
          </button>

          <div class="toggle-row">
            <input id="timedReturn" type="checkbox" checked />
            <div>
              <strong>Timed manual return</strong>
              <small>
                Manual Red / Yellow / Green holds for its configured time, then returns to Auto.
              </small>
            </div>
          </div>

          <div style="height: 18px"></div>

          <div class="panel-header">
            <div>
              <h2 class="panel-title">Manual Command</h2>
              <p class="panel-subtitle">
                Keyboard shortcuts while armed: R, Y, G, O, A.
              </p>
            </div>
          </div>

          <div class="mode-grid">
            <button class="btn mode-btn red" data-mode="red" type="button">
              <span class="mode-dot"></span>
              <span class="mode-copy">
                <strong>Red</strong>
                <small>Stop / hold</small>
              </span>
            </button>

            <button class="btn mode-btn yellow" data-mode="yellow" type="button">
              <span class="mode-dot"></span>
              <span class="mode-copy">
                <strong>Yellow</strong>
                <small>Warning phase</small>
              </span>
            </button>

            <button class="btn mode-btn green" data-mode="green" type="button">
              <span class="mode-dot"></span>
              <span class="mode-copy">
                <strong>Green</strong>
                <small>Go phase</small>
              </span>
            </button>

            <button class="btn mode-btn off" data-mode="off" type="button">
              <span class="mode-dot"></span>
              <span class="mode-copy">
                <strong>All Off</strong>
                <small>Relay safe state</small>
              </span>
            </button>

            <button class="btn mode-btn auto" data-mode="auto" type="button" style="grid-column: 1 / -1">
              <span class="mode-dot"></span>
              <span class="mode-copy">
                <strong>Auto Mode</strong>
                <small>Startup check, then cycle Red → Yellow → Green</small>
              </span>
            </button>
          </div>
        </section>

        <section class="panel">
          <div class="panel-header">
            <div>
              <h2 class="panel-title">Live Signal Preview</h2>
              <p class="panel-subtitle">
                Visual state mirrors the command currently stored in the backend.
              </p>
            </div>
            <button class="btn small ghost" id="refreshButton" type="button">Refresh</button>
          </div>

          <div class="traffic-wrap">
            <div>
              <div class="traffic-light" aria-label="Traffic light preview">
                <div class="lamp red" id="lampRed"></div>
                <div class="lamp yellow" id="lampYellow"></div>
                <div class="lamp green" id="lampGreen"></div>
              </div>

              <div class="phase-card">
                <div class="phase-top">
                  <div>
                    <strong id="phaseName">Waiting for state</strong>
                    <span id="phaseDetail">Backend sync pending</span>
                  </div>
                  <strong id="phaseCountdown">—</strong>
                </div>
                <div class="bar">
                  <div class="bar-fill" id="phaseBar"></div>
                </div>
                <div class="mini-bars" id="miniBars">
                  <span></span>
                  <span></span>
                  <span></span>
                </div>
              </div>
            </div>
          </div>
        </section>

        <aside class="side-stack">
          <section class="panel">
            <div class="panel-header">
              <div>
                <h2 class="panel-title">Auto Timing</h2>
                <p class="panel-subtitle">
                  These values are saved with the next command.
                </p>
              </div>
            </div>

            <div class="timing-grid">
              <div class="input-group">
                <label for="redTime">Red</label>
                <input id="redTime" type="number" min="1" max="120" value="10" />
              </div>

              <div class="input-group">
                <label for="yellowTime">Yellow</label>
                <input id="yellowTime" type="number" min="1" max="120" value="5" />
              </div>

              <div class="input-group">
                <label for="greenTime">Green</label>
                <input id="greenTime" type="number" min="1" max="120" value="15" />
              </div>
            </div>

            <div class="preset-grid">
              <button class="btn small" data-preset="standard" type="button">Standard</button>
              <button class="btn small" data-preset="fast" type="button">Fast Test</button>
              <button class="btn small" data-preset="green" type="button">Long Green</button>
              <button class="btn small" data-preset="balanced" type="button">Balanced</button>
            </div>

            <div style="height: 10px"></div>

            <button class="btn primary full" id="applyAuto" type="button">
              Apply Timings + Auto
            </button>
          </section>

          <section class="panel">
            <div class="panel-header">
              <div>
                <h2 class="panel-title">Showcase Sequence</h2>
                <p class="panel-subtitle">
                  Runs a controlled demo from the browser by sending timed commands.
                </p>
              </div>
            </div>

            <button class="btn dark full" id="runDemo" type="button">Run Demo Sweep</button>
            <div style="height: 10px"></div>
            <button class="btn full" id="stopDemo" type="button">Stop Demo</button>
          </section>

          <section class="panel">
            <div class="panel-header">
              <div>
                <h2 class="panel-title">System Metrics</h2>
              </div>
            </div>

            <div class="metric-grid">
              <div class="metric">
                <span>Backend</span>
                <strong id="metricBackend">—</strong>
              </div>
              <div class="metric">
                <span>Security</span>
                <strong id="metricSecurity">—</strong>
              </div>
              <div class="metric">
                <span>Revision</span>
                <strong id="metricRevision">—</strong>
              </div>
              <div class="metric">
                <span>Source</span>
                <strong id="metricSource">—</strong>
              </div>
            </div>
          </section>

          <section class="panel">
            <div class="panel-header">
              <div>
                <h2 class="panel-title">Command Log</h2>
              </div>
              <button class="btn small ghost" id="clearLog" type="button">Clear</button>
            </div>

            <div class="log" id="commandLog"></div>
          </section>
        </aside>
      </main>

      <section class="diagnostics">
        <details>
          <summary>Raw API diagnostics</summary>
          <pre id="rawState">Waiting for API response...</pre>
        </details>
      </section>
    </div>

    <div class="toast" id="toast"></div>

    <script is:inline>
      const API_BASE = "https://traffic-light-api.gunshots2005.workers.dev";

      const $ = (id) => document.getElementById(id);

      const elements = {
        backendText: $("backendText"),
        armText: $("armText"),
        heroMode: $("heroMode"),
        heroPhase: $("heroPhase"),
        heroUpdated: $("heroUpdated"),
        controlPin: $("controlPin"),
        armButton: $("armButton"),
        emergencyOff: $("emergencyOff"),
        timedReturn: $("timedReturn"),
        refreshButton: $("refreshButton"),
        lampRed: $("lampRed"),
        lampYellow: $("lampYellow"),
        lampGreen: $("lampGreen"),
        phaseName: $("phaseName"),
        phaseDetail: $("phaseDetail"),
        phaseCountdown: $("phaseCountdown"),
        phaseBar: $("phaseBar"),
        miniBars: $("miniBars"),
        redTime: $("redTime"),
        yellowTime: $("yellowTime"),
        greenTime: $("greenTime"),
        applyAuto: $("applyAuto"),
        runDemo: $("runDemo"),
        stopDemo: $("stopDemo"),
        metricBackend: $("metricBackend"),
        metricSecurity: $("metricSecurity"),
        metricRevision: $("metricRevision"),
        metricSource: $("metricSource"),
        commandLog: $("commandLog"),
        clearLog: $("clearLog"),
        rawState: $("rawState"),
        toast: $("toast"),
      };

      let armed = false;
      let latestState = {
        mode: "auto",
        red: 10,
        yellow: 5,
        green: 15,
        startupCheckMs: 1500,
        updatedAt: null,
        revision: 0,
        source: "initial",
      };

      let backendOnline = false;
      let pinProtectionEnabled = false;
      let manualReturnTimer = null;
      let demoTimer = null;
      let demoRunning = false;
      let commandLog = [];

      function toast(message) {
        elements.toast.textContent = message;
        elements.toast.classList.add("show");

        window.clearTimeout(elements.toast._timer);
        elements.toast._timer = window.setTimeout(() => {
          elements.toast.classList.remove("show");
        }, 2600);
      }

      function formatMode(mode) {
        const value = String(mode || "unknown").toLowerCase();

        if (value === "red") return "Manual Red";
        if (value === "yellow") return "Manual Yellow";
        if (value === "green") return "Manual Green";
        if (value === "off") return "All Off";
        if (value === "auto") return "Auto Cycle";

        return "Unknown";
      }

      function formatTimeAgo(iso) {
        if (!iso) return "Not yet";
        const diff = Math.max(0, Date.now() - Date.parse(iso));
        const seconds = Math.floor(diff / 1000);

        if (seconds < 5) return "Just now";
        if (seconds < 60) return `${seconds}s ago`;

        const minutes = Math.floor(seconds / 60);
        if (minutes < 60) return `${minutes}m ago`;

        const hours = Math.floor(minutes / 60);
        return `${hours}h ago`;
      }

      function getNumber(input, fallback) {
        const value = Number(input.value);

        if (!Number.isFinite(value)) return fallback;

        return Math.min(Math.max(Math.round(value), 1), 120);
      }

      function getTimingPayload() {
        return {
          red: getNumber(elements.redTime, latestState.red || 10),
          yellow: getNumber(elements.yellowTime, latestState.yellow || 5),
          green: getNumber(elements.greenTime, latestState.green || 15),
        };
      }

      function savePin() {
        localStorage.setItem("traffic-control-pin", elements.controlPin.value || "");
      }

      function loadPin() {
        elements.controlPin.value = localStorage.getItem("traffic-control-pin") || "";
      }

      function setArmed(nextValue) {
        armed = nextValue;

        elements.armText.textContent = armed ? "Armed" : "Locked";
        elements.armText.className = armed ? "status-ok" : "status-warn";
        elements.armButton.textContent = armed ? "Disarm" : "Arm";
        elements.armButton.classList.toggle("danger", armed);
        elements.armButton.classList.toggle("primary", !armed);

        document.querySelectorAll("[data-mode], #applyAuto, #runDemo, #stopDemo").forEach((button) => {
          button.disabled = !armed;
        });

        elements.emergencyOff.disabled = false;

        toast(armed ? "Control panel armed" : "Control panel locked");
      }

      function addLog(title, detail) {
        const time = new Date().toLocaleTimeString([], {
          hour: "2-digit",
          minute: "2-digit",
          second: "2-digit",
        });

        commandLog.unshift({ title, detail, time });
        commandLog = commandLog.slice(0, 12);

        elements.commandLog.innerHTML = commandLog
          .map(
            (item) => `
              <div class="log-item">
                <strong>${item.title}</strong>
                <span>${item.detail} • ${item.time}</span>
              </div>
            `
          )
          .join("");
      }

      function renderPreviewFromMode(mode) {
        const value = String(mode || "off").toLowerCase();

        elements.lampRed.classList.toggle("on", value === "red");
        elements.lampYellow.classList.toggle("on", value === "yellow");
        elements.lampGreen.classList.toggle("on", value === "green");

        if (value === "auto") {
          const phase = getAutoPhase();

          elements.lampRed.classList.toggle("on", phase.color === "red");
          elements.lampYellow.classList.toggle("on", phase.color === "yellow");
          elements.lampGreen.classList.toggle("on", phase.color === "green");
        }

        if (value === "off") {
          elements.lampRed.classList.remove("on");
          elements.lampYellow.classList.remove("on");
          elements.lampGreen.classList.remove("on");
        }
      }

      function getAutoPhase() {
        const startup = latestState.startupCheckMs || 1500;
        const redMs = (latestState.red || 10) * 1000;
        const yellowMs = (latestState.yellow || 5) * 1000;
        const greenMs = (latestState.green || 15) * 1000;

        const totalMs = startup + redMs + yellowMs + greenMs;
        const updatedAt = latestState.updatedAt ? Date.parse(latestState.updatedAt) : Date.now();

        let elapsed = (Date.now() - updatedAt) % totalMs;
        if (elapsed < 0) elapsed = 0;

        if (elapsed < startup) {
          return {
            name: "Startup Check",
            detail: "All lights briefly ON at hardware",
            color: "all",
            elapsed,
            duration: startup,
            remaining: startup - elapsed,
          };
        }

        elapsed -= startup;

        if (elapsed < redMs) {
          return {
            name: "Auto Red",
            detail: "Stop phase",
            color: "red",
            elapsed,
            duration: redMs,
            remaining: redMs - elapsed,
          };
        }

        elapsed -= redMs;

        if (elapsed < yellowMs) {
          return {
            name: "Auto Yellow",
            detail: "Warning phase",
            color: "yellow",
            elapsed,
            duration: yellowMs,
            remaining: yellowMs - elapsed,
          };
        }

        elapsed -= yellowMs;

        return {
          name: "Auto Green",
          detail: "Go phase",
          color: "green",
          elapsed,
          duration: greenMs,
          remaining: greenMs - elapsed,
        };
      }

      function renderPhase() {
        if (latestState.mode !== "auto") {
          elements.phaseName.textContent = formatMode(latestState.mode);
          elements.phaseDetail.textContent =
            latestState.mode === "off"
              ? "All relays commanded OFF"
              : "Manual command active";
          elements.phaseCountdown.textContent = "Hold";
          elements.phaseBar.style.width = "100%";
          elements.heroPhase.textContent = formatMode(latestState.mode);
          return;
        }

        const phase = getAutoPhase();
        const percent = Math.min(100, Math.max(0, (phase.elapsed / phase.duration) * 100));
        const remainingSeconds = Math.ceil(phase.remaining / 1000);

        elements.phaseName.textContent = phase.name;
        elements.phaseDetail.textContent = phase.detail;
        elements.phaseCountdown.textContent = `${remainingSeconds}s`;
        elements.phaseBar.style.width = `${percent}%`;
        elements.heroPhase.textContent = phase.name;
      }

      function renderState() {
        elements.heroMode.textContent = formatMode(latestState.mode);
        elements.heroUpdated.textContent = formatTimeAgo(latestState.updatedAt);

        elements.redTime.value = latestState.red ?? 10;
        elements.yellowTime.value = latestState.yellow ?? 5;
        elements.greenTime.value = latestState.green ?? 15;

        elements.backendText.textContent = backendOnline ? "Online" : "Offline";
        elements.backendText.className = backendOnline ? "status-ok" : "status-bad";

        elements.metricBackend.textContent = backendOnline ? "Online" : "Offline";
        elements.metricSecurity.textContent = pinProtectionEnabled ? "PIN On" : "Open";
        elements.metricRevision.textContent = latestState.revision || "0";
        elements.metricSource.textContent = latestState.source || "—";

        elements.miniBars.style.setProperty("--r", `${latestState.red || 10}fr`);
        elements.miniBars.style.setProperty("--y", `${latestState.yellow || 5}fr`);
        elements.miniBars.style.setProperty("--g", `${latestState.green || 15}fr`);

        renderPreviewFromMode(latestState.mode);
        renderPhase();
      }

      async function loadState() {
        try {
          const response = await fetch(`${API_BASE}/api/state`, {
            method: "GET",
            cache: "no-store",
          });

          const data = await response.json();

          elements.rawState.textContent = JSON.stringify(data, null, 2);

          if (!response.ok || !data.ok) {
            throw new Error(data.error || "API state error");
          }

          backendOnline = true;
          pinProtectionEnabled = Boolean(data.pinProtectionEnabled);
          latestState = data.state;

          renderState();
        } catch (error) {
          backendOnline = false;
          elements.backendText.textContent = "Offline";
          elements.backendText.className = "status-bad";
          elements.metricBackend.textContent = "Offline";
          elements.rawState.textContent = String(error);
        }
      }

      async function sendCommand(mode, options = {}) {
        if (!armed && !options.bypassArm) {
          toast("Arm the panel before sending commands");
          return;
        }

        savePin();

        const controlPin = elements.controlPin.value || "";
        const timing = getTimingPayload();

        const body = {
          mode,
          ...timing,
          source: options.source || "web-control-centre-v2",
        };

        if (controlPin) {
          body.controlPin = controlPin;
        }

        try {
          const response = await fetch(`${API_BASE}/api/command`, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "X-Control-Pin": controlPin,
            },
            body: JSON.stringify(body),
          });

          const data = await response.json();

          elements.rawState.textContent = JSON.stringify(data, null, 2);

          if (!response.ok || !data.ok) {
            throw new Error(data.error || "Command failed");
          }

          latestState = data.state;
          backendOnline = true;

          addLog(`Command: ${formatMode(mode)}`, `R${body.red}s / Y${body.yellow}s / G${body.green}s`);
          toast(`${formatMode(mode)} command sent`);

          renderState();

          return data;
        } catch (error) {
          toast(error.message || "Command failed");
          addLog("Command failed", error.message || "Unknown error");
          throw error;
        }
      }

      function clearManualReturn() {
        if (manualReturnTimer) {
          window.clearTimeout(manualReturnTimer);
          manualReturnTimer = null;
        }
      }

      function scheduleTimedReturn(mode) {
        clearManualReturn();

        if (!elements.timedReturn.checked) return;
        if (!["red", "yellow", "green"].includes(mode)) return;

        const timing = getTimingPayload();
        const seconds = timing[mode] || 5;

        manualReturnTimer = window.setTimeout(() => {
          sendCommand("auto", {
            bypassArm: true,
            source: "timed-manual-return",
          });
        }, seconds * 1000);

        addLog("Timed return armed", `${formatMode(mode)} will return to Auto in ${seconds}s`);
      }

      async function runDemoSequence() {
        if (!armed) {
          toast("Arm the panel before running demo");
          return;
        }

        stopDemoSequence(false);

        demoRunning = true;
        addLog("Demo started", "Red → Yellow → Green → Off → Auto");

        const steps = [
          { mode: "red", wait: 4000 },
          { mode: "yellow", wait: 2000 },
          { mode: "green", wait: 4000 },
          { mode: "off", wait: 1500 },
          { mode: "auto", wait: 0 },
        ];

        let index = 0;

        const next = async () => {
          if (!demoRunning) return;

          const step = steps[index];

          await sendCommand(step.mode, {
            source: "demo-sequence",
          });

          index++;

          if (index >= steps.length) {
            demoRunning = false;
            addLog("Demo finished", "System returned to Auto");
            return;
          }

          demoTimer = window.setTimeout(next, step.wait);
        };

        next();
      }

      function stopDemoSequence(sendOff = true) {
        demoRunning = false;

        if (demoTimer) {
          window.clearTimeout(demoTimer);
          demoTimer = null;
        }

        if (sendOff && armed) {
          sendCommand("off", {
            source: "demo-stop",
          });
        }

        addLog("Demo stopped", sendOff ? "All Off command sent" : "Sequence cleared");
      }

      function applyPreset(name) {
        const presets = {
          standard: { red: 10, yellow: 5, green: 15 },
          fast: { red: 3, yellow: 1, green: 3 },
          green: { red: 8, yellow: 3, green: 30 },
          balanced: { red: 12, yellow: 4, green: 12 },
        };

        const preset = presets[name];
        if (!preset) return;

        elements.redTime.value = preset.red;
        elements.yellowTime.value = preset.yellow;
        elements.greenTime.value = preset.green;

        toast(`${name} preset loaded`);
        addLog("Preset loaded", `R${preset.red}s / Y${preset.yellow}s / G${preset.green}s`);
      }

      function bindEvents() {
        elements.armButton.addEventListener("click", () => {
          setArmed(!armed);
        });

        elements.controlPin.addEventListener("change", savePin);

        document.querySelectorAll("[data-mode]").forEach((button) => {
          button.addEventListener("click", async () => {
            const mode = button.dataset.mode;
            clearManualReturn();
            await sendCommand(mode);
            scheduleTimedReturn(mode);
          });
        });

        document.querySelectorAll("[data-preset]").forEach((button) => {
          button.addEventListener("click", () => {
            applyPreset(button.dataset.preset);
          });
        });

        elements.applyAuto.addEventListener("click", () => {
          clearManualReturn();
          sendCommand("auto");
        });

        elements.emergencyOff.addEventListener("click", () => {
          clearManualReturn();
          stopDemoSequence(false);
          sendCommand("off", {
            bypassArm: true,
            source: "emergency-off",
          });
        });

        elements.refreshButton.addEventListener("click", () => {
          loadState();
          toast("State refreshed");
        });

        elements.runDemo.addEventListener("click", runDemoSequence);

        elements.stopDemo.addEventListener("click", () => {
          stopDemoSequence(true);
        });

        elements.clearLog.addEventListener("click", () => {
          commandLog = [];
          elements.commandLog.innerHTML = "";
        });

        window.addEventListener("keydown", (event) => {
          const activeTag = document.activeElement?.tagName?.toLowerCase();

          if (activeTag === "input" || activeTag === "textarea") return;
          if (!armed) return;

          const key = event.key.toLowerCase();

          if (key === "r") sendCommand("red");
          if (key === "y") sendCommand("yellow");
          if (key === "g") sendCommand("green");
          if (key === "o") sendCommand("off");
          if (key === "a") sendCommand("auto");
        });
      }

      function startRenderLoop() {
        window.setInterval(() => {
          renderPreviewFromMode(latestState.mode);
          renderPhase();
          elements.heroUpdated.textContent = formatTimeAgo(latestState.updatedAt);
        }, 250);
      }

      function startPolling() {
        loadState();
        window.setInterval(loadState, 2500);
      }

      function init() {
        loadPin();
        bindEvents();
        setArmed(false);
        startPolling();
        startRenderLoop();

        addLog("Control centre loaded", "Waiting for backend state");
      }

      init();
    </script>
  </body>
</html>
