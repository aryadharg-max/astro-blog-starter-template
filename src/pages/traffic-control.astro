---
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Aryadhar Gupta | Builder. Driver. Operator.</title>
    <meta
      name="description"
      content="Aryadhar Gupta — motorsport, engineering, environmental systems, physical builds, product ventures, and operating projects."
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT,WONK@9..144,400..900,0..100,0..1&family=IBM+Plex+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --bg: #f2ede3;
        --bg-2: #e8dece;
        --text: #11110f;
        --muted: #716a60;
        --line: rgba(17, 17, 15, 0.13);
        --line-strong: rgba(17, 17, 15, 0.22);
        --panel: rgba(255, 255, 255, 0.58);
        --panel-strong: rgba(255, 255, 255, 0.86);
        --navy: #0b243f;
        --navy-2: #071623;
        --red: #d63d31;
        --gold: #ad7e2b;
        --green: #177a55;
        --yellow: #d2a218;
        --dark: #10100e;
        --shadow: 0 34px 90px rgba(17, 17, 15, 0.12);
        --soft-shadow: 0 16px 42px rgba(17, 17, 15, 0.08);
        --radius-xl: 34px;
        --radius-lg: 26px;
        --radius-md: 18px;
        --max: 1440px;
        --display: "Fraunces", Georgia, serif;
        --body: "Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --mono: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--text);
        font-family: var(--body);
        background:
          linear-gradient(120deg, rgba(11, 36, 63, 0.08), transparent 26rem),
          linear-gradient(240deg, rgba(214, 61, 49, 0.055), transparent 24rem),
          linear-gradient(180deg, var(--bg), var(--bg-2));
        overflow-x: hidden;
      }

      body.locked {
        overflow: hidden;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button,
      input {
        font: inherit;
      }

      button {
        cursor: pointer;
      }

      .grid-noise {
        position: fixed;
        inset: 0;
        z-index: -1;
        opacity: 0.25;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(17, 17, 15, 0.035) 1px, transparent 1px),
          linear-gradient(90deg, rgba(17, 17, 15, 0.035) 1px, transparent 1px);
        background-size: 46px 46px;
        mask-image: linear-gradient(to bottom, black 0%, rgba(0, 0, 0, 0.72) 48%, transparent 96%);
      }

      .progress {
        position: fixed;
        top: 0;
        left: 0;
        width: 0%;
        height: 4px;
        z-index: 200;
        background: linear-gradient(90deg, var(--red), var(--gold), var(--navy));
        box-shadow: 0 0 18px rgba(214, 61, 49, 0.28);
      }

      .shell {
        width: min(var(--max), calc(100% - 32px));
        margin: 0 auto;
      }

      .nav {
        position: sticky;
        top: 12px;
        z-index: 100;
        margin-top: 12px;
      }

      .nav-inner {
        min-height: 64px;
        border: 1px solid var(--line);
        border-radius: 22px;
        background: rgba(242, 237, 227, 0.78);
        backdrop-filter: blur(24px) saturate(1.25);
        box-shadow: 0 16px 38px rgba(17, 17, 15, 0.08);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        padding: 10px 12px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: fit-content;
      }

      .brand-mark {
        width: 42px;
        height: 42px;
        border-radius: 15px;
        background:
          radial-gradient(circle at 30% 18%, rgba(255, 255, 255, 0.45), transparent 22px),
          linear-gradient(135deg, var(--navy), var(--navy-2));
        color: white;
        display: grid;
        place-items: center;
        font-weight: 950;
        letter-spacing: -0.08em;
        box-shadow: 0 14px 34px rgba(11, 36, 63, 0.28);
      }

      .brand-text strong {
        display: block;
        line-height: 1;
        letter-spacing: -0.04em;
      }

      .brand-text span {
        display: block;
        margin-top: 4px;
        font-size: 12px;
        color: var(--muted);
      }

      .nav-links {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        flex-wrap: wrap;
      }

      .nav-links a,
      .command-trigger {
        border: 1px solid transparent;
        border-radius: 999px;
        padding: 10px 12px;
        color: var(--muted);
        background: transparent;
        transition: 0.18s ease;
        font-size: 13px;
        font-weight: 800;
      }

      .nav-links a:hover,
      .command-trigger:hover {
        color: var(--text);
        border-color: var(--line);
        background: rgba(255, 255, 255, 0.52);
      }

      .command-trigger {
        display: inline-flex;
        align-items: center;
        gap: 7px;
      }

      .keycap {
        border: 1px solid var(--line);
        border-bottom-width: 2px;
        background: rgba(255, 255, 255, 0.72);
        border-radius: 8px;
        padding: 2px 6px;
        font-family: var(--mono);
        font-size: 11px;
        color: var(--text);
      }

      .menu-btn {
        display: none;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.66);
        border-radius: 14px;
        padding: 10px 12px;
        font-weight: 900;
      }

      .hero {
        padding: clamp(42px, 7vw, 104px) 0 46px;
        min-height: calc(100vh - 96px);
        display: grid;
        grid-template-columns: minmax(0, 1.12fr) minmax(360px, 0.88fr);
        gap: 18px;
        align-items: stretch;
      }

      .glass {
        border: 1px solid var(--line);
        background: var(--panel);
        backdrop-filter: blur(24px);
        box-shadow: var(--shadow);
      }

      .hero-main {
        border-radius: var(--radius-xl);
        padding: clamp(24px, 5vw, 58px);
        min-height: 700px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
      }

      .hero-main::before {
        content: "";
        position: absolute;
        inset: 20px;
        border: 1px solid rgba(17, 17, 15, 0.08);
        border-radius: 26px;
        pointer-events: none;
      }

      .racing-line {
        position: absolute;
        left: -12%;
        bottom: 16%;
        width: 130%;
        height: 90px;
        pointer-events: none;
        opacity: 0.72;
        background:
          linear-gradient(105deg, transparent 0 12%, rgba(214, 61, 49, 0.18) 12% 13%, transparent 13% 22%, rgba(214, 61, 49, 0.5) 22% 23%, transparent 23% 100%),
          linear-gradient(105deg, transparent 0 45%, rgba(11, 36, 63, 0.1) 45% 46%, transparent 46% 100%);
        transform: rotate(-7deg);
      }

      .hero-content,
      .hero-proof {
        position: relative;
        z-index: 1;
      }

      .status-strip {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 28px;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.58);
        border-radius: 999px;
        padding: 9px 12px;
        color: var(--muted);
        font-size: 13px;
        font-weight: 800;
      }

      .pulse {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--green);
        box-shadow: 0 0 0 7px rgba(23, 122, 85, 0.13);
      }

      .hero-kicker {
        margin: 0 0 14px;
        font-family: var(--mono);
        color: var(--red);
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.16em;
      }

      .hero h1 {
        margin: 0;
        max-width: 960px;
        font-family: var(--display);
        font-size: clamp(66px, 10vw, 152px);
        font-weight: 760;
        line-height: 0.78;
        letter-spacing: -0.075em;
        text-wrap: balance;
      }

      .hero h1 em {
        font-style: italic;
        font-weight: 520;
        color: var(--red);
      }

      .hero-copy {
        margin: 30px 0 0;
        max-width: 760px;
        color: var(--muted);
        font-size: clamp(17px, 2vw, 22px);
        line-height: 1.5;
      }

      .hero-copy strong {
        color: var(--text);
      }

      .hero-actions {
        margin-top: 34px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .btn {
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 13px 16px;
        background: rgba(255, 255, 255, 0.66);
        color: var(--text);
        font-weight: 900;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition:
          transform 0.16s ease,
          box-shadow 0.16s ease,
          background 0.16s ease,
          border-color 0.16s ease;
      }

      .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 16px 36px rgba(17, 17, 15, 0.1);
        border-color: var(--line-strong);
      }

      .btn.primary {
        background: linear-gradient(135deg, var(--navy), var(--navy-2));
        color: white;
        border-color: rgba(11, 36, 63, 0.7);
      }

      .btn.redline {
        color: white;
        background: linear-gradient(135deg, var(--red), #8f1e19);
        border-color: rgba(214, 61, 49, 0.5);
      }

      .hero-proof {
        margin-top: 48px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
      }

      .proof-tile {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.58);
        border-radius: 20px;
        padding: 16px;
        min-height: 124px;
        display: grid;
        align-content: space-between;
        transition:
          transform 0.18s ease,
          border-color 0.18s ease,
          background 0.18s ease;
      }

      .proof-tile:hover {
        transform: translateY(-3px);
        border-color: rgba(214, 61, 49, 0.26);
        background: rgba(255, 255, 255, 0.76);
      }

      .proof-tile span {
        font-family: var(--mono);
        color: var(--muted);
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      .proof-tile strong {
        display: block;
        margin-top: 18px;
        font-size: 18px;
        line-height: 1.05;
        letter-spacing: -0.04em;
      }

      .ops-panel {
        border-radius: var(--radius-xl);
        padding: 18px;
        min-height: 700px;
        display: grid;
        gap: 14px;
      }

      .ops-board {
        border-radius: 28px;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.06), transparent),
          #10100e;
        color: white;
        padding: 20px;
        min-height: 430px;
        display: grid;
        align-content: space-between;
        overflow: hidden;
        position: relative;
      }

      .ops-board::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.045) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.045) 1px, transparent 1px);
        background-size: 32px 32px;
        opacity: 0.42;
        pointer-events: none;
      }

      .ops-board > * {
        position: relative;
        z-index: 1;
      }

      .ops-topline {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        color: rgba(255, 255, 255, 0.62);
        font-family: var(--mono);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.13em;
        font-weight: 700;
      }

      .ops-title {
        margin-top: 24px;
      }

      .ops-title h2 {
        margin: 0;
        font-family: var(--display);
        font-size: clamp(44px, 5vw, 78px);
        line-height: 0.84;
        letter-spacing: -0.07em;
        font-weight: 720;
      }

      .ops-title p {
        color: rgba(255, 255, 255, 0.62);
        line-height: 1.5;
        margin: 16px 0 0;
      }

      .ops-focus {
        display: grid;
        gap: 10px;
        margin-top: 28px;
      }

      .ops-item {
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 18px;
        padding: 14px;
        background: rgba(255, 255, 255, 0.055);
        display: grid;
        grid-template-columns: 92px 1fr auto;
        gap: 12px;
        align-items: center;
      }

      .ops-item span {
        color: rgba(255, 255, 255, 0.58);
        font-family: var(--mono);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-weight: 700;
      }

      .ops-item strong {
        font-size: 15px;
      }

      .ops-item em {
        font-style: normal;
        color: rgba(255, 255, 255, 0.54);
        font-size: 12px;
      }

      .tach {
        margin-top: 22px;
        display: grid;
        grid-template-columns: repeat(28, 1fr);
        gap: 4px;
        align-items: end;
        height: 70px;
      }

      .tach span {
        height: 16px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
        animation: tach 2.6s ease-in-out infinite;
      }

      .tach span:nth-child(4n) {
        animation-delay: 0.22s;
      }

      .tach span:nth-child(5n) {
        animation-delay: 0.38s;
      }

      .tach span:nth-child(7n) {
        animation-delay: 0.58s;
        background: rgba(214, 61, 49, 0.36);
      }

      @keyframes tach {
        0%,
        100% {
          height: 14px;
        }
        50% {
          height: 62px;
        }
      }

      .side-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
      }

      .side-card {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.58);
        border-radius: 24px;
        padding: 18px;
        min-height: 170px;
      }

      .side-card span {
        color: var(--muted);
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.11em;
        text-transform: uppercase;
      }

      .side-card strong {
        display: block;
        margin-top: 22px;
        font-family: var(--display);
        font-size: 32px;
        line-height: 0.9;
        letter-spacing: -0.06em;
      }

      .side-card p {
        color: var(--muted);
        margin: 10px 0 0;
        line-height: 1.42;
        font-size: 14px;
      }

      section {
        padding: 58px 0;
      }

      .section-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: 22px;
      }

      .section-head h2 {
        margin: 0;
        font-family: var(--display);
        font-size: clamp(42px, 6vw, 92px);
        line-height: 0.82;
        letter-spacing: -0.075em;
        font-weight: 720;
        text-wrap: balance;
      }

      .section-head p {
        margin: 0;
        max-width: 590px;
        color: var(--muted);
        font-size: 16px;
        line-height: 1.55;
      }

      .filters-wrap {
        margin: 20px 0;
        overflow-x: auto;
        padding-bottom: 4px;
        scrollbar-width: thin;
      }

      .filters {
        display: flex;
        gap: 8px;
        min-width: max-content;
      }

      .filter {
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.5);
        padding: 10px 13px;
        color: var(--muted);
        font-weight: 900;
        font-size: 13px;
        transition: 0.18s ease;
      }

      .filter.active,
      .filter:hover {
        color: white;
        background: var(--navy);
        border-color: var(--navy);
      }

      .projects-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 14px;
      }

      .project-card {
        grid-column: span 4;
        min-height: 340px;
        border: 1px solid var(--line);
        border-radius: 28px;
        background: var(--panel);
        backdrop-filter: blur(22px);
        box-shadow: var(--soft-shadow);
        padding: 18px;
        display: grid;
        align-content: space-between;
        position: relative;
        overflow: hidden;
        transition:
          transform 0.18s ease,
          box-shadow 0.18s ease,
          border-color 0.18s ease,
          background 0.18s ease,
          opacity 0.18s ease;
      }

      .project-card.feature {
        grid-column: span 6;
        min-height: 380px;
      }

      .project-card::before {
        content: "";
        position: absolute;
        inset: 0 0 auto 0;
        height: 4px;
        background: var(--accent, var(--navy));
        opacity: 0;
        transition: opacity 0.18s ease;
      }

      .project-card::after {
        content: "";
        position: absolute;
        inset: auto -110px -150px auto;
        width: 300px;
        height: 300px;
        border-radius: 50%;
        background: var(--orb, rgba(11, 36, 63, 0.08));
        pointer-events: none;
        transition: transform 0.22s ease, opacity 0.22s ease;
      }

      .project-card:hover {
        transform: translateY(-5px) scale(1.007);
        box-shadow: var(--shadow);
        border-color: rgba(214, 61, 49, 0.28);
        background: rgba(255, 255, 255, 0.72);
      }

      .project-card:hover::before {
        opacity: 1;
      }

      .project-card:hover::after {
        transform: scale(1.08);
        opacity: 0.9;
      }

      .project-card.hidden {
        display: none;
      }

      .project-top,
      .project-bottom {
        position: relative;
        z-index: 1;
      }

      .project-meta {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 18px;
      }

      .tag {
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.56);
        padding: 7px 9px;
        color: var(--muted);
        font-family: var(--mono);
        font-weight: 700;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      .tag.live {
        color: var(--green);
        border-color: rgba(23, 122, 85, 0.24);
      }

      .project-card h3 {
        margin: 0;
        font-family: var(--display);
        font-size: clamp(30px, 3.4vw, 48px);
        letter-spacing: -0.07em;
        line-height: 0.9;
        font-weight: 700;
      }

      .project-card p {
        color: var(--muted);
        line-height: 1.52;
        margin: 16px 0 0;
      }

      .project-bottom {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        margin-top: 30px;
      }

      .project-bottom span {
        color: var(--muted);
        font-size: 13px;
        font-weight: 800;
      }

      .open-btn {
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 10px 12px;
        background: rgba(255, 255, 255, 0.66);
        font-weight: 900;
      }

      .case-stage {
        border: 1px solid var(--line);
        border-radius: var(--radius-xl);
        background: var(--panel);
        backdrop-filter: blur(24px);
        box-shadow: var(--shadow);
        padding: 18px;
        display: grid;
        grid-template-columns: 0.42fr 0.58fr;
        gap: 14px;
      }

      .case-tabs {
        display: grid;
        gap: 10px;
        align-content: start;
      }

      .case-tab {
        border: 1px solid var(--line);
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.54);
        padding: 16px;
        text-align: left;
        transition: 0.18s ease;
      }

      .case-tab:hover,
      .case-tab.active {
        color: white;
        background: var(--navy);
        border-color: var(--navy);
        transform: translateX(4px);
      }

      .case-tab span {
        display: block;
        opacity: 0.64;
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .case-tab strong {
        display: block;
        margin-top: 8px;
        font-size: 20px;
        letter-spacing: -0.04em;
      }

      .case-display {
        border: 1px solid var(--line);
        border-radius: 28px;
        background: rgba(255, 255, 255, 0.62);
        padding: clamp(20px, 4vw, 44px);
        min-height: 620px;
        display: grid;
        align-content: space-between;
        position: relative;
        overflow: hidden;
      }

      .case-display::after {
        content: "";
        position: absolute;
        right: -120px;
        top: -120px;
        width: 300px;
        height: 300px;
        border-radius: 50%;
        border: 1px solid rgba(214, 61, 49, 0.18);
      }

      .case-display > * {
        position: relative;
        z-index: 1;
      }

      .case-kicker {
        margin: 0 0 12px;
        color: var(--red);
        font-family: var(--mono);
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.14em;
      }

      .case-display h3 {
        margin: 0;
        font-family: var(--display);
        font-size: clamp(42px, 5vw, 78px);
        line-height: 0.84;
        letter-spacing: -0.075em;
        font-weight: 720;
      }

      .case-copy {
        margin: 22px 0 0;
        color: var(--muted);
        font-size: 18px;
        line-height: 1.58;
        max-width: 860px;
      }

      .case-matrix {
        margin-top: 28px;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
      }

      .case-cell {
        border: 1px solid var(--line);
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.58);
        padding: 16px;
        min-height: 128px;
      }

      .case-cell span {
        display: block;
        color: var(--muted);
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      .case-cell strong {
        display: block;
        margin-top: 10px;
        font-size: 17px;
        letter-spacing: -0.03em;
        line-height: 1.25;
      }

      .case-actions {
        margin-top: 32px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .fields-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
      }

      .field-card {
        border: 1px solid var(--line);
        background: var(--panel);
        border-radius: 28px;
        padding: 20px;
        box-shadow: var(--soft-shadow);
        min-height: 290px;
        transition: 0.18s ease;
      }

      .field-card:hover {
        transform: translateY(-4px);
        border-color: rgba(214, 61, 49, 0.22);
        background: rgba(255, 255, 255, 0.72);
      }

      .field-card span {
        color: var(--muted);
        font-family: var(--mono);
        font-weight: 700;
        letter-spacing: 0.12em;
        font-size: 11px;
        text-transform: uppercase;
      }

      .field-card h3 {
        margin: 30px 0 0;
        font-family: var(--display);
        font-size: 36px;
        line-height: 0.92;
        letter-spacing: -0.065em;
        font-weight: 720;
      }

      .field-card p {
        color: var(--muted);
        line-height: 1.52;
      }

      .now-grid {
        display: grid;
        grid-template-columns: 1.12fr 0.88fr;
        gap: 14px;
      }

      .panel {
        border: 1px solid var(--line);
        background: var(--panel);
        border-radius: var(--radius-xl);
        padding: 22px;
        box-shadow: var(--soft-shadow);
      }

      .queue {
        display: grid;
        gap: 10px;
      }

      .queue-item {
        display: grid;
        grid-template-columns: 120px 1fr auto;
        gap: 14px;
        align-items: center;
        border: 1px solid var(--line);
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.52);
        padding: 14px;
      }

      .queue-item span {
        color: var(--muted);
        font-family: var(--mono);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.11em;
        font-weight: 700;
      }

      .queue-item strong {
        letter-spacing: -0.03em;
      }

      .queue-item em {
        font-style: normal;
        color: var(--muted);
        font-size: 13px;
      }

      .velocity-panel {
        background:
          linear-gradient(135deg, rgba(214, 61, 49, 0.18), transparent 34%),
          #10100e;
        color: white;
        border-radius: var(--radius-xl);
        padding: 24px;
        min-height: 100%;
        display: grid;
        align-content: space-between;
        position: relative;
        overflow: hidden;
      }

      .velocity-panel::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(115deg, transparent 0 42%, rgba(214, 61, 49, 0.28) 42.2% 42.7%, transparent 43%),
          linear-gradient(rgba(255, 255, 255, 0.045) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.045) 1px, transparent 1px);
        background-size: auto, 30px 30px, 30px 30px;
        opacity: 0.66;
        pointer-events: none;
      }

      .velocity-panel > * {
        position: relative;
        z-index: 1;
      }

      .velocity-panel h3 {
        margin: 0;
        font-family: var(--display);
        font-size: 48px;
        line-height: 0.84;
        letter-spacing: -0.075em;
        font-weight: 720;
      }

      .velocity-panel p {
        color: rgba(255, 255, 255, 0.62);
        line-height: 1.5;
      }

      .velocity-links {
        display: grid;
        gap: 10px;
        margin-top: 22px;
      }

      .velocity-links a {
        border: 1px solid rgba(255, 255, 255, 0.13);
        border-radius: 16px;
        padding: 12px;
        background: rgba(255, 255, 255, 0.06);
        display: flex;
        justify-content: space-between;
        gap: 12px;
      }

      .timeline-list {
        display: grid;
        gap: 10px;
      }

      .timeline-item {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.52);
        border-radius: 22px;
        padding: 18px;
        display: grid;
        grid-template-columns: 170px 1fr;
        gap: 18px;
      }

      .timeline-item span {
        color: var(--red);
        font-family: var(--mono);
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-size: 12px;
      }

      .timeline-item strong {
        display: block;
        font-size: 20px;
        letter-spacing: -0.045em;
      }

      .timeline-item p {
        color: var(--muted);
        margin: 6px 0 0;
        line-height: 1.45;
      }

      .contact-card {
        border: 1px solid var(--line);
        background: var(--panel);
        border-radius: var(--radius-xl);
        padding: clamp(24px, 5vw, 54px);
        box-shadow: var(--shadow);
        display: grid;
        grid-template-columns: 1fr 0.9fr;
        gap: 22px;
      }

      .contact-card h2 {
        margin: 0;
        font-family: var(--display);
        font-size: clamp(48px, 7vw, 104px);
        line-height: 0.82;
        letter-spacing: -0.08em;
        font-weight: 720;
      }

      .contact-card p {
        color: var(--muted);
        font-size: 18px;
        line-height: 1.55;
      }

      .contact-links {
        display: grid;
        gap: 10px;
      }

      .contact-links a,
      .contact-links div {
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 16px;
        background: rgba(255, 255, 255, 0.58);
        display: flex;
        justify-content: space-between;
        gap: 16px;
        font-weight: 900;
        transition: 0.18s ease;
      }

      .contact-links a:hover {
        transform: translateY(-2px);
        border-color: rgba(214, 61, 49, 0.26);
        background: rgba(255, 255, 255, 0.78);
      }

      .contact-links span {
        color: var(--muted);
      }

      .footer {
        padding: 28px 0 42px;
        color: var(--muted);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
        font-size: 14px;
      }

      .reveal {
        opacity: 0;
        transform: translateY(18px);
        transition:
          opacity 0.55s ease,
          transform 0.55s ease;
      }

      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }

      .modal,
      .command-palette {
        position: fixed;
        inset: 0;
        z-index: 220;
        display: none;
        place-items: center;
        padding: 18px;
        background: rgba(16, 16, 14, 0.42);
        backdrop-filter: blur(18px);
      }

      .modal.open,
      .command-palette.open {
        display: grid;
      }

      .modal-card,
      .command-card {
        width: min(780px, 100%);
        max-height: min(780px, calc(100vh - 40px));
        overflow: auto;
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 28px;
        background: rgba(242, 237, 227, 0.96);
        box-shadow: var(--shadow);
      }

      .modal-head,
      .command-head {
        position: sticky;
        top: 0;
        background: rgba(242, 237, 227, 0.9);
        backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--line);
        padding: 18px;
        display: flex;
        justify-content: space-between;
        gap: 14px;
      }

      .modal-body,
      .command-body {
        padding: 18px;
      }

      .close-btn {
        border: 1px solid var(--line);
        border-radius: 14px;
        background: white;
        padding: 10px 12px;
        font-weight: 950;
      }

      .modal-title {
        margin: 0;
        font-family: var(--display);
        font-size: 42px;
        letter-spacing: -0.075em;
        line-height: 0.9;
      }

      .modal-sub {
        color: var(--muted);
        margin: 4px 0 0;
      }

      .modal-body p {
        color: var(--muted);
        line-height: 1.58;
        font-size: 16px;
      }

      .detail-list {
        display: grid;
        gap: 10px;
        margin-top: 18px;
        padding: 0;
      }

      .detail-list li {
        list-style: none;
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 13px;
        background: rgba(255, 255, 255, 0.56);
      }

      .command-input {
        width: 100%;
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 16px;
        background: white;
        outline: none;
        font-weight: 800;
      }

      .command-list {
        display: grid;
        gap: 8px;
        margin-top: 14px;
      }

      .command-list a {
        border: 1px solid var(--line);
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.62);
        padding: 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }

      .command-list span {
        color: var(--muted);
        font-size: 13px;
      }

      @media (max-width: 1160px) {
        .hero,
        .case-stage,
        .now-grid,
        .contact-card {
          grid-template-columns: 1fr;
        }

        .hero-main,
        .ops-panel {
          min-height: auto;
        }

        .project-card,
        .project-card.feature {
          grid-column: span 6;
        }

        .fields-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (max-width: 820px) {
        .nav-links,
        .command-trigger {
          display: none;
        }

        .menu-btn {
          display: inline-flex;
        }

        .nav-links.mobile-open {
          position: fixed;
          left: 16px;
          right: 16px;
          top: 90px;
          display: grid;
          gap: 8px;
          border: 1px solid var(--line);
          border-radius: 22px;
          background: rgba(242, 237, 227, 0.96);
          backdrop-filter: blur(20px);
          padding: 12px;
          box-shadow: var(--shadow);
        }

        .nav-links.mobile-open a {
          display: block;
          padding: 14px;
        }

        .hero-proof,
        .side-grid,
        .case-matrix,
        .fields-grid {
          grid-template-columns: 1fr 1fr;
        }

        .project-card,
        .project-card.feature {
          grid-column: span 12;
        }

        .section-head {
          align-items: flex-start;
          flex-direction: column;
        }

        .queue-item {
          grid-template-columns: 100px 1fr;
        }

        .queue-item em {
          grid-column: 2;
        }

        .timeline-item {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 560px) {
        .shell {
          width: min(100% - 20px, var(--max));
        }

        .hero {
          padding-top: 36px;
        }

        .hero h1 {
          font-size: clamp(58px, 19vw, 92px);
        }

        .hero-proof,
        .side-grid,
        .case-matrix,
        .fields-grid {
          grid-template-columns: 1fr;
        }

        .ops-item {
          grid-template-columns: 1fr;
          gap: 6px;
        }

        .contact-links a,
        .contact-links div {
          flex-direction: column;
        }

        .case-display {
          min-height: auto;
        }
      }
    </style>
  </head>

