<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Traffic Light Control — Aryadhar Gupta</title>
    <meta
      name="description"
      content="Control page for Aryadhar Gupta's NodeMCU traffic light system."
    />
    <meta name="theme-color" content="#f6f4ef" />

    <style>
      :root {
        --bg: #f6f4ef;
        --surface: #ffffff;
        --surface-soft: #f0ede6;
        --text: #171717;
        --muted: #5f6268;
        --subtle: #8a8d93;
        --line: #dedbd3;
        --accent: #12355b;
        --red: #dc2626;
        --yellow: #eab308;
        --green: #16a34a;
        --max: 980px;
        --radius: 18px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", Arial, sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: inherit;
      }

      p,
      h1,
      h2,
      h3 {
        margin-top: 0;
      }

      p:last-child {
        margin-bottom: 0;
      }

      .wrap {
        width: min(calc(100% - 32px), var(--max));
        margin: 0 auto;
      }

      .site-header {
        border-bottom: 1px solid var(--line);
        background: rgba(246, 244, 239, 0.94);
        backdrop-filter: blur(14px);
      }

      .nav {
        min-height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        font-weight: 700;
        letter-spacing: -0.02em;
      }

      .brand-mark {
        width: 36px;
        height: 36px;
        display: grid;
        place-items: center;
        border-radius: 50%;
        background: var(--text);
        color: var(--bg);
        font-size: 0.82rem;
        font-weight: 800;
      }

      .back-link {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.95rem;
      }

      .back-link:hover {
        color: var(--text);
      }

      .hero {
        padding: 76px 0 42px;
      }

      .kicker {
        margin-bottom: 12px;
        color: var(--accent);
        font-size: 0.78rem;
        font-weight: 750;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      h1 {
        max-width: 760px;
        margin-bottom: 18px;
        font-size: clamp(2.5rem, 7vw, 5rem);
        line-height: 0.98;
        letter-spacing: -0.065em;
      }

      .lead {
        max-width: 680px;
        color: var(--muted);
        font-size: clamp(1.02rem, 2vw, 1.18rem);
      }

      .control-shell {
        padding: 0 0 80px;
      }

      .control-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 260px;
        gap: 18px;
        align-items: stretch;
      }

      .card {
        padding: 26px;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: var(--surface);
      }

      .card h2 {
        margin-bottom: 8px;
        font-size: 1.25rem;
        letter-spacing: -0.025em;
      }

      .card p {
        color: var(--muted);
      }

      .button-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(145px, 1fr));
        gap: 12px;
        margin-top: 24px;
      }

      .control-button {
        min-height: 50px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: var(--surface-soft);
        color: var(--text);
        font: inherit;
        font-weight: 700;
        cursor: pointer;
      }

      .control-button:hover {
        border-color: var(--text);
        background: var(--surface);
      }

      .control-button.is-active {
        background: var(--text);
        color: var(--bg);
        border-color: var(--text);
      }

      .timing-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(155px, 1fr));
        gap: 12px;
        margin-top: 22px;
      }

      .time-field {
        padding: 14px;
        border: 1px solid var(--line);
        border-radius: 14px;
        background: var(--bg);
      }

      .time-field label {
        display: block;
        margin-bottom: 6px;
        color: var(--subtle);
        font-size: 0.74rem;
        font-weight: 750;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .time-field input {
        width: 100%;
        min-height: 42px;
        border: 1px solid var(--line);
        border-radius: 10px;
        background: var(--surface);
        color: var(--text);
        font: inherit;
        font-weight: 700;
        padding: 0 12px;
      }

      .toggle-row {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        margin-top: 16px;
        color: var(--muted);
        font-size: 0.94rem;
      }

      .toggle-row input {
        margin-top: 5px;
      }

      .status-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 12px;
        margin-top: 18px;
      }

      .status-box {
        padding: 15px;
        border: 1px solid var(--line);
        border-radius: 14px;
        background: var(--bg);
      }

      .status-box span {
        display: block;
        margin-bottom: 4px;
        color: var(--subtle);
        font-size: 0.74rem;
        font-weight: 750;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .status-box strong {
        font-size: 1rem;
      }

      .countdown-text {
        color: var(--accent);
      }

      .traffic-card {
        display: grid;
        place-items: center;
      }

      .traffic-light {
        width: 154px;
        padding: 18px;
        border-radius: 42px;
        background: #171717;
        border: 1px solid #050505;
      }

      .light {
        width: 92px;
        height: 92px;
        margin: 0 auto 16px;
        border-radius: 50%;
        background: #3a3a3a;
        border: 7px solid #0d0d0d;
        opacity: 0.3;
        transition:
          opacity 160ms ease,
          background 160ms ease,
          box-shadow 160ms ease;
      }

      .light:last-child {
        margin-bottom: 0;
      }

      .light.red.on {
        background: var(--red);
        opacity: 1;
        box-shadow: 0 0 26px rgba(220, 38, 38, 0.5);
      }

      .light.yellow.on {
        background: var(--yellow);
        opacity: 1;
        box-shadow: 0 0 26px rgba(234, 179, 8, 0.5);
      }

      .light.green.on {
        background: var(--green);
        opacity: 1;
        box-shadow: 0 0 26px rgba(22, 163, 74, 0.5);
      }

      .note {
        margin-top: 18px;
        color: var(--muted);
        font-size: 0.94rem;
      }

      footer {
        padding: 28px 0;
        border-top: 1px solid var(--line);
        color: var(--muted);
        font-size: 0.92rem;
      }

      .footer-inner {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 12px;
      }

      @media (max-width: 760px) {
        .nav {
          align-items: flex-start;
          flex-direction: column;
          padding: 14px 0;
        }

        .hero {
          padding: 56px 0 34px;
        }

        .control-grid {
          grid-template-columns: 1fr;
        }

        .card {
          padding: 20px;
        }
      }
    </style>
  </head>

  <body>
    <header class="site-header">
      <div class="wrap nav">
        <a class="brand" href="/" aria-label="Back to Aryadhar Gupta homepage">
          <span class="brand-mark">AG</span>
          <span>Aryadhar Gupta</span>
        </a>

        <a class="back-link" href="/">Back to portfolio</a>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="wrap">
          <div class="kicker">NodeMCU System</div>
          <h1>Traffic light control.</h1>
          <p class="lead">
            A dedicated control page for the ESP8266 / NodeMCU traffic light
            system. Auto mode begins with a 1.5 second startup check where all
            lights turn on before the normal cycle starts.
          </p>
        </div>
      </section>

      <section class="control-shell">
        <div class="wrap">
          <div class="control-grid">
            <div class="card">
              <h2>Manual control</h2>
              <p>
                Use the buttons below to control the light preview. Manual timed
                mode is on by default: the selected light stays on for its set
                duration, then the system returns to Auto mode after the 1.5
                second startup check.
              </p>

              <div class="button-grid">
                <button class="control-button" data-light="red">Red</button>
                <button class="control-button" data-light="yellow">Yellow</button>
                <button class="control-button" data-light="green">Green</button>
                <button class="control-button" data-light="off">All Off</button>
                <button class="control-button" data-light="auto">Auto Mode</button>
              </div>

              <div class="timing-grid">
                <div class="time-field">
                  <label for="redDuration">Red Time</label>
                  <input id="redDuration" type="number" min="1" max="120" value="10" />
                </div>

                <div class="time-field">
                  <label for="yellowDuration">Yellow Time</label>
                  <input id="yellowDuration" type="number" min="1" max="120" value="5" />
                </div>

                <div class="time-field">
                  <label for="greenDuration">Green Time</label>
                  <input id="greenDuration" type="number" min="1" max="120" value="15" />
                </div>
              </div>

              <label class="toggle-row">
                <input id="manualTimedReturn" type="checkbox" checked />
                <span>
                  Manual timed mode: after a manual light finishes its timer,
                  return to Auto mode.
                </span>
              </label>

              <div class="status-grid">
                <div class="status-box">
                  <span>Current Mode</span>
                  <strong id="trafficMode">Starting</strong>
                </div>

                <div class="status-box">
                  <span>Timer</span>
                  <strong id="trafficTimer" class="countdown-text">—</strong>
                </div>

                <div class="status-box">
                  <span>Connection</span>
                  <strong id="trafficConnection">Website preview</strong>
                </div>

                <div class="status-box">
                  <span>Hardware</span>
                  <strong id="trafficHardware">Not connected yet</strong>
                </div>
              </div>

              <p class="note">
                Safety note: the live version should only be connected after the
                relay wiring, insulation, fail-safe behaviour, and 220V AC safety
                precautions are confirmed.
              </p>
            </div>

            <aside class="card traffic-card">
              <div class="traffic-light" aria-label="Traffic light preview">
                <div id="lightRed" class="light red"></div>
                <div id="lightYellow" class="light yellow"></div>
                <div id="lightGreen" class="light green"></div>
              </div>
            </aside>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <div class="wrap footer-inner">
        <span>© <span id="year"></span> Aryadhar Gupta</span>
        <span>Traffic Light Control</span>
      </div>
    </footer>

    <script>
  document.getElementById("year").textContent = new Date().getFullYear();

  const API_BASE = "https://traffic-light-api.gunshots2005.workers.dev";
  const STARTUP_CHECK_MS = 1500;

  const buttons = document.querySelectorAll("[data-light]");
  const modeText = document.getElementById("trafficMode");
  const timerText = document.getElementById("trafficTimer");
  const connectionText = document.getElementById("trafficConnection");
  const hardwareText = document.getElementById("trafficHardware");

  const redLight = document.getElementById("lightRed");
  const yellowLight = document.getElementById("lightYellow");
  const greenLight = document.getElementById("lightGreen");

  const redDurationInput = document.getElementById("redDuration");
  const yellowDurationInput = document.getElementById("yellowDuration");
  const greenDurationInput = document.getElementById("greenDuration");
  const manualTimedReturn = document.getElementById("manualTimedReturn");

  let autoTimer = null;
  let countdownTimer = null;
  let manualReturnTimer = null;
  let autoIndex = 0;

  const autoCycle = ["red", "yellow", "green"];

  function getSeconds(input, fallback) {
    const value = Number(input.value);

    if (!Number.isFinite(value)) {
      return fallback;
    }

    return Math.min(Math.max(value, 1), 120);
  }

  function getTimings() {
    return {
      red: getSeconds(redDurationInput, 10),
      yellow: getSeconds(yellowDurationInput, 5),
      green: getSeconds(greenDurationInput, 15),
    };
  }

  function getDuration(mode) {
    const timings = getTimings();

    if (mode === "red") return timings.red * 1000;
    if (mode === "yellow") return timings.yellow * 1000;
    if (mode === "green") return timings.green * 1000;

    return 0;
  }

  function labelFor(mode) {
    if (mode === "red") return "Red";
    if (mode === "yellow") return "Yellow";
    if (mode === "green") return "Green";
    if (mode === "auto") return "Auto Mode";
    if (mode === "off") return "All Off";
    return "Unknown";
  }

  function clearTimers() {
    clearTimeout(autoTimer);
    clearTimeout(manualReturnTimer);
    clearInterval(countdownTimer);

    autoTimer = null;
    manualReturnTimer = null;
    countdownTimer = null;
  }

  function clearLights() {
    redLight.classList.remove("on");
    yellowLight.classList.remove("on");
    greenLight.classList.remove("on");
  }

  function allLightsOn() {
    redLight.classList.add("on");
    yellowLight.classList.add("on");
    greenLight.classList.add("on");
  }

  function clearActiveButtons() {
    buttons.forEach((button) => button.classList.remove("is-active"));
  }

  function setActiveButton(mode) {
    clearActiveButtons();

    const activeButton = document.querySelector(`[data-light="${mode}"]`);

    if (activeButton) {
      activeButton.classList.add("is-active");
    }
  }

  function showOnly(mode) {
    clearLights();

    if (mode === "red") redLight.classList.add("on");
    if (mode === "yellow") yellowLight.classList.add("on");
    if (mode === "green") greenLight.classList.add("on");
  }

  function startCountdown(label, durationMs) {
    clearInterval(countdownTimer);

    const endTime = Date.now() + durationMs;

    function updateCountdown() {
      const remainingMs = Math.max(0, endTime - Date.now());
      const remainingSeconds = Math.ceil(remainingMs / 1000);
      timerText.textContent = `${label}: ${remainingSeconds}s`;
    }

    updateCountdown();
    countdownTimer = setInterval(updateCountdown, 250);
  }

  function startStartupCountdown() {
    clearInterval(countdownTimer);

    const endTime = Date.now() + STARTUP_CHECK_MS;

    function updateStartupCountdown() {
      const remainingMs = Math.max(0, endTime - Date.now());
      const remainingSeconds = (remainingMs / 1000).toFixed(1);
      timerText.textContent = `Startup check: ${remainingSeconds}s`;
    }

    updateStartupCountdown();
    countdownTimer = setInterval(updateStartupCountdown, 100);
  }

  async function sendCommand(mode) {
    const timings = getTimings();

    connectionText.textContent = "Sending command...";

    const response = await fetch(`${API_BASE}/api/command`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        mode,
        red: timings.red,
        yellow: timings.yellow,
        green: timings.green,
      }),
    });

    const data = await response.json();

    if (!response.ok || !data.ok) {
      throw new Error(data.error || "Command failed");
    }

    connectionText.textContent = "Connected to API";
    hardwareText.textContent = "Waiting for NodeMCU";

    return data.state;
  }

  async function loadStateFromApi() {
    connectionText.textContent = "Loading API state...";

    const response = await fetch(`${API_BASE}/api/state`);
    const data = await response.json();

    if (!response.ok || !data.ok) {
      throw new Error(data.error || "Could not load state");
    }

    redDurationInput.value = data.state.red || 10;
    yellowDurationInput.value = data.state.yellow || 5;
    greenDurationInput.value = data.state.green || 15;

    connectionText.textContent = "Connected to API";
    hardwareText.textContent = "Waiting for NodeMCU";

    return data.state;
  }

  function startAutoWithCheck() {
    clearTimers();

    setActiveButton("auto");
    clearLights();
    allLightsOn();

    modeText.textContent = "Startup Check";
    connectionText.textContent = "Connected to API";
    startStartupCountdown();

    autoTimer = setTimeout(() => {
      clearInterval(countdownTimer);
      autoIndex = 0;
      runAutoStep();
    }, STARTUP_CHECK_MS);
  }

  function runAutoStep() {
    const mode = autoCycle[autoIndex];
    const duration = getDuration(mode);

    setActiveButton("auto");
    showOnly(mode);

    modeText.textContent = `Auto — ${labelFor(mode)}`;
    connectionText.textContent = "Connected to API";
    startCountdown(labelFor(mode), duration);

    autoTimer = setTimeout(() => {
      autoIndex = (autoIndex + 1) % autoCycle.length;
      runAutoStep();
    }, duration);
  }

  function setManualPreview(mode) {
    clearTimers();

    if (mode === "off") {
      clearLights();
      setActiveButton("off");
      modeText.textContent = "All Off";
      timerText.textContent = "Hold";
      connectionText.textContent = "Connected to API";
      return;
    }

    showOnly(mode);
    setActiveButton(mode);

    modeText.textContent = `Manual — ${labelFor(mode)}`;
    connectionText.textContent = "Connected to API";

    if (manualTimedReturn.checked) {
      const duration = getDuration(mode);
      startCountdown(`Manual ${labelFor(mode)}`, duration);

      manualReturnTimer = setTimeout(async () => {
        try {
          await sendCommand("auto");
          startAutoWithCheck();
        } catch (error) {
          connectionText.textContent = "API error";
          timerText.textContent = "Auto return failed";
          console.error(error);
        }
      }, duration);
    } else {
      timerText.textContent = "Hold until changed";
    }
  }

  async function handleButtonClick(mode) {
    try {
      await sendCommand(mode);

      if (mode === "auto") {
        startAutoWithCheck();
        return;
      }

      setManualPreview(mode);
    } catch (error) {
      connectionText.textContent = "API error";
      timerText.textContent = "Command failed";
      console.error(error);
    }
  }

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      handleButtonClick(button.dataset.light);
    });
  });

  [redDurationInput, yellowDurationInput, greenDurationInput].forEach((input) => {
    input.addEventListener("change", () => {
      input.value = getSeconds(input, Number(input.defaultValue));
    });
  });

  async function bootPage() {
    try {
      const state = await loadStateFromApi();

      if (state.mode === "auto") {
        startAutoWithCheck();
        return;
      }

      setManualPreview(state.mode);
    } catch (error) {
      connectionText.textContent = "API offline";
      hardwareText.textContent = "Not connected";
      timerText.textContent = "Local preview only";
      console.error(error);

      startAutoWithCheck();
    }
  }

  bootPage();
</script>
  </body>
</html>
