---
const pageTitle = "About | AG Systems";
const pageDescription =
  "AG Systems is a technology systems company by Aryadhar Gupta — custom operational software, dashboards, and connected hardware for physical businesses.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={pageDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <style>
      :root {
        --paper: #f3eee5;
        --ink: #15130f;
        --body: #3b372f;
        --muted: #70675b;
        --rule: rgba(21, 19, 15, 0.15);
        --rule-strong: rgba(21, 19, 15, 0.34);
        --white: #fffaf0;
        --max: 760px;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        background: linear-gradient(180deg, var(--paper), #f6f1e8 46%, var(--paper));
        color: var(--ink);
        font-family: "Segoe UI", Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      a { color: inherit; text-decoration: none; }

      .wrap { width: min(var(--max), calc(100% - 48px)); margin: 0 auto; }

      .topbar {
        position: sticky;
        top: 0;
        z-index: 30;
        border-bottom: 1px solid var(--rule);
        background: rgba(243, 238, 229, 0.9);
        backdrop-filter: blur(16px);
      }

      .nav {
        min-height: 64px;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .brand-name {
        font-size: 18px;
        font-weight: 700;
        letter-spacing: -0.045em;
      }

      .backlink {
        font-size: 13px;
        color: var(--muted);
        border-bottom: 1px solid transparent;
        padding-bottom: 2px;
      }

      .backlink:hover {
        color: var(--ink);
        border-color: var(--ink);
      }

      .label {
        margin: 0 0 16px;
        color: var(--muted);
        font-size: 12px;
        letter-spacing: 0.07em;
        text-transform: uppercase;
      }

      .label::before {
        content: "";
        display: inline-block;
        width: 28px;
        height: 1px;
        margin-right: 10px;
        vertical-align: middle;
        background: var(--rule-strong);
      }

      main { padding: 56px 0 72px; }

      h1 {
        margin: 0;
        max-width: 640px;
        font-family: Georgia, "Times New Roman", ui-serif, serif;
        font-size: clamp(36px, 5vw, 54px);
        line-height: 1;
        letter-spacing: -0.055em;
        font-weight: 500;
      }

      .copy {
        max-width: 640px;
        margin: 22px 0 0;
        color: var(--body);
        font-size: 17px;
        line-height: 1.6;
      }

      .copy + .copy { margin-top: 16px; }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 28px;
      }

      .button {
        min-height: 40px;
        display: inline-flex;
        align-items: center;
        padding: 0 14px;
        border: 1px solid var(--rule-strong);
        font-size: 13px;
        font-weight: 600;
      }

      .button:hover {
        background: var(--ink);
        border-color: var(--ink);
        color: var(--white);
      }

      .button-dark {
        background: var(--ink);
        border-color: var(--ink);
        color: var(--white);
      }

      .button-dark:hover { opacity: 0.86; }

      .footer {
        padding: 22px 0;
        border-top: 1px solid var(--rule);
        color: var(--muted);
        font-size: 12px;
      }
    </style>
  </head>
  <body>
    <header class="topbar">
      <div class="wrap nav">
        <a class="brand-name" href="/">AG Systems</a>
        <a class="backlink" href="/">← Home</a>
      </div>
    </header>

    <main>
      <div class="wrap">
        <p class="label">About</p>
        <h1>A technology systems company by Aryadhar Gupta.</h1>
        <p class="copy">
          AG Systems builds custom operational software, dashboards, and connected hardware for physical
          businesses — systems designed around how the operation actually runs.
        </p>
        <p class="copy">
          Founder-led work. When an off-the-shelf tool does not fit the process, the system is built from
          the ground up.
        </p>
        <div class="actions">
          <a class="button button-dark" href="/#systems">View Working Systems</a>
          <a class="button" href="/#contact">Start a Project</a>
        </div>
      </div>
    </main>

    <footer class="footer">
      <div class="wrap">© {new Date().getFullYear()} AG Systems.</div>
    </footer>
  </body>
</html>
